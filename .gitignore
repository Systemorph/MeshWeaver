*.SdkResolver.*.proj

# Build output
dist/

# Kernel cache files
samples/Graph/Data/kernel/
samples/Graph/Data/test/
samples/Graph/Data/VUser/

# Azurite emulator state (entire directory)
/memex/Azurite/

# User activity data
**/_useractivity/

# Runtime-generated notification satellites the framework writes into the
# FileSystem-backed sample data during local runs (createdBy=system-security,
# GUID ids, e.g. "Type 'X' failed to compile") — generated output, not source.
**/_Notification/

# Throwaway single-segment scratch partition roots from local sessions (c1, c2, …).
/samples/Graph/Data/c[1-6].json

# Claude Code per-user local state (settings.local.json, plans/, scheduled_tasks.lock, etc.)
# — but DO track the shared team skills under .claude/skills/. The debug/ and release/
# skills also need explicit negations because the generic [Dd]ebug/ / [Rr]elease/
# build-output ignores above otherwise swallow them.
.claude/*
!.claude/skills/
!.claude/skills/debug/
!.claude/skills/release/
