<Project>  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowedOutputExtensionsInPackageBuildOutputFolder>$(AllowedOutputExtensionsInPackageBuildOutputFolder);.pdb</AllowedOutputExtensionsInPackageBuildOutputFolder>
    <DeployPath>$(SolutionDir)deploy</DeployPath>
    <Authors>Systemorph</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/Systemorph/MeshWeaver</RepositoryUrl>
    <NoWarn>649;CA2255;NU5104;$(NoWarn)</NoWarn>
    <DefineConstants Condition=" '$(CIRun)' == 'true' ">$(DefineConstants);CIRun</DefineConstants>
    <!-- Suppress FluentAssertions license warning for open source project -->
    <FLUENTASSERTIONS_SUPPRESS_WARNING>true</FLUENTASSERTIONS_SUPPRESS_WARNING>
  </PropertyGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <!-- Copy dynamic compilation cache to output directory during build -->
  <Target Name="CopyMeshCache" AfterTargets="Build" Condition="Exists('$(SolutionDir).mesh-cache')">
    <ItemGroup>
      <MeshCacheFiles Include="$(SolutionDir).mesh-cache\*.dll" />
      <MeshCacheFiles Include="$(SolutionDir).mesh-cache\*.pdb" />
    </ItemGroup>
    <Copy SourceFiles="@(MeshCacheFiles)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
  </Target>
</Project>
