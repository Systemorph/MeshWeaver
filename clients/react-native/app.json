{
  "expo": {
    "name": "MeshWeaver",
    "slug": "meshweaver-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cloud.meshweaver.mobile",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": { "package": "cloud.meshweaver.mobile" },
    "extra": {
      "portalUrl": "http://localhost:5250"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "MeshWeaver records the microphone for speech-to-text (transcribed on the centralized Whisper service, not on this device)."
        }
      ]
    ]
  }
}
