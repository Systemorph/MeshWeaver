{
  "name": "meshweaver-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "MeshWeaver on React Native / Expo — the native leaf pack over @meshweaver/react/core. The MAUI peer.",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "web:export": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.1",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-status-bar": "~2.0.0",
    "marked": "^18.0.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-fetch-api": "^3.0.0",
    "react-native-render-html": "^6.3.4",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "text-encoding": "^0.7.0",
    "web-streams-polyfill": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/react": "~18.3.0",
    "@types/react-test-renderer": "~18.3.0",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
