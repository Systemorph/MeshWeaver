{
  "name": "@meshweaver/react",
  "version": "0.1.0",
  "description": "React + Fluent UI renderer for MeshWeaver layout areas — the web/Electron/React-Native-capable counterpart of the MAUI MauiViewPack.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./wire": {
      "types": "./dist/live/wire.d.ts",
      "import": "./dist/live/wire.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "dev": "vite",
    "demo:build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "electron": "electron electron/main.cjs",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-icons": "^2.0.260",
    "@monaco-editor/react": "^4.7.0",
    "chart.js": "^4.4.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.1.1",
    "mermaid": "11.4.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
