{
  "name": "@meshweaver/client",
  "version": "0.1.0",
  "description": "MeshWeaver mesh client over gRPC for Node and Bun — the foreign-language counterpart of the MAUI/SignalR participant.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "meshweaver-node-worker": "./dist/worker.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test test/*.test.mjs",
    "demo": "tsc && node dist/worker.js --demo"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.13",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
