  <ItemGroup>
    <ProjectReference Include="..\Memex.Database.Migration\Memex.Database.Migration.csproj" />
    <ProjectReference Include="..\Memex.Portal.Distributed\Memex.Portal.Distributed.csproj" />
    <ProjectReference Include="..\..\Memex.Portal.Monolith\Memex.Portal.Monolith.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting.AppHost" />
    <PackageReference Include="Aspire.Hosting.Azure.AppContainers" />
    <PackageReference Include="Aspire.Hosting.Azure.ApplicationInsights" />
    <PackageReference Include="Aspire.Hosting.Azure.KeyVault" />
    <PackageReference Include="Aspire.Hosting.Orleans" />
    <PackageReference Include="Aspire.Hosting.Azure.Storage" />
    <PackageReference Include="Aspire.Hosting.PostgreSQL" />
    <PackageReference Include="Aspire.Hosting.Azure.PostgreSQL" />
  </ItemGroup>

</Project>
