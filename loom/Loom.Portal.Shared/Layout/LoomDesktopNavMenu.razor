<FluentAppBar PopoverShowSearch="false" Class="desktop-nav-menu">
    <FluentAppBarItem Href="/" Match="NavLinkMatch.All" IconRest="HomeIcon()"
        IconActive="HomeIcon(active: true)" Text="Home" />
    <FluentDivider Style="width: 100%;" Role="DividerRole.Presentation"></FluentDivider>
    <FluentAppBarItem Href="/graph/_Nodes" Match="NavLinkMatch.Prefix" IconRest="RootIcon()"
        IconActive="RootIcon(true)" Text="Root" />
    <FluentDivider Style="width: 100%;" Role="DividerRole.Presentation"></FluentDivider>
    <FluentAppBarItem Href="/Organizations" Match="NavLinkMatch.Prefix" IconRest="OrganizationIcon()"
        IconActive="OrganizationIcon(true)" Text="Orgs" />
    <FluentDivider Style="width: 100%;" Role="DividerRole.Presentation"></FluentDivider>
    <FluentAppBarItem Href="/People" Match="NavLinkMatch.Prefix" IconRest="PersonIcon()"
        IconActive="PersonIcon(true)" Text="People" />
</FluentAppBar>
