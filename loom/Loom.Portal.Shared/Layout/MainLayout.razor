@using MeshWeaver.Blazor.Portal.Layout
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@inherits PortalLayoutBase

@* Inline styles to override scoped CSS from PortalLayoutBase *@
<style>
    /* Override grid to remove nav column - higher specificity with attribute selector */
    .layout[class],
    div.layout[class] {
        grid-template-columns: auto 1fr !important;
        grid-template-areas:
            "icon head"
            "messagebar messagebar"
            "main main" !important;
    }

    /* Chat right position */
    .layout[class].chat-visible.chat-position-right {
        grid-template-columns: auto 1fr var(--chat-width, 400px) !important;
        grid-template-areas:
            "icon head head"
            "messagebar messagebar chat"
            "main main chat" !important;
    }

    /* Chat bottom position */
    .layout[class].chat-visible.chat-position-bottom {
        grid-template-columns: auto 1fr !important;
        grid-template-rows: auto auto 1fr var(--chat-height, 400px) !important;
        grid-template-areas:
            "icon head"
            "messagebar messagebar"
            "main main"
            "chat chat" !important;
    }

    /* Hide nav bar and remove body border */
    .layout[class] > .fluent-appbar,
    .layout[class] > .desktop-nav-menu {
        display: none !important;
    }

    .layout[class] > .body-content {
        border-left: none !important;
    }

    /* Header links container - flexbox for search + buttons */
    .layout[class] > header .links {
        display: flex !important;
        align-items: center !important;
        flex: 1 !important;
        gap: 8px !important;
    }

    /* Search bar styling */
    .loom-search-container {
        flex: 1;
        display: flex;
        justify-content: flex-end;
        max-width: 400px;
    }

    .loom-search {
        width: 100%;
        min-width: 200px;
    }

    /* Mobile: hide search */
    @@media (max-width: 767px) {
        .loom-search-container {
            display: none;
        }
    }
</style>

@{
    // GitHub-style header - search on right side of brand, then actions
    HeaderLinks = @<text>
        <div class="loom-search-container">
            <FluentSearch Placeholder="Search..." @bind-Value="searchQuery"
                @onkeydown="HandleSearchKeyDown" Class="loom-search" />
        </div>
        <FluentButton Appearance="Appearance.Stealth" Id="create-menu-button"
            Title="Create new" aria-label="Create new" @onclick="@(() => isCreateMenuOpen = !isCreateMenuOpen)">
            <FluentIcon Value="@(new Icons.Regular.Size20.Add())" Color="Color.FillInverse" />
        </FluentButton>
        <FluentMenu Anchor="create-menu-button" @bind-Open="isCreateMenuOpen">
            <FluentMenuItem OnClick="@(() => NavigateToCreate("Organization"))">New Organization</FluentMenuItem>
            <FluentMenuItem OnClick="@(() => NavigateToCreate("Project"))">New Project</FluentMenuItem>
        </FluentMenu>
    </text>;

    // No left navigation menu (GitHub-style full-width content)
    DesktopNavMenu = null;

    // Mobile: Hamburger menu with essential actions
    MobileNavMenu = @<LoomMobileMenu IsOpen="@IsNavMenuOpen" OnClose="@CloseMobileNavMenu"
        OnSearch="@HandleMobileSearch" OnOpenSettings="@OpenSiteSettingsAsync" />;
}

@{
    base.BuildRenderTree(__builder);
}

@code {
    private string searchQuery = "";
    private bool isCreateMenuOpen;

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchQuery))
        {
            NavigationManager.NavigateTo($"/search?q={Uri.EscapeDataString(searchQuery)}");
        }
    }

    private void HandleMobileSearch(string query)
    {
        if (!string.IsNullOrWhiteSpace(query))
        {
            NavigationManager.NavigateTo($"/search?q={Uri.EscapeDataString(query)}");
        }
    }

    private void NavigateToCreate(string type)
    {
        isCreateMenuOpen = false;
        // Phase 2: Will use context-aware creation
        NavigationManager.NavigateTo($"/create/{type}");
    }
}
