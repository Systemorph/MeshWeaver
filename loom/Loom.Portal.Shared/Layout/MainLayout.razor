@using MeshWeaver.Blazor.Portal.Infrastructure
@using MeshWeaver.Blazor.Portal.Layout
@inherits PortalLayoutBase

@{
    // Set render fragments before base renders
    HeaderLinks = @<text>
        <FluentAnchor Appearance="Appearance.Hypertext" Href="http://github.com/Systemorph/MeshWeaver"
            Target="_blank" Rel="noreferrer noopener" title="MeshWeaver on GitHub"
            aria-label="MeshWeaver source on GitHub">
            <FluentIcon Value="@(new PortalIcons.Size20.GitHub())" Color="Color.FillInverse" />
        </FluentAnchor>
    </text>;

    // No DesktopNavMenu - we want a simpler layout without the nav bar
    DesktopNavMenu = null;

    // No MobileNavMenu either for now
    MobileNavMenu = null;
}

@{
    base.BuildRenderTree(__builder);
}
