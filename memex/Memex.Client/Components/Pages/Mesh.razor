@page "/mesh"
@using MeshWeaver.Messaging
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Maui.Storage
@inject IServiceProvider Services

<PageTitle>Mesh</PageTitle>

<h1>Memex — mesh participant</h1>

<p>This client joins the MeshWeaver mesh as a SignalR participant. Interactive Blazor runs
   <strong>in-process</strong>; only mesh data crosses the persistent socket.</p>

<dl>
    <dt>Portal address</dt>
    <dd><code>@(_address ?? "(mesh hub not available)")</code></dd>
    <dt>Transport</dt>
    <dd>SignalR (<code>/signalr</code>) — <code>signalr client ⇒ portal hub ⇒ rest of mesh</code></dd>
</dl>

<div class="mb-3" style="max-width: 32rem">
    <label class="form-label">API token (identity)</label>
    <div class="input-group">
        <input class="form-control" type="password" @bind="_token" placeholder="mw_…" />
        <button class="btn btn-primary" @onclick="SaveTokenAsync">Save</button>
    </div>
    <small class="text-muted">
        The token authenticates this participant; the server stamps your identity on every write.
        Without it, writes are anonymous (RLS-denied). Reconnect (or restart) to apply.
    </small>
    @if (!string.IsNullOrEmpty(_status))
    {
        <div class="mt-1"><em>@_status</em></div>
    }
</div>

@code {
    private string _token = "";
    private string? _status;
    private string? _address;

    protected override async Task OnInitializedAsync()
    {
        try { _token = await SecureStorage.Default.GetAsync("mesh.token") ?? ""; }
        catch { /* SecureStorage unavailable on this platform */ }
        // Resolve the participant hub safely — never let a failed build/connect blank the page.
        try { _address = Services.GetService<IMessageHub>()?.Address?.ToString(); }
        catch (Exception ex) { _status = $"Mesh hub unavailable: {ex.Message}"; }
    }

    private async Task SaveTokenAsync()
    {
        try
        {
            await SecureStorage.Default.SetAsync("mesh.token", _token);
            _status = "Saved. Reconnect to apply.";
        }
        catch (Exception ex)
        {
            _status = $"Could not save token: {ex.Message}";
        }
    }
}
