@page "/voice"
@using System.Reactive.Linq
@using Memex.Client.Voice
@using Memex.Client.Services
@using MeshWeaver.Messaging
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Maui.Media
@using Microsoft.Maui.Storage
@inject AudioCaptureService Capture
@inject VoiceService VoiceSvc
@inject IServiceProvider Services
@implements IDisposable

<PageTitle>Voice</PageTitle>

<div class="voice-page container py-3" style="max-width: 720px;">
    <h1 class="h3 mb-1">🎙️ Voice</h1>
    <p class="text-muted">Speech is transcribed <strong>on this device</strong> (Whisper). If a mesh is
        connected, the transcript opens a thread and the agent's reply is spoken back.</p>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-7">
                    <label class="form-label fw-semibold">Language</label>
                    <select class="form-select" @bind="_language" disabled="@_busy">
                        @foreach (var (langCode, label) in Languages)
                        {
                            <option value="@langCode">@label</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-5 d-grid">
                    @if (!Capture.IsRecording)
                    {
                        <button class="btn btn-primary btn-lg" @onclick="StartAsync" disabled="@_busy">
                            ● Record
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-danger btn-lg" @onclick="StopAsync">
                            ■ Stop &amp; transcribe
                        </button>
                    }
                </div>
            </div>

            @if (Capture.IsRecording)
            {
                <div class="mt-3 d-flex align-items-center text-danger">
                    <span class="recording-dot me-2"></span> Recording… speak now.
                </div>
            }

            @if (_busy)
            {
                <div class="mt-3">
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span>@(_status ?? "Transcribing on device…")</span>
                        <span>@_progress%</span>
                    </div>
                    <div class="progress" role="progressbar" aria-valuenow="@_progress" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar progress-bar-striped progress-bar-animated"
                             style="width:@(_progress)%"></div>
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(_status))
            {
                <p class="mt-3 mb-0 text-muted"><em>@_status</em></p>
            }
        </div>
    </div>

    @if (_segments.Count > 0)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold">You said</div>
            <div class="card-body"><p class="mb-0">@string.Join(" ", _segments.Select(s => s.Text))</p></div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_reply))
    {
        <div class="card shadow-sm mb-3 border-primary">
            <div class="card-header fw-semibold text-primary">Agent</div>
            <div class="card-body">
                <p class="card-text">@_reply</p>
                <button class="btn btn-outline-secondary btn-sm" @onclick="SpeakReplyAsync">🔊 Speak again</button>
            </div>
        </div>
    }

    <details class="mb-3">
        <summary class="text-muted">Conversation settings</summary>
        <div class="row g-2 mt-1">
            <div class="col-12 col-md-6">
                <label class="form-label small">Thread namespace</label>
                <input class="form-control form-control-sm" @bind="_namespace" placeholder="rbuergi" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label small">Agent (optional)</label>
                <input class="form-control form-control-sm" @bind="_agent" placeholder="Assistant" />
            </div>
        </div>
    </details>
</div>

<style>
    .recording-dot { width: 12px; height: 12px; border-radius: 50%; background: #dc3545;
        display: inline-block; animation: voice-pulse 1s ease-in-out infinite; }
    @@keyframes voice-pulse { 0%,100% { opacity: 1; } 50% { opacity: .3; } }
</style>

@code {
    private static readonly (string Code, string Label)[] Languages =
    {
        (WhisperTranscriber.AutoPreferGermanEnglish, "Auto — German / Swiss German / English first, then any"),
        ("auto", "Auto — any language"),
        ("de", "German / Swiss German → Standard German"),
        ("en", "English"),
        ("fr", "French"),
        ("it", "Italian"),
        ("es", "Spanish"),
        ("pt", "Portuguese"),
        ("nl", "Dutch"),
    };

    private string _language = WhisperTranscriber.AutoPreferGermanEnglish;
    private bool _busy;
    private int _progress;
    private string? _status;
    private readonly List<TranscriptSegment> _segments = new();
    private IDisposable? _transcribeSub;

    private string _namespace = "";
    private string _agent = "";
    private string? _threadPath;
    private string? _reply;
    private IDisposable? _replySub;
    private IMessageHub? _hub;

    protected override void OnInitialized()
    {
        _namespace = Preferences.Default.Get("thread.namespace", "");
        _agent = Preferences.Default.Get("thread.agent", "");
        try { _hub = Services.GetService<IMessageHub>(); }
        catch (Exception ex) { _status = $"(mesh unavailable: {ex.Message})"; }
    }

    private async Task StartAsync()
    {
        _reply = null;
        _segments.Clear();
        _status = null;
        await Capture.StartAsync();
    }

    private async Task StopAsync()
    {
        _busy = true;
        _progress = 0;
        _segments.Clear();
        _status = "Transcribing on device…";

        var samples = await Capture.StopAsync();
        if (samples.Length == 0)
        {
            _busy = false;
            _status = "No audio captured.";
            return;
        }

        // Reactive: inference runs on the IoPool (off the UI thread). We just subscribe and render.
        _transcribeSub?.Dispose();
        var progress = new Progress<int>(p => InvokeAsync(() => { _progress = p; StateHasChanged(); }));
        var status = new Progress<string>(s => InvokeAsync(() => { _status = s; StateHasChanged(); }));

        _transcribeSub = VoiceSvc.Transcribe(samples, _language, progress, status).Subscribe(
            seg => InvokeAsync(() => { _segments.Add(seg); StateHasChanged(); }),
            ex => InvokeAsync(() => { _busy = false; _status = $"Error: {ex.Message}"; StateHasChanged(); }),
            () => InvokeAsync(() => { _busy = false; _progress = 100; OnTranscribed(); StateHasChanged(); }));
    }

    private void OnTranscribed()
    {
        var text = string.Join(" ", _segments.Select(s => s.Text)).Trim();
        if (text.Length == 0) { _status = "Nothing recognised."; return; }

        if (_hub is null) { _status = $"Transcribed. (Mesh not connected — transcription only.)"; return; }
        if (string.IsNullOrWhiteSpace(_namespace))
        {
            _status = "Transcribed. (Set a thread namespace under “Conversation settings” to chat.)";
            return;
        }

        Preferences.Default.Set("thread.namespace", _namespace);
        Preferences.Default.Set("thread.agent", _agent);
        _status = _threadPath is null ? "Opening thread…" : "Sent — agent is thinking…";

        _hub.SpeakToThread(
            _threadPath, _namespace, text,
            string.IsNullOrWhiteSpace(_agent) ? null : _agent,
            onThreadOpened: path =>
            {
                _threadPath = path;
                SubscribeReplies(path);
                InvokeAsync(StateHasChanged);
            },
            onError: err => InvokeAsync(() => { _status = $"Thread error: {err}"; StateHasChanged(); }));
    }

    private void SubscribeReplies(string threadPath)
    {
        if (_hub is null) return;
        _replySub?.Dispose();
        _replySub = _hub.ObserveAssistantReplies(threadPath).Subscribe(
            reply => InvokeAsync(async () =>
            {
                _reply = reply;
                _status = "Reply received.";
                StateHasChanged();
                await SpeakReplyAsync();
            }),
            ex => InvokeAsync(() => { _status = $"Reply stream error: {ex.Message}"; StateHasChanged(); }));
    }

    private async Task SpeakReplyAsync()
    {
        if (!string.IsNullOrWhiteSpace(_reply))
            await TextToSpeech.Default.SpeakAsync(_reply);
    }

    public void Dispose()
    {
        _transcribeSub?.Dispose();
        _replySub?.Dispose();
    }
}
