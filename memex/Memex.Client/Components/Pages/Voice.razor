@page "/voice"
@using Memex.Client.Voice
@using Memex.Client.Services
@inject AudioCaptureService Capture
@inject VoiceService VoiceSvc

<PageTitle>Voice</PageTitle>

<h1>Voice — on-device Whisper</h1>

<p>Speech is transcribed <strong>on this device</strong> with Whisper (whisper.cpp). Nothing leaves
   the phone; works offline. The model downloads once on first use.</p>

<div class="mb-3">
    <label class="form-label">Language</label>
    <select class="form-select" style="max-width: 20rem" @bind="_language" disabled="@_busy">
        <option value="auto">Auto-detect</option>
        <option value="de">German / Swiss German → Standard German</option>
        <option value="en">English</option>
        <option value="fr">French</option>
        <option value="it">Italian</option>
    </select>
</div>

@if (!Capture.IsRecording)
{
    <button class="btn btn-primary" @onclick="StartAsync" disabled="@_busy">● Record</button>
}
else
{
    <button class="btn btn-danger" @onclick="StopAsync">■ Stop &amp; transcribe</button>
}

@if (!string.IsNullOrEmpty(_status))
{
    <p class="mt-3"><em>@_status</em></p>
}

@if (_segments is { Count: > 0 })
{
    <table class="table table-sm mt-3">
        <thead><tr><th>Time</th><th>Text</th></tr></thead>
        <tbody>
            @foreach (var s in _segments)
            {
                <tr>
                    <td class="text-nowrap">@s.Start.ToString(@"mm\:ss") – @s.End.ToString(@"mm\:ss")</td>
                    <td>@s.Text</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private string _language = "auto";
    private bool _busy;
    private string? _status;
    private IReadOnlyList<TranscriptSegment>? _segments;

    private async Task StartAsync()
    {
        _segments = null;
        _status = "Recording… speak now.";
        await Capture.StartAsync();
    }

    private async Task StopAsync()
    {
        _busy = true;
        _status = "Processing…";
        try
        {
            var samples = await Capture.StopAsync();
            if (samples.Length == 0)
            {
                _status = "No audio captured.";
                return;
            }

            var progress = new Progress<string>(m => { _status = m; InvokeAsync(StateHasChanged); });
            _segments = await VoiceSvc.TranscribeAsync(samples, _language, progress);
            _status = $"Done — {_segments.Count} segment(s), {samples.Length / 16000.0:F1}s of audio.";
        }
        catch (Exception ex)
        {
            _status = $"Error: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }
}
