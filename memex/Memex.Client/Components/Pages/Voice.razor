@page "/voice"
@using Memex.Client.Voice
@using Memex.Client.Services
@using MeshWeaver.Messaging
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Maui.Media
@using Microsoft.Maui.Storage
@inject AudioCaptureService Capture
@inject VoiceService VoiceSvc
@inject IServiceProvider Services
@implements IDisposable

<PageTitle>Voice</PageTitle>

<h1>Voice — on-device Whisper</h1>

<p>Speech is transcribed <strong>on this device</strong> (Whisper). If the mesh is connected, the
   transcript opens/feeds a thread and the agent's reply is spoken back.</p>

<details class="mb-3">
    <summary>Conversation</summary>
    <div class="row g-2 mt-1">
        <div class="col-12 col-md-6">
            <label class="form-label">Thread namespace</label>
            <input class="form-control" @bind="_namespace" placeholder="rbuergi" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">Agent (optional)</label>
            <input class="form-control" @bind="_agent" placeholder="Assistant" />
        </div>
    </div>
</details>

<div class="mb-3">
    <label class="form-label">Language</label>
    <select class="form-select" style="max-width: 24rem" @bind="_language" disabled="@_busy">
        <option value="auto-de-en-first">Auto — German/Swiss German/English first, then any</option>
        <option value="auto-de-en">German · English only (Swiss German → German)</option>
        <option value="de">German / Swiss German → Standard German</option>
        <option value="en">English</option>
        <option value="auto">Auto — any language</option>
        <option value="fr">French</option>
        <option value="it">Italian</option>
    </select>
</div>

@if (!Capture.IsRecording)
{
    <button class="btn btn-primary" @onclick="StartAsync" disabled="@_busy">● Record</button>
}
else
{
    <button class="btn btn-danger" @onclick="StopAsync">■ Stop &amp; transcribe</button>
}

@if (!string.IsNullOrEmpty(_status))
{
    <p class="mt-3"><em>@_status</em></p>
}

@if (_segments is { Count: > 0 })
{
    <h5 class="mt-3">You said</h5>
    <p>@string.Join(" ", _segments.Select(s => s.Text))</p>
}

@if (!string.IsNullOrEmpty(_reply))
{
    <div class="card mt-3">
        <div class="card-header">Agent</div>
        <div class="card-body">
            <p class="card-text">@_reply</p>
            <button class="btn btn-outline-secondary btn-sm" @onclick="SpeakReplyAsync">🔊 Speak again</button>
        </div>
    </div>
}

@code {
    private string _language = "auto-de-en-first";
    private bool _busy;
    private string? _status;
    private IReadOnlyList<TranscriptSegment>? _segments;

    private string _namespace = "";
    private string _agent = "";
    private string? _threadPath;
    private string? _reply;
    private IDisposable? _replySub;

    // The participant hub is resolved SAFELY — if it can't build/connect (e.g. portal not reachable),
    // on-device transcription still works; only the thread round-trip is unavailable.
    private IMessageHub? _hub;

    protected override void OnInitialized()
    {
        _namespace = Preferences.Default.Get("thread.namespace", "");
        _agent = Preferences.Default.Get("thread.agent", "");
        try { _hub = Services.GetService<IMessageHub>(); }
        catch (Exception ex) { _status = $"(mesh unavailable: {ex.Message})"; }
    }

    private async Task StartAsync()
    {
        _status = "Recording… speak now.";
        await Capture.StartAsync();
    }

    private async Task StopAsync()
    {
        _busy = true;
        _status = "Transcribing on device…";
        try
        {
            var samples = await Capture.StopAsync();
            if (samples.Length == 0) { _status = "No audio captured."; return; }

            var progress = new Progress<string>(m => { _status = m; InvokeAsync(StateHasChanged); });
            _segments = await VoiceSvc.TranscribeAsync(samples, _language, progress);
            var text = string.Join(" ", _segments.Select(s => s.Text)).Trim();
            if (text.Length == 0) { _status = "Nothing recognised."; return; }

            // On-device transcription succeeded. Sending to a thread is best-effort.
            if (_hub is null)
            {
                _status = $"Transcribed — {_segments.Count} segment(s). (Mesh not connected — transcription only.)";
                return;
            }
            if (string.IsNullOrWhiteSpace(_namespace))
            {
                _status = $"Transcribed — {_segments.Count} segment(s). (Set a namespace under “Conversation” to send to a thread.)";
                return;
            }

            Preferences.Default.Set("thread.namespace", _namespace);
            Preferences.Default.Set("thread.agent", _agent);

            _status = _threadPath is null ? "Opening thread…" : "Sent — agent is thinking…";
            _hub.SpeakToThread(
                _threadPath, _namespace, text,
                string.IsNullOrWhiteSpace(_agent) ? null : _agent,
                onThreadOpened: path =>
                {
                    _threadPath = path;
                    SubscribeReplies(path);
                    InvokeAsync(StateHasChanged);
                },
                onError: err => { _status = $"Thread error: {err}"; InvokeAsync(StateHasChanged); });
        }
        catch (Exception ex)
        {
            _status = $"Error: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private void SubscribeReplies(string threadPath)
    {
        if (_hub is null) return;
        _replySub?.Dispose();
        _replySub = _hub.ObserveAssistantReplies(threadPath).Subscribe(
            reply => InvokeAsync(async () =>
            {
                _reply = reply;
                _status = "Reply received.";
                StateHasChanged();
                await SpeakReplyAsync();
            }),
            ex => InvokeAsync(() => { _status = $"Reply stream error: {ex.Message}"; StateHasChanged(); }));
    }

    private async Task SpeakReplyAsync()
    {
        if (!string.IsNullOrWhiteSpace(_reply))
            await TextToSpeech.Default.SpeakAsync(_reply);
    }

    public void Dispose() => _replySub?.Dispose();
}
