@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Memex.Portal.Shared.Admin
@using MeshWeaver.Blazor.Infrastructure
@using MeshWeaver.Mesh.Services
@using Microsoft.Extensions.DependencyInjection
@implements IDisposable

<FluentMenu Open="@IsOpen" Anchored="false" Style="grid-area: nav-menu; height: auto; max-height: 80vh; width: 100%;">
    <div style="padding: 8px;">
        <FluentSearch Placeholder="Search..." @bind-Value="searchQuery"
            @onkeydown="HandleSearchKeyDown" Style="width: 100%;" />
    </div>
    <FluentDivider />
    <FluentMenuItem OnClick="@HandleCreateClick">
        <FluentIcon Value="@(new Icons.Regular.Size20.Add())" Slot="start" />
        Create New...
    </FluentMenuItem>
    <FluentDivider />
    <FluentMenuItem OnClick="@HandleSettingsClick">
        <FluentIcon Value="@(new Icons.Regular.Size20.Settings())" Slot="start" />
        Settings
    </FluentMenuItem>
    @if (isAdmin)
    {
        <FluentMenuItem OnClick="@HandleAdminClick">
            <FluentIcon Value="@(new Icons.Regular.Size20.ShieldKeyhole())" Slot="start" />
            Platform Settings
        </FluentMenuItem>
    }
</FluentMenu>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<string> OnSearch { get; set; }
    [Parameter] public EventCallback OnOpenSettings { get; set; }

    [CascadingParameter]
    private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthState { get; set; }

    [Inject] NavigationManager NavigationManager { get; set; } = null!;
    [Inject] MeshWeaver.Mesh.Services.INavigationService NavigationService { get; set; } = null!;
    [Inject] IServiceProvider ServiceProvider { get; set; } = null!;

    private string searchQuery = "";
    private bool isAdmin;
    private CancellationTokenSource? cts;

    protected override async Task OnInitializedAsync()
    {
        cts = new CancellationTokenSource();
        try
        {
            var portalApp = ServiceProvider.GetService<PortalApplication>();
            var persistence = portalApp?.Hub.ServiceProvider.GetService<IPersistenceService>();
            if (persistence == null)
                return;

            var authState = AuthState != null ? await AuthState : null;
            var userId = authState?.User?.FindFirst("preferred_username")?.Value
                         ?? authState?.User?.Identity?.Name;

            if (string.IsNullOrEmpty(userId))
                return;

            var adminService = new AdminService(persistence);
            isAdmin = await adminService.IsAdminAsync(userId, cts.Token);
        }
        catch
        {
            // Non-critical — just hide the menu item
        }
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchQuery))
        {
            await OnSearch.InvokeAsync(searchQuery);
            await OnClose.InvokeAsync();
        }
    }

    private async Task HandleCreateClick()
    {
        // Phase 2: Will open create dialog
        await OnClose.InvokeAsync();
    }

    private async Task HandleSettingsClick()
    {
        var currentPath = NavigationService.CurrentNamespace ?? "";
        var settingsUrl = string.IsNullOrEmpty(currentPath) ? "/Settings" : $"/{currentPath}/Settings";
        NavigationManager.NavigateTo(settingsUrl);
        await OnClose.InvokeAsync();
    }

    private async Task HandleAdminClick()
    {
        NavigationManager.NavigateTo("/Admin");
        await OnClose.InvokeAsync();
    }

    public void Dispose()
    {
        cts?.Cancel();
        cts?.Dispose();
    }
}
