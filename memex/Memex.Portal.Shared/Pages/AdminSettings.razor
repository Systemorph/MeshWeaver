@page "/admin/settings"
@using Memex.Portal.Shared.Admin
@using MeshWeaver.Blazor.Infrastructure
@using MeshWeaver.Mesh.Services
@using Microsoft.Extensions.DependencyInjection
@using AdminSettingsModel = Memex.Portal.Shared.Admin.AdminSettings
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Navigation
@inject IServiceProvider ServiceProvider

<PageTitle>Admin Settings - Memex Portal</PageTitle>

<div class="admin-container">
    <div class="admin-card">
        <div class="admin-header">
            <h1>Admin Settings</h1>
            @if (initialization != null)
            {
                <span class="version-badge">v@(initialization.Version)</span>
            }
        </div>

        @if (isLoading)
        {
            <div class="loading-container">
                <FluentProgressRing />
                <span>Loading settings...</span>
            </div>
        }
        else if (!isAdmin)
        {
            <FluentMessageBar Intent="@MessageIntent.Error">
                You do not have admin access. Contact a platform administrator.
            </FluentMessageBar>
        }
        else
        {
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <FluentMessageBar Intent="@MessageIntent.Error" Style="margin-bottom: 1rem;">
                    @errorMessage
                </FluentMessageBar>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <FluentMessageBar Intent="@MessageIntent.Success" Style="margin-bottom: 1rem;">
                    @successMessage
                </FluentMessageBar>
            }

            <!-- Auth Providers Section -->
            <section class="settings-section">
                <h2>Authentication Providers</h2>

                <div class="provider-option">
                    <FluentCheckbox @bind-Value="enableDevLogin" Label="Enable Developer Login" />
                    <span class="provider-hint">Allows signing in as any user node (development only)</span>
                </div>

                <div class="providers-divider">
                    <span>External Providers</span>
                </div>

                @foreach (var def in OAuthProviderDefinitions.All.Values)
                {
                    var providerName = def.Name;
                    if (!providerEntries.ContainsKey(providerName))
                        providerEntries[providerName] = new ProviderFormEntry();
                    var entry = providerEntries[providerName];

                    <div class="provider-section">
                        <div class="provider-header-row">
                            <FluentCheckbox @bind-Value="entry.Enabled">
                                <span class="provider-label">@GetProviderIcon(providerName) @def.DisplayName</span>
                            </FluentCheckbox>
                            <a href="@def.RegistrationUrl" target="_blank" class="registration-link">Register App</a>
                        </div>

                        @if (entry.Enabled)
                        {
                            <div class="provider-fields">
                                <div class="field-group">
                                    <label>App ID (Client ID)</label>
                                    <FluentTextField @bind-Value="entry.AppId" Placeholder="e.g., 12345678-abcd-..." Style="width: 100%;" />
                                </div>
                                <div class="field-group">
                                    <label>KeyVault Secret Name</label>
                                    <FluentTextField @bind-Value="entry.KeyVaultSecretName" Placeholder="@($"e.g., memex-{providerName.ToLowerInvariant()}-client-secret")" Style="width: 100%;" />
                                </div>
                                @if (def.HasTenantId)
                                {
                                    <div class="field-group">
                                        <label>Tenant ID</label>
                                        <FluentTextField @bind-Value="entry.TenantId" Placeholder="common (for multi-tenant)" Style="width: 100%;" />
                                    </div>
                                }

                                <details class="registration-instructions">
                                    <summary>How to register</summary>
                                    <pre>@def.RegistrationInstructions</pre>
                                </details>
                            </div>
                        }
                    </div>
                }
            </section>

            <!-- Admin Users Section -->
            <section class="settings-section">
                <h2>Platform Administrators</h2>
                <p class="hint">User IDs with admin access (one per line)</p>
                <FluentTextArea @bind-Value="adminUsersText" Rows="5" Style="width: 100%;" />
            </section>

            <!-- Save -->
            <div class="settings-actions">
                <FluentButton Appearance="Appearance.Accent" OnClick="SaveSettings" Disabled="@isSaving">
                    @if (isSaving)
                    {
                        <FluentProgressRing Style="width: 16px; height: 16px; margin-right: 8px;" />
                    }
                    Save Settings
                </FluentButton>
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private bool isAdmin;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;
    private InitializationContent? initialization;
    private bool enableDevLogin = true;
    private string adminUsersText = "";
    private Dictionary<string, ProviderFormEntry> providerEntries = new();

    [CascadingParameter]
    private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var portalApp = ServiceProvider.GetService<PortalApplication>();
            var persistence = portalApp?.Hub.ServiceProvider.GetService<IPersistenceService>();
            if (persistence == null)
            {
                errorMessage = "Persistence service not available.";
                isLoading = false;
                return;
            }

            var adminService = new AdminService(persistence);

            // Check admin access
            var authState = AuthState != null ? await AuthState : null;
            var userId = authState?.User?.FindFirst("preferred_username")?.Value
                         ?? authState?.User?.Identity?.Name;

            if (string.IsNullOrEmpty(userId))
            {
                isAdmin = false;
                isLoading = false;
                return;
            }

            isAdmin = await adminService.IsAdminAsync(userId);
            if (!isAdmin)
            {
                isLoading = false;
                return;
            }

            // Load current settings
            initialization = await adminService.GetInitializationAsync();
            var authSettings = await adminService.GetAuthProviderSettingsAsync();
            var adminSettings = await adminService.GetAdminSettingsAsync();

            enableDevLogin = authSettings.EnableDevLogin;

            foreach (var (name, entry) in authSettings.Providers)
            {
                providerEntries[name] = new ProviderFormEntry
                {
                    Enabled = entry.Enabled,
                    AppId = entry.AppId,
                    KeyVaultSecretName = entry.KeyVaultSecretName,
                    TenantId = entry.TenantId
                };
            }

            adminUsersText = string.Join("\n", adminSettings.AdminUsers);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load settings: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveSettings()
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var portalApp = ServiceProvider.GetService<PortalApplication>();
            var persistence = portalApp?.Hub.ServiceProvider.GetService<IPersistenceService>();
            if (persistence == null)
            {
                errorMessage = "Persistence service not available.";
                return;
            }

            var adminService = new AdminService(persistence);

            // Build auth provider settings
            var providers = new Dictionary<string, AuthProviderEntry>();
            foreach (var (name, entry) in providerEntries)
            {
                if (entry.Enabled)
                {
                    providers[name] = new AuthProviderEntry
                    {
                        Enabled = true,
                        AppId = entry.AppId ?? "",
                        KeyVaultSecretName = entry.KeyVaultSecretName ?? "",
                        TenantId = string.IsNullOrWhiteSpace(entry.TenantId) ? null : entry.TenantId
                    };
                }
            }

            await adminService.SaveAuthProviderSettingsAsync(new AuthProviderSettings
            {
                EnableDevLogin = enableDevLogin,
                Providers = providers
            });

            // Parse and save admin users
            var adminUsers = (adminUsersText ?? "")
                .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            await adminService.SaveAdminSettingsAsync(new AdminSettingsModel { AdminUsers = adminUsers });

            successMessage = "Settings saved. Restart the application for auth provider changes to take effect.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save settings: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private static string GetProviderIcon(string provider)
    {
        return provider.ToLowerInvariant() switch
        {
            "microsoft" => "\U0001faaa",
            "google" => "\U0001f310",
            "linkedin" => "\U0001f4bc",
            "apple" => "\U0001f34e",
            _ => "\U0001f511"
        };
    }

    private class ProviderFormEntry
    {
        public bool Enabled { get; set; }
        public string? AppId { get; set; }
        public string? KeyVaultSecretName { get; set; }
        public string? TenantId { get; set; }
    }
}
