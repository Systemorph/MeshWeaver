@page "/admin/setup"
@using Memex.Portal.Shared.Admin
@using MeshWeaver.Blazor.Infrastructure
@using MeshWeaver.Mesh.Services
@using Microsoft.Extensions.DependencyInjection
@inject NavigationManager Navigation
@inject IServiceProvider ServiceProvider

<PageTitle>Setup - Memex Portal</PageTitle>

<div class="setup-container">
    <div class="setup-card">
        @if (currentStep == 1)
        {
            <div class="setup-header">
                <h1>Welcome to Memex</h1>
                <p class="setup-subtitle">Let's set up your portal — Version 3.0</p>
            </div>

            <div class="step-content">
                <p>This wizard will help you configure:</p>
                <ul>
                    <li>Authentication providers (Microsoft, Google, LinkedIn, Apple)</li>
                    <li>Platform administrator accounts</li>
                </ul>
                <p class="hint">Each provider requires an App ID and an Azure KeyVault secret name for the client secret.</p>
            </div>

            <div class="step-actions">
                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => currentStep = 2)">
                    Get Started
                </FluentButton>
            </div>
        }
        else if (currentStep == 2)
        {
            <div class="setup-header">
                <h1>Authentication Providers</h1>
                <p class="setup-subtitle">Step 2 of 3 — Configure sign-in methods</p>
            </div>

            <div class="step-content">
                <div class="provider-option">
                    <FluentCheckbox @bind-Value="enableDevLogin" Label="Enable Developer Login" />
                    <span class="provider-hint">Allows signing in as any user node (development only)</span>
                </div>

                <div class="field-group" style="margin: 1rem 0;">
                    <label>Azure KeyVault URI</label>
                    <FluentTextField @bind-Value="keyVaultUri" Placeholder="https://my-vault.vault.azure.net/" Style="width: 100%;" />
                    <span class="provider-hint">Used to resolve client secrets at startup. Leave empty for dev mode (no secrets needed).</span>
                </div>

                <div class="providers-divider">
                    <span>External Providers</span>
                </div>

                @foreach (var def in OAuthProviderDefinitions.All.Values)
                {
                    var providerName = def.Name;
                    if (!providerEntries.ContainsKey(providerName))
                        providerEntries[providerName] = new ProviderFormEntry();
                    var entry = providerEntries[providerName];

                    <div class="provider-section">
                        <div class="provider-header-row">
                            <FluentCheckbox @bind-Value="entry.Enabled">
                                <span class="provider-label">@GetProviderIcon(providerName) @def.DisplayName</span>
                            </FluentCheckbox>
                            <a href="@def.RegistrationUrl" target="_blank" class="registration-link">Register App</a>
                        </div>

                        @if (entry.Enabled)
                        {
                            <div class="provider-fields">
                                <div class="field-group">
                                    <label>App ID (Client ID)</label>
                                    <FluentTextField @bind-Value="entry.AppId" Placeholder="e.g., 12345678-abcd-..." Style="width: 100%;" />
                                </div>
                                <div class="field-group">
                                    <label>Client Secret (KeyVault Secret Name)</label>
                                    <FluentTextField @bind-Value="entry.KeyVaultClientSecretName" Placeholder="@($"e.g., memex-{providerName.ToLowerInvariant()}-client-secret")" Style="width: 100%;" />
                                </div>
                                @if (def.HasTenantId)
                                {
                                    <div class="field-group">
                                        <label>Tenant ID</label>
                                        <FluentTextField @bind-Value="entry.TenantId" Placeholder="common (for multi-tenant)" Style="width: 100%;" />
                                    </div>
                                }

                                <details class="registration-instructions">
                                    <summary>How to register</summary>
                                    <pre>@def.RegistrationInstructions</pre>
                                </details>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="step-actions">
                <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => currentStep = 1)">Back</FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => currentStep = 3)">Next</FluentButton>
            </div>
        }
        else if (currentStep == 3)
        {
            <div class="setup-header">
                <h1>Platform Administrators</h1>
                <p class="setup-subtitle">Step 3 of 3 — Set admin users</p>
            </div>

            <div class="step-content">
                <p>Enter the user IDs (one per line) who should have admin access to manage settings.</p>
                <FluentTextArea @bind-Value="adminUsersText" Rows="5" Placeholder="e.g., Roland&#10;Alice&#10;admin@company.com" Style="width: 100%;" />
                <p class="hint">These users will be able to access /admin/settings to manage auth providers and admin users.</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <FluentMessageBar Intent="@MessageIntent.Error" Style="margin-bottom: 1rem;">
                    @errorMessage
                </FluentMessageBar>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <FluentMessageBar Intent="@MessageIntent.Success" Style="margin-bottom: 1rem;">
                    @successMessage
                </FluentMessageBar>
            }

            <div class="step-actions">
                <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => currentStep = 2)">Back</FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="CompleteSetup" Disabled="@isSaving">
                    @if (isSaving)
                    {
                        <FluentProgressRing Style="width: 16px; height: 16px; margin-right: 8px;" />
                    }
                    Complete Setup
                </FluentButton>
            </div>
        }

        <div class="step-indicator">
            @for (int i = 1; i <= 3; i++)
            {
                <span class="@(i == currentStep ? "step-dot active" : "step-dot")"></span>
            }
        </div>
    </div>
</div>

@code {
    private int currentStep = 1;
    private bool enableDevLogin = true;
    private string? keyVaultUri;
    private string adminUsersText = "";
    private string? errorMessage;
    private string? successMessage;
    private bool isSaving;
    private Dictionary<string, ProviderFormEntry> providerEntries = new();

    private async Task CompleteSetup()
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var portalApp = ServiceProvider.GetService<PortalApplication>();
            var persistence = portalApp?.Hub.ServiceProvider.GetService<IPersistenceService>();
            if (persistence == null)
            {
                errorMessage = "Persistence service not available. Please try again.";
                return;
            }

            var adminService = new AdminService(persistence);

            // Build platform settings with auth providers
            var providers = new Dictionary<string, AuthProviderEntry>();
            foreach (var (name, entry) in providerEntries)
            {
                if (entry.Enabled && !string.IsNullOrWhiteSpace(entry.AppId))
                {
                    providers[name] = new AuthProviderEntry
                    {
                        AppId = entry.AppId,
                        KeyVaultClientSecretName = entry.KeyVaultClientSecretName ?? "",
                        TenantId = string.IsNullOrWhiteSpace(entry.TenantId) ? null : entry.TenantId
                    };
                }
            }

            var platformSettings = new PlatformSettings
            {
                EnableDevLogin = enableDevLogin,
                KeyVaultUri = string.IsNullOrWhiteSpace(keyVaultUri) ? null : keyVaultUri.Trim(),
                Providers = providers
            };

            // Parse admin users
            var adminUsers = (adminUsersText ?? "")
                .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            // Use "setup" as the initializer ID (no user may be logged in yet)
            var userId = "setup";
            await adminService.InitializeAsync(userId, platformSettings, adminUsers);

            successMessage = "Setup complete! Redirecting...";
            StateHasChanged();

            // Small delay for user feedback, then redirect
            await Task.Delay(1000);
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Setup failed: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private static string GetProviderIcon(string provider)
    {
        return provider.ToLowerInvariant() switch
        {
            "microsoft" => "\U0001faaa",
            "google" => "\U0001f310",
            "linkedin" => "\U0001f4bc",
            "apple" => "\U0001f34e",
            _ => "\U0001f511"
        };
    }

    private class ProviderFormEntry
    {
        public bool Enabled { get; set; }
        public string? AppId { get; set; }
        public string? KeyVaultClientSecretName { get; set; }
        public string? TenantId { get; set; }
    }
}
