@page "/"
@using MeshWeaver.Blazor.Components
@using MeshWeaver.Mesh.Security
@using MeshWeaver.Messaging
@inject AccessService AccessService
@inject NavigationManager Navigation

<PageTitle>Memex Portal</PageTitle>

@if (IsRealUser)
{
    <LayoutArea Address="@UserAddress" Area="Activity" Top="true" />
}

@code {
    private AccessContext? UserContext => AccessService?.Context ?? AccessService?.CircuitContext;

    private bool IsRealUser =>
        UserContext != null
        && !string.IsNullOrEmpty(UserContext.ObjectId)
        && !UserContext.IsVirtual
        && !string.Equals(UserContext.ObjectId, WellKnownUsers.Anonymous, StringComparison.OrdinalIgnoreCase);

    // Post-v10: the User node lives at the root of its own partition
    // (path = ObjectId, e.g. `rbuergi`) — not under a `User/` prefix.
    private string UserAddress => UserContext?.ObjectId ?? string.Empty;

    protected override void OnInitialized()
    {
        if (!IsRealUser)
        {
            Navigation.NavigateTo("/welcome", replace: true);
        }
    }
}
