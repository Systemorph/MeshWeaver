@page "/onboarding"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MeshWeaver.Blazor.Infrastructure
@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Security
@using MeshWeaver.Mesh.Services
@using MeshWeaver.Messaging
@using Microsoft.Extensions.DependencyInjection
@inject AccessService AccessService
@inject IMeshService NodeFactory
@inject IMeshService MeshQuery
@inject PortalApplication PortalApplication
@inject NavigationManager Navigation

<PageTitle>Complete Your Profile - Memex Portal</PageTitle>

<div class="onboarding-container">
    <div class="onboarding-card">
        <div class="onboarding-header">
            <FluentIcon Value="@(new Icons.Regular.Size24.PersonAdd())" />
            <h1>Complete Your Profile</h1>
            <p class="onboarding-subtitle">Tell us a bit about yourself to get started</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <FluentMessageBar Intent="@MessageIntent.Error" Style="margin-bottom: 1rem;">
                @errorMessage
            </FluentMessageBar>
        }

        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="onboarding">
            <DataAnnotationsValidator />

            <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
                <FluentTextField Label="Username"
                                 Required="true"
                                 @bind-Value="model.Username"
                                 Placeholder="Pick a username"
                                 Style="width: 100%;" />

                <FluentTextField Label="Email"
                                 ReadOnly="true"
                                 @bind-Value="model.Email"
                                 Style="width: 100%; opacity: 0.7;" />

                <FluentTextArea Label="Bio"
                                @bind-Value="model.Bio"
                                Placeholder="A short bio about yourself (optional)"
                                Rows="3"
                                Style="width: 100%;" />

                <FluentTextField Label="Role"
                                 @bind-Value="model.Role"
                                 Placeholder="e.g., Developer, Manager, Designer (optional)"
                                 Style="width: 100%;" />

                <FluentTextField Label="Avatar URL"
                                 @bind-Value="model.AvatarUrl"
                                 Placeholder="https://example.com/avatar.jpg (optional)"
                                 Style="width: 100%;" />

                <FluentButton Type="ButtonType.Submit"
                              Appearance="Appearance.Accent"
                              Style="width: 100%; margin-top: 8px;"
                              Loading="isSaving"
                              Disabled="isSaving">
                    Get Started
                </FluentButton>
            </FluentStack>
        </EditForm>
    </div>
</div>

@code {
    private OnboardingModel model = new();
    private bool isSaving;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        var context = AccessService?.Context;
        if (context != null)
        {
            model.Email = context.Email ?? "";
            // Suggest the first name from OAuth claims, fallback to email prefix
            if (!string.IsNullOrEmpty(context.Name) && context.Name != "Unknown")
            {
                var firstName = context.Name.Split(' ')[0];
                model.Username = firstName;
            }
            else if (!string.IsNullOrEmpty(context.Email) && context.Email.Contains('@'))
            {
                model.Username = context.Email.Split('@')[0];
            }
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(model.Username))
        {
            errorMessage = "Username is required.";
            return;
        }

        isSaving = true;
        errorMessage = null;

        try
        {
            var userId = AccessService?.Context?.ObjectId;
            if (string.IsNullOrEmpty(userId))
            {
                errorMessage = "Not authenticated. Please sign in again.";
                return;
            }

            var username = model.Username.Trim();
            var content = new Dictionary<string, object?>
            {
                ["email"] = model.Email.Trim(),
            };

            if (!string.IsNullOrWhiteSpace(model.Bio))
                content["bio"] = model.Bio.Trim();
            if (!string.IsNullOrWhiteSpace(model.Role))
                content["role"] = model.Role.Trim();
            if (!string.IsNullOrWhiteSpace(model.AvatarUrl))
                content["avatar"] = model.AvatarUrl.Trim();

            // Use ImpersonateAsHub so the portal hub identity is recognized
            // by UserSelfRegistryAccessRule (portal namespace = create/read/update User nodes)
            using (AccessService.ImpersonateAsHub(PortalApplication.Hub))
            {
                // Check if this is the first user (no existing User nodes = platform admin)
                var isFirstUser = true;
                await foreach (var _ in MeshQuery.QueryAsync<MeshNode>(new MeshQueryRequest { Query = "namespace:User", Limit = 1 }))
                {
                    isFirstUser = false;
                    break;
                }

                // Check that the username is not already taken
                var existingNode = await MeshQuery.QueryAsync<MeshNode>(
                    $"path:User/{username} scope:self").FirstOrDefaultAsync();
                if (existingNode != null)
                {
                    errorMessage = $"Username '{username}' is already taken. Please choose a different one.";
                    return;
                }

                // Check that the email is not already assigned to another user
                var emailValue = model.Email.Trim();
                var existingByEmail = await MeshQuery.QueryAsync<MeshNode>(
                    $"nodeType:User content.email:\"{emailValue}\"").FirstOrDefaultAsync();
                if (existingByEmail != null && existingByEmail.State == MeshNodeState.Active)
                {
                    errorMessage = $"This email is already assigned to user '{existingByEmail.Id}'. Please sign in with that account.";
                    return;
                }

                var node = new MeshNode(username, "User")
                {
                    Name = username,
                    NodeType = "User",
                    State = MeshNodeState.Active,
                    Content = content
                };

                await NodeFactory.CreateNodeAsync(node);

                // First user becomes PlatformAdmin
                if (isFirstUser)
                {
                    var securityService = PortalApplication.Hub.ServiceProvider
                        .GetService<ISecurityService>();
                    if (securityService != null)
                        await securityService.AddUserRoleAsync(username, "PlatformAdmin", null, username);
                }
            }

            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Microsoft.AspNetCore.Components.NavigationException)
        {
            // NavigateTo with forceLoad throws NavigationException — let it propagate
            throw;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save profile: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private class OnboardingModel
    {
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
        public string? Bio { get; set; }
        public string? Role { get; set; }
        public string? AvatarUrl { get; set; }
    }

    private static class Icons
    {
        public static class Regular
        {
            public static class Size24
            {
                public class PersonAdd : Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size24.PersonAdd { }
            }
        }
    }
}
