{
  "DetailedErrors": true,
  "Features": {
    "StaticRepoSync": {
      "Partitions": [ "Doc", "Agent", "Model" ]
    }
  },
  "Logging": {
    "LogLevel": {
      // Quiet by default — Information surfaces app-level events without
      // drowning chat / synced-query traces in routing/buffer spam.
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",

      // Catch-all: everything in MeshWeaver.* is Warning unless pinned below.
      "MeshWeaver": "Warning",

      "Azure.Core": "Warning",
      "Orleans": "Warning",
      "Memex": "Warning",
      "Npgsql": "Warning"
    }
  }
}
