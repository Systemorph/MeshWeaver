{
  // Production logging. The goal is to SEE what the system is doing —
  // node creation, NodeType compiles, chat rounds, mesh operations, auth —
  // without drowning in third-party / per-message infrastructure noise.
  //   * MeshWeaver.* → Information: app- and framework-level events visible.
  //   * Third-party (Microsoft / Orleans / Azure / Npgsql / System) → Warning.
  //   * A few genuinely chatty MeshWeaver namespaces stay pinned to Warning.
  // Information-level MeshWeaver logs are app events, not per-message spam —
  // MESSAGE_FLOW / SYNC_STREAM / routing traces are Debug/Trace and stay off.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "MeshWeaver": "Information",

      // Chatty under load — keep at Warning so the signal above stays readable.
      "MeshWeaver.Blazor.AI": "Warning",
      "MeshWeaver.Kernel.Hub": "Warning",
      "MeshWeaver.Hosting.Orleans.RoutingGrain": "Warning",

      // Third-party / infrastructure noise.
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Orleans": "Warning",
      "Azure": "Warning",
      "Azure.Core": "Warning",
      "Npgsql": "Warning",
      "System": "Warning",

      "Memex": "Information"
    }
  },
  "AllowedHosts": "*",
  "DataProtection": {
    "ConnectionName": "storage",
    "ContainerName": "dataprotection",
    "BlobName": "keys.xml"
  },
  "Styles": {
    "StylesheetName": "Memex.Portal.Distributed"
  },
  "Graph": {
    "Storage": {
      "Type": "PostgreSql"
    }
  },
  "Storage": {
    "Name": "storage",
    "SourceType": "AzureBlob",
    "Settings": {
      "ContainerName": "content",
      "ClientName": "storage"
    }
  },
  "Auth": {
    "GlobalAdmins": [ "rbuergi" ]
  }
}
