{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DataProtection": {
    "ConnectionName": "storage",
    "ContainerName": "dataprotection",
    "BlobName": "keys.xml"
  },
  "Styles": {
    "StylesheetName": "Memex.Portal.Distributed"
  },
  "Graph": {
    "Storage": {
      "Type": "PostgreSql"
    }
  },
  "Storage": {
    "Name": "storage",
    "SourceType": "AzureBlob",
    "Settings": {
      "ContainerName": "content",
      "ClientName": "storage"
    }
  }
}
