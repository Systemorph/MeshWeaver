@using MeshWeaver.Blazor.Portal.Infrastructure
@using MeshWeaver.Blazor.Portal.Layout
@inherits PortalLayoutBase

@{
    // Set render fragments before base renders
    HeaderLinks = @<text>
        <FluentAnchor Appearance="Appearance.Hypertext" Href="http://github.com/Systemorph/MeshWeaver"
            Target="_blank" Rel="noreferrer noopener" title="MeshWeaver on GitHub"
            aria-label="MeshWeaver source on GitHub">
            <FluentIcon Value="@(new PortalIcons.Size20.GitHub())" Color="Color.FillInverse" />
        </FluentAnchor>
        <FluentAnchor Appearance="Appearance.Hypertext" Href="https://discord.gg/wMTug8qtvc" Target="_blank"
            Rel="noreferrer noopener" title="MeshWeaver on Discord" aria-label="MeshWeaver Discord">
            <FluentIcon Value="@(new PortalIcons.Size20.Discord())" Color="Color.FillInverse" />
        </FluentAnchor>
    </text>;

    DesktopNavMenu = @<DesktopNavMenu />;

    MobileNavMenu = @<MobileNavMenu IsNavMenuOpen="@IsNavMenuOpen" CloseNavMenu="@CloseMobileNavMenu"
        LaunchSettingsAsync="@OpenSiteSettingsAsync" />;
}

@{
    base.BuildRenderTree(__builder);
}
