{
  "id": "Todo",
  "namespace": "ACME/Software/Project",
  "name": "Task",
  "nodeType": "NodeType",
  "description": "A task with status, assignee, and due date",
  "iconName": "TaskListSquare",
  "icon": "/static/storage/content/ACME/Software/Project/Todo/icon.svg",
  "isPersistent": true,
  "content": {
    "$type": "NodeTypeDefinition",
    "namespace": "ACME/Software/Project",
    "displayName": "Task",
    "iconName": "TaskListSquare",
    "description": "A task with status, assignee, and due date",
    "configuration": "config => config.WithContentType<Todo>().AddData(data => data.AddHubSource(new Address(config.Address.Segments.Take(config.Address.Segments.Length - 2).ToArray()), source => source.WithType<Status>().WithType<Category>().WithType<Priority>())).AddDefaultLayoutAreas().AddLayout(layout => layout.WithView(\"Thumbnail\", TodoViews.Thumbnail))"
  }
}
