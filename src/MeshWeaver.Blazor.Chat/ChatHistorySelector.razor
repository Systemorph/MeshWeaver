@using MeshWeaver.AI.Persistence
@using MeshWeaver.Graph.Configuration
@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Services
@using MeshWeaver.Messaging
@using System.Text.Json
@namespace MeshWeaver.Blazor.Chat
@inject IMeshQuery MeshQuery
@inject AccessService AccessService
@inject IMessageHub Hub

<div class="chat-history-container @(IsRightPanel ? "right-panel" : "")">
    <!-- Header at top, same height as main bar -->
    <div class="chat-history-header">
        <h3>Chat History</h3>
        <FluentButton BackgroundColor="transparent" OnClick="StartNewConversation" Title="New Chat">
            <FluentIcon Value="@(new Icons.Regular.Size20.Add())" Color="Color.Neutral" />
        </FluentButton>
    </div>

    <!-- Scrollable conversation list -->
    <div class="conversation-list-container">
        @if (!Chats.Any())
        {
            <div class="no-conversations">No previous conversations</div>
        }
        else
        {
            <div class="conversation-list">
                @foreach (var chat in Chats.OrderByDescending(c => c.Content.LastActivityAt))
                {
                    <div class="conversation-item @(chat.Path == SelectedConversationId ? "selected" : "")"
                        @onclick="() => SelectConversation(chat.Path)">
                        <div class="conversation-title">@GetChatTitle(chat)</div>
                        <div class="conversation-preview">@GetChatPreview(chat)</div>
                        <div class="conversation-meta">
                            <small class="text-muted">
                                @FormatDate(chat.Content.LastActivityAt)
                                @if (!string.IsNullOrEmpty(GetPathScope(chat.Path)))
                                {
                                    <span> • @GetContextName(GetPathScope(chat.Path))</span>
                                }
                            </small>
                        </div>
                        <FluentButton BackgroundColor="transparent" OnClick="() => DeleteConversation(chat.Path)"
                            OnClick:stopPropagation="true"
                            title="Delete conversation" Class="delete-btn">
                            <FluentIcon Value="@(new Icons.Regular.Size16.Delete())" Color="Color.Error" />
                        </FluentButton>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Close button at bottom -->
    <div class="chat-history-footer">
        <FluentButton BackgroundColor="transparent" OnClick="HandleClose" Style="width: 100%;">
            <FluentIcon Value="@(new Icons.Regular.Size20.Dismiss())" Color="Color.Neutral" />
            Close
        </FluentButton>
    </div>
</div>

<style>
    .chat-history-container {
        width: 300px;
        border-right: 1px solid var(--neutral-stroke-divider);
        background-color: var(--neutral-layer-2);
        height: 100%;
        display: flex;
        flex-direction: column;
        color: var(--neutral-foreground-rest);
    }

    .chat-history-container.right-panel {
        width: 100%;
        border-right: none;
        background-color: var(--neutral-layer-1);
    }

    .chat-history-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--neutral-stroke-divider);
        background-color: var(--neutral-layer-2);
        flex-shrink: 0;
        min-height: 48px;
    }

    .chat-history-header h3 {
        margin: 0;
        font-size: 1rem;
        font-weight: 600;
        color: var(--neutral-foreground-rest);
    }

    .conversation-list-container {
        flex: 1;
        overflow-y: auto;
        padding: 0.75rem;
    }

    .conversation-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .conversation-item {
        position: relative;
        padding: 0.75rem;
        border: 1px solid var(--neutral-stroke-rest);
        border-radius: 6px;
        background-color: var(--neutral-layer-card-container);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .conversation-item:hover {
        border-color: var(--accent-fill-rest);
        background-color: var(--neutral-fill-secondary-hover);
    }

    .conversation-item.selected {
        border-color: var(--accent-fill-rest);
        background-color: var(--accent-fill-secondary);
    }

    .conversation-title {
        font-weight: 500;
        margin-bottom: 0.25rem;
        color: var(--neutral-foreground-rest);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        padding-right: 24px; /* Space for delete button */
    }

    .conversation-preview {
        font-size: 0.85rem;
        color: var(--neutral-foreground-hint);
        margin-bottom: 0.25rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .conversation-meta {
        margin-bottom: 0;
        color: var(--neutral-foreground-hint);
        font-size: 0.8rem;
    }

    .delete-btn {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        padding: 0.25rem;
        opacity: 0;
        transition: opacity 0.2s ease;
        min-width: auto;
    }

    .conversation-item:hover .delete-btn {
        opacity: 1;
    }

    .no-conversations {
        text-align: center;
        padding: 2rem;
        color: var(--neutral-foreground-hint);
        font-style: italic;
    }

    .chat-history-footer {
        padding: 0.75rem 1rem;
        border-top: 1px solid var(--neutral-stroke-divider);
        background-color: var(--neutral-layer-2);
        flex-shrink: 0;
    }
</style>

@code {
    [Parameter] public string? SelectedConversationId { get; set; }
    [Parameter] public EventCallback<string> SelectedConversationIdChanged { get; set; }
    [Parameter] public EventCallback OnNewConversation { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public bool IsRightPanel { get; set; }
    [Parameter] public string? Scope { get; set; }

    // Chat items with path and content for display
    private record ThreadItem(string Path, ThreadNodeContent Content);
    private IReadOnlyList<ThreadItem> Chats = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadConversations();
    }

    private string GetCurrentUserId()
    {
        return AccessService?.Context?.ObjectId ?? "anonymous";
    }

    private async Task LoadConversations()
    {
        try
        {
            var userId = GetCurrentUserId();
            var threadNodes = await ThreadNodePersistenceHelper.ListUserThreadNodesAsync(MeshQuery, userId);

            // Convert to ThreadItem list, filtering by scope if specified
            var items = threadNodes
                .Select(n => new ThreadItem(n.Path ?? n.Id, n.Content as ThreadNodeContent ?? new ThreadNodeContent()))
                .Where(c => Scope == null || GetPathScope(c.Path) == Scope)
                .OrderByDescending(c => c.Content.LastActivityAt)
                .ToList();

            Chats = items;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading conversations: {ex.Message}");
        }
    }

    private static string? GetPathScope(string path)
    {
        // Extract scope from path if needed
        // For now, just return the path minus the chat ID
        var lastSlash = path.LastIndexOf('/');
        return lastSlash > 0 ? path[..lastSlash] : null;
    }

    private string GetChatTitle(ThreadItem chat)
    {
        // Use title if available
        if (!string.IsNullOrEmpty(chat.Content.Title))
            return chat.Content.Title;

        // Try to extract first user message as title
        var preview = GetFirstUserMessage(chat.Content);
        if (!string.IsNullOrEmpty(preview))
        {
            return preview.Length > 40 ? preview[..40] + "..." : preview;
        }

        // Fallback to date
        return $"Chat from {chat.Content.CreatedAt:MM/dd HH:mm}";
    }

    private string GetChatPreview(ThreadItem chat)
    {
        // Get first user message as preview
        var firstMessage = GetFirstUserMessage(chat.Content);
        if (!string.IsNullOrEmpty(firstMessage))
        {
            return firstMessage.Length > 60 ? firstMessage[..60] + "..." : firstMessage;
        }

        return "No messages";
    }

    private static string? GetFirstUserMessage(ThreadNodeContent content)
    {
        if (content.Messages == null || content.Messages.Count == 0)
            return null;

        // Find first user message
        var userMessage = content.Messages.FirstOrDefault(m =>
            m.Role.Equals("user", StringComparison.OrdinalIgnoreCase));

        return userMessage?.Text;
    }

    private string GetContextName(string? scope)
    {
        if (string.IsNullOrEmpty(scope))
            return "";

        // Extract last segment of path for display
        var segments = scope.Split('/');
        return segments.Length > 0 ? segments[^1] : scope;
    }

    private async Task SelectConversation(string chatPath)
    {
        if (SelectedConversationId != chatPath)
        {
            SelectedConversationId = chatPath;
            await SelectedConversationIdChanged.InvokeAsync(chatPath);
        }
    }

    private async Task StartNewConversation()
    {
        SelectedConversationId = null;
        await SelectedConversationIdChanged.InvokeAsync(null);
        await OnNewConversation.InvokeAsync();
    }

    private async Task HandleClose()
    {
        await OnClose.InvokeAsync();
    }

    private async Task DeleteConversation(string chatPath)
    {
        try
        {
            // Delete via hub
            await ThreadNodePersistenceHelper.DeleteThreadNodeAsync(Hub, chatPath);

            // Remove from local list
            Chats = Chats.Where(c => c.Path != chatPath).ToList();

            // If this was the selected conversation, start a new one
            if (SelectedConversationId == chatPath)
            {
                await StartNewConversation();
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting conversation: {ex.Message}");
        }
    }

    private string FormatDate(DateTime date)
    {
        var now = DateTime.Now;
        var timeSpan = now - date;

        if (timeSpan.TotalDays < 1)
        {
            return date.ToString("HH:mm");
        }
        else if (timeSpan.TotalDays < 7)
        {
            return date.ToString("ddd HH:mm");
        }
        else
        {
            return date.ToString("MM/dd");
        }
    }

    public async Task RefreshConversations()
    {
        await LoadConversations();
    }
}
