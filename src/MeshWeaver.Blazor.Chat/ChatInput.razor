@using ChatMessage = Microsoft.Extensions.AI.ChatMessage
@using MeshWeaver.AI
@using MeshWeaver.Blazor.Components.Monaco
@using Microsoft.Extensions.Logging
@inject IJSRuntime JS
@inject ILogger<ChatInput> Logger

<div class="input-box page-width">
    <div class="input-container">
        <MonacoEditorView @ref="monacoEditor"
                          @bind-Value="MessageText"
                          OnSubmit="SendMessageAsync"
                          IsDisabled="@IsDisabled"
                          Placeholder="Type your message..."
                          Height="60px"
                          MaxHeight="150px"
                          CompletionProvider="@CompletionProvider"
                          AsyncCompletionCallback="@AsyncCompletionCallback" />
    </div>

    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8" Class="tools">
        @if (ShowSelectors)
        {
            @* 1. Context selector *@
            <SimpleDropdown TOption="CompletionItem"
                            SelectedItem="@selectedContextItem"
                            SelectedItemChanged="@OnContextItemChanged"
                            OnSearch="@OnContextSearchAsync"
                            GetDisplayText="@(c => c?.Label ?? "Context...")"
                            Placeholder="Context..."
                            Tooltip="@(selectedContextItem?.Path ?? "Select context")"
                            PanelWidth="320px"
                            Class="selector-context">
                <ItemTemplate Context="item">
                    <div class="simple-dropdown-item-name">@item.Label</div>
                    @if (!string.IsNullOrEmpty(item.Path) && item.Path != item.Label)
                    {
                        <div class="simple-dropdown-item-path">@item.Path</div>
                    }
                </ItemTemplate>
            </SimpleDropdown>

            @* 2. Agent selector *@
            <SimpleDropdown TOption="AgentDisplayInfo"
                            SelectedItem="@SelectedAgentInfo"
                            SelectedItemChanged="@OnAgentItemChanged"
                            Items="@AgentDisplayInfos"
                            GetDisplayText="@(a => a?.Name ?? "Select agent...")"
                            Placeholder="Select agent..."
                            Tooltip="@(SelectedAgentInfo?.Path ?? "Select agent")"
                            PanelWidth="320px"
                            Class="selector-agent">
                <ItemTemplate Context="agent">
                    <div class="simple-dropdown-item-name">@agent.Name</div>
                    @if (!string.IsNullOrEmpty(agent.Path) && agent.Path != agent.Name)
                    {
                        <div class="simple-dropdown-item-path">@agent.Path</div>
                    }
                    @if (!string.IsNullOrEmpty(agent.Description))
                    {
                        <div class="simple-dropdown-item-description">@TruncateDescription(agent.Description, 80)</div>
                    }
                </ItemTemplate>
            </SimpleDropdown>

            @* 3. Model selector *@
            @if (AvailableModels.Count > 0)
            {
                <SimpleDropdown TOption="ModelInfo"
                                SelectedItem="@SelectedModelInfo"
                                SelectedItemChanged="@OnModelInfoItemChanged"
                                Items="@AvailableModels"
                                GetDisplayText="@(m => m?.Name ?? "Select model...")"
                                Placeholder="Select model..."
                                ShowSearch="false"
                                PanelWidth="280px"
                                Class="selector-model">
                    <ItemTemplate Context="model">
                        <div class="simple-dropdown-item-provider">@model.Provider</div>
                        <div class="simple-dropdown-item-name">@model.Name</div>
                    </ItemTemplate>
                </SimpleDropdown>
            }
        }
        <FluentSpacer />
        @if (IsStreaming && !string.IsNullOrWhiteSpace(MessageText))
        {
            @* When streaming and user has typed, show send button to interrupt and send *@
            <button type="button" title="Interrupt and send" class="send-button interrupt" @onclick="@SendMessageAsync"
                disabled="@IsDisabled">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                    stroke="currentColor" class="tool-icon">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                </svg>
            </button>
        }
        else
        {
            <button type="button" title="Send" class="send-button" @onclick="@SendMessageAsync"
                disabled="@(IsDisabled || string.IsNullOrWhiteSpace(MessageText))">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                    stroke="currentColor" class="tool-icon">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                </svg>
            </button>
        }
    </FluentStack>
</div>

@code {
    private MonacoEditorView? monacoEditor;
    private string? MessageText;

    // Context selector state
    private CompletionItem? selectedContextItem;

    [Parameter]
    public EventCallback<ChatMessage> OnSend { get; set; }

    [Parameter]
    public bool IsDisabled { get; set; }

    /// <summary>
    /// Indicates whether a response is currently being streamed.
    /// When true, the input is still enabled but shows visual indication
    /// that sending will interrupt the current response.
    /// </summary>
    [Parameter]
    public bool IsStreaming { get; set; }

    [Parameter]
    public CompletionProviderConfig? CompletionProvider { get; set; }

    [Parameter]
    public Func<string, Task<CompletionItem[]>>? AsyncCompletionCallback { get; set; }

    [Parameter]
    public bool ShowSelectors { get; set; } = true;

    [Parameter]
    public string? SelectedContext { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedContextChanged { get; set; }

    /// <summary>
    /// Display name for the selected context (e.g., node name instead of full path)
    /// </summary>
    [Parameter]
    public string? SelectedContextDisplayName { get; set; }

    /// <summary>
    /// Async callback for context autocomplete. Returns CompletionItem[] for two-line display.
    /// </summary>
    [Parameter]
    public Func<string, Task<CompletionItem[]>>? OnContextAutocomplete { get; set; }

    [Parameter]
    public IReadOnlyList<AgentDisplayInfo> AgentDisplayInfos { get; set; } = [];

    [Parameter]
    public AgentDisplayInfo? SelectedAgentInfo { get; set; }

    [Parameter]
    public EventCallback<AgentDisplayInfo?> SelectedAgentInfoChanged { get; set; }

    [Parameter]
    public IReadOnlyList<ModelInfo> AvailableModels { get; set; } = [];

    [Parameter]
    public ModelInfo? SelectedModelInfo { get; set; }

    [Parameter]
    public EventCallback<ModelInfo?> SelectedModelInfoChanged { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        // Sync selected context to SimpleDropdown
        if (!string.IsNullOrEmpty(SelectedContext))
        {
            // Only update if different to avoid re-render loops
            if (selectedContextItem?.Path != SelectedContext)
            {
                selectedContextItem = new CompletionItem
                {
                    Label = SelectedContextDisplayName ?? SelectedContext,
                    InsertText = SelectedContext,
                    Path = SelectedContext
                };
            }
        }
        else if (selectedContextItem != null)
        {
            selectedContextItem = null;
        }
    }

    private async Task<IEnumerable<CompletionItem>> OnContextSearchAsync(string searchText)
    {
        if (OnContextAutocomplete == null)
        {
            return Enumerable.Empty<CompletionItem>();
        }

        // Build query - add @ prefix for UCR-style autocomplete
        var query = string.IsNullOrEmpty(searchText) ? "@" : $"@{searchText}";

        try
        {
            // Results come pre-ordered by relevance from IMeshQuery.AutocompleteAsync
            // (path length first, then score, then name)
            return await OnContextAutocomplete(query);
        }
        catch
        {
            return Enumerable.Empty<CompletionItem>();
        }
    }

    private async Task OnContextItemChanged(CompletionItem? item)
    {
        // Update local state to preserve the Label for display
        selectedContextItem = item;

        var newContext = item?.Path;
        if (newContext != SelectedContext)
        {
            await SelectedContextChanged.InvokeAsync(newContext);
        }
    }

    private async Task OnAgentItemChanged(AgentDisplayInfo? agent)
    {
        if (agent != SelectedAgentInfo)
        {
            await SelectedAgentInfoChanged.InvokeAsync(agent);
        }
    }

    private async Task OnModelInfoItemChanged(ModelInfo? model)
    {
        if (model?.Name != SelectedModelInfo?.Name)
        {
            await SelectedModelInfoChanged.InvokeAsync(model);
        }
    }

    public async ValueTask FocusAsync()
    {
        if (monacoEditor != null)
        {
            await monacoEditor.FocusAsync();
        }
    }

    private async Task SendMessageAsync()
    {
        if (monacoEditor != null)
        {
            var text = await monacoEditor.GetValueAsync();
            if (!string.IsNullOrWhiteSpace(text) && !IsDisabled)
            {
                await monacoEditor.ClearAsync();
                MessageText = null;
                await OnSend.InvokeAsync(new ChatMessage(ChatRole.User, text));
            }
        }
    }

    private static string TruncateDescription(string description, int maxLength)
    {
        if (string.IsNullOrEmpty(description) || description.Length <= maxLength)
            return description;
        return description[..maxLength] + "...";
    }
}
