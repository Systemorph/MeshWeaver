@using ChatMessage = Microsoft.Extensions.AI.ChatMessage
@using MeshWeaver.Blazor.Monaco
@inject IJSRuntime JS

<div class="input-box page-width">
    <div class="input-container">
        <MonacoEditorView @ref="monacoEditor"
                          @bind-Value="MessageText"
                          OnSubmit="SendMessageAsync"
                          IsDisabled="@IsDisabled"
                          Placeholder="Type your message..."
                          Height="60px"
                          MaxHeight="150px"
                          CompletionProvider="@CompletionProvider"
                          AsyncCompletionCallback="@AsyncCompletionCallback" />
    </div>

    <div class="tools">
        @if (ShowSelectors)
        {
            <div class="chat-selectors">
                @* 1. Context autocomplete *@
                <FluentAutocomplete TOption="string"
                                    AutoComplete="off"
                                    Placeholder="@ContextPlaceholder"
                                    Width="180px"
                                    MaximumSelectedOptions="1"
                                    OptionText="@(item => item)"
                                    @bind-SelectedOptions="@selectedContextOptions"
                                    @bind-SelectedOptions:after="@OnContextSelectionChanged"
                                    OnOptionsSearch="@OnContextSearchAsync" />

                @* 2. Agent autocomplete *@
                <FluentAutocomplete TOption="AgentDisplayInfo"
                                    AutoComplete="off"
                                    Placeholder="Agent"
                                    Width="140px"
                                    MaximumSelectedOptions="1"
                                    OptionText="@(a => a.Name)"
                                    @bind-SelectedOptions="@selectedAgentOptions"
                                    @bind-SelectedOptions:after="@OnAgentSelectionChanged"
                                    OnOptionsSearch="@OnAgentSearchAsync" />

                @* 3. Model dropdown *@
                @if (AvailableModels.Count > 0)
                {
                    <FluentSelect TOption="string"
                                  Items="@AvailableModels"
                                  Style="width: 140px;"
                                  OptionText="@(m => m)"
                                  OptionValue="@(m => m)"
                                  Value="@SelectedModel"
                                  ValueChanged="@OnModelValueChanged" />
                }
            </div>
        }
        <button type="button" title="Send" class="send-button" @onclick="@SendMessageAsync"
            disabled="@(IsDisabled || string.IsNullOrWhiteSpace(MessageText))">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                stroke="currentColor" class="tool-icon">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
            </svg>
        </button>
    </div>
</div>

@code {
    private const string ContextPlaceholder = "@context";
    private MonacoEditorView? monacoEditor;
    private string? MessageText;

    // Backing fields for FluentAutocomplete bindings
    private IEnumerable<string> selectedContextOptions = [];
    private IEnumerable<AgentDisplayInfo> selectedAgentOptions = [];

    [Parameter]
    public EventCallback<ChatMessage> OnSend { get; set; }

    [Parameter]
    public bool IsDisabled { get; set; }

    [Parameter]
    public CompletionProviderConfig? CompletionProvider { get; set; }

    [Parameter]
    public Func<string, Task<CompletionItem[]>>? AsyncCompletionCallback { get; set; }

    [Parameter]
    public bool ShowSelectors { get; set; } = true;

    [Parameter]
    public string? SelectedContext { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedContextChanged { get; set; }

    [Parameter]
    public Func<string, Task<IEnumerable<string>>>? OnContextAutocomplete { get; set; }

    [Parameter]
    public Func<string, Task<IEnumerable<AgentDisplayInfo>>>? OnAgentAutocomplete { get; set; }

    [Parameter]
    public IReadOnlyList<AgentDisplayInfo> AgentDisplayInfos { get; set; } = [];

    [Parameter]
    public AgentDisplayInfo? SelectedAgentInfo { get; set; }

    [Parameter]
    public EventCallback<AgentDisplayInfo?> SelectedAgentInfoChanged { get; set; }

    [Parameter]
    public IReadOnlyList<string> AvailableModels { get; set; } = [];

    [Parameter]
    public string? SelectedModel { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedModelChanged { get; set; }

    protected override void OnParametersSet()
    {
        // Sync selected options with parameters
        if (SelectedContext != null && !selectedContextOptions.Contains(SelectedContext))
        {
            selectedContextOptions = [SelectedContext];
        }
        else if (SelectedContext == null && selectedContextOptions.Any())
        {
            selectedContextOptions = [];
        }

        if (SelectedAgentInfo != null && !selectedAgentOptions.Contains(SelectedAgentInfo))
        {
            selectedAgentOptions = [SelectedAgentInfo];
        }
    }

    private async Task OnContextSearchAsync(OptionsSearchEventArgs<string> args)
    {
        if (OnContextAutocomplete != null)
        {
            var suggestions = await OnContextAutocomplete(args.Text ?? "");
            args.Items = suggestions;
        }
        else
        {
            // Default: show current context if set
            args.Items = string.IsNullOrEmpty(SelectedContext) ? [] : [SelectedContext];
        }
    }

    private async Task OnAgentSearchAsync(OptionsSearchEventArgs<AgentDisplayInfo> args)
    {
        var text = args.Text ?? "";

        if (OnAgentAutocomplete != null)
        {
            var suggestions = await OnAgentAutocomplete(text);
            args.Items = suggestions;
        }
        else
        {
            // Fallback to filtering from AgentDisplayInfos
            args.Items = AgentDisplayInfos
                .Where(a => string.IsNullOrEmpty(text) || a.Name.Contains(text, StringComparison.OrdinalIgnoreCase))
                .OrderBy(a => a.Name);
        }
    }

    private async Task OnContextSelectionChanged()
    {
        var selected = selectedContextOptions.FirstOrDefault();
        if (selected != SelectedContext)
        {
            await SelectedContextChanged.InvokeAsync(selected);
        }
    }

    private async Task OnAgentSelectionChanged()
    {
        var selected = selectedAgentOptions.FirstOrDefault();
        if (selected != SelectedAgentInfo)
        {
            await SelectedAgentInfoChanged.InvokeAsync(selected);
        }
    }

    private async Task OnModelValueChanged(string? model)
    {
        if (model != SelectedModel)
        {
            await SelectedModelChanged.InvokeAsync(model);
        }
    }

    public async ValueTask FocusAsync()
    {
        if (monacoEditor != null)
        {
            await monacoEditor.FocusAsync();
        }
    }

    private async Task SendMessageAsync()
    {
        if (monacoEditor != null)
        {
            var text = await monacoEditor.GetValueAsync();
            if (!string.IsNullOrWhiteSpace(text) && !IsDisabled)
            {
                await monacoEditor.ClearAsync();
                MessageText = null;
                await OnSend.InvokeAsync(new ChatMessage(ChatRole.User, text));
            }
        }
    }
}
