@using ChatMessage = Microsoft.Extensions.AI.ChatMessage
@using MeshWeaver.Blazor.Monaco
@using Microsoft.Extensions.Logging
@inject IJSRuntime JS
@inject ILogger<ChatInput> Logger

<div class="input-box page-width">
    <div class="input-container">
        <MonacoEditorView @ref="monacoEditor"
                          @bind-Value="MessageText"
                          OnSubmit="SendMessageAsync"
                          IsDisabled="@IsDisabled"
                          Placeholder="Type your message..."
                          Height="60px"
                          MaxHeight="150px"
                          CompletionProvider="@CompletionProvider"
                          AsyncCompletionCallback="@AsyncCompletionCallback" />
    </div>

    <div class="tools">
        @if (ShowSelectors)
        {
            <div class="chat-selectors">
                @* 1. Context text field *@
                <FluentTextField @bind-Value="@contextDisplayText"
                                 @bind-Value:after="@OnContextTextChanged"
                                 Placeholder="@ContextPlaceholder"
                                 Class="selector-context"
                                 Style="min-width: 50px;" />

                @* 2. Agent dropdown - shows name only, expanded shows path and description *@
                <FluentSelect TOption="AgentDisplayInfo"
                              Items="@AgentDisplayInfos"
                              Class="selector-agent"
                              OptionText="@(a => a?.Name ?? "")"
                              OptionValue="@(a => a?.Name ?? "")"
                              SelectedOption="@SelectedAgentInfo"
                              SelectedOptionChanged="@OnAgentSelectChanged"
                              Style="min-width: 50px;"
                              Height="200px">
                    <OptionTemplate Context="agent">
                        <div class="agent-option">
                            <div class="agent-option-name">@agent.Name</div>
                            @if (!string.IsNullOrEmpty(agent.Path) && agent.Path != agent.Name)
                            {
                                <div class="agent-option-path">@agent.Path</div>
                            }
                            @if (!string.IsNullOrEmpty(agent.Description))
                            {
                                <div class="agent-option-desc">@TruncateDescription(agent.Description, 60)</div>
                            }
                        </div>
                    </OptionTemplate>
                </FluentSelect>

                @* 3. Model dropdown *@
                @if (AvailableModels.Count > 0)
                {
                    <FluentSelect TOption="string"
                                  Items="@AvailableModels"
                                  Class="selector-model"
                                  OptionText="@(m => m)"
                                  OptionValue="@(m => m)"
                                  Value="@SelectedModel"
                                  ValueChanged="@OnModelValueChanged"
                                  Style="min-width: 50px;"
                                  Height="200px" />
                }
            </div>
        }
        <button type="button" title="Send" class="send-button" @onclick="@SendMessageAsync"
            disabled="@(IsDisabled || string.IsNullOrWhiteSpace(MessageText))">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                stroke="currentColor" class="tool-icon">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
            </svg>
        </button>
    </div>
</div>

@code {
    private const string ContextPlaceholder = "@context";
    private MonacoEditorView? monacoEditor;
    private string? MessageText;

    // Display text for context (read-only, shows current path)
    private string? contextDisplayText;
    private bool isSettingFromParameter;

    [Parameter]
    public EventCallback<ChatMessage> OnSend { get; set; }

    [Parameter]
    public bool IsDisabled { get; set; }

    [Parameter]
    public CompletionProviderConfig? CompletionProvider { get; set; }

    [Parameter]
    public Func<string, Task<CompletionItem[]>>? AsyncCompletionCallback { get; set; }

    [Parameter]
    public bool ShowSelectors { get; set; } = true;

    [Parameter]
    public string? SelectedContext { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedContextChanged { get; set; }

    [Parameter]
    public Func<string, Task<IEnumerable<string>>>? OnContextAutocomplete { get; set; }

    [Parameter]
    public IReadOnlyList<AgentDisplayInfo> AgentDisplayInfos { get; set; } = [];

    [Parameter]
    public AgentDisplayInfo? SelectedAgentInfo { get; set; }

    [Parameter]
    public EventCallback<AgentDisplayInfo?> SelectedAgentInfoChanged { get; set; }

    [Parameter]
    public IReadOnlyList<string> AvailableModels { get; set; } = [];

    [Parameter]
    public string? SelectedModel { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedModelChanged { get; set; }

    protected override void OnParametersSet()
    {
        // Sync context display text with parameter, but flag that we're setting from parameter
        // to prevent the :after callback from triggering a circular update
        if (contextDisplayText != SelectedContext)
        {
            Logger.LogDebug("[ChatInput] OnParametersSet: context changed from '{Old}' to '{New}', setting flag",
                contextDisplayText, SelectedContext);
            isSettingFromParameter = true;
            contextDisplayText = SelectedContext;
        }
    }

    private async Task OnContextTextChanged()
    {
        Logger.LogDebug("[ChatInput] OnContextTextChanged called. isSettingFromParameter={Flag}, contextDisplayText='{Display}', SelectedContext='{Selected}'",
            isSettingFromParameter, contextDisplayText, SelectedContext);

        // Skip callback if this change came from parameter sync
        if (isSettingFromParameter)
        {
            Logger.LogDebug("[ChatInput] Skipping callback - change came from parameter sync");
            isSettingFromParameter = false;
            return;
        }

        if (contextDisplayText != SelectedContext)
        {
            Logger.LogDebug("[ChatInput] Invoking SelectedContextChanged callback with '{Context}'", contextDisplayText);
            await SelectedContextChanged.InvokeAsync(contextDisplayText);
        }
    }

    private async Task OnAgentSelectChanged(AgentDisplayInfo? agent)
    {
        if (agent != SelectedAgentInfo)
        {
            await SelectedAgentInfoChanged.InvokeAsync(agent);
        }
    }

    private async Task OnModelValueChanged(string? model)
    {
        if (model != SelectedModel)
        {
            await SelectedModelChanged.InvokeAsync(model);
        }
    }

    public async ValueTask FocusAsync()
    {
        if (monacoEditor != null)
        {
            await monacoEditor.FocusAsync();
        }
    }

    private async Task SendMessageAsync()
    {
        if (monacoEditor != null)
        {
            var text = await monacoEditor.GetValueAsync();
            if (!string.IsNullOrWhiteSpace(text) && !IsDisabled)
            {
                await monacoEditor.ClearAsync();
                MessageText = null;
                await OnSend.InvokeAsync(new ChatMessage(ChatRole.User, text));
            }
        }
    }

    private static string TruncateDescription(string description, int maxLength)
    {
        if (string.IsNullOrEmpty(description) || description.Length <= maxLength)
            return description;
        return description[..maxLength] + "...";
    }
}
