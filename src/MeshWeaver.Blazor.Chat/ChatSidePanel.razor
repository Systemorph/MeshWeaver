@namespace MeshWeaver.Blazor.Chat

@using MeshWeaver.AI
@using MeshWeaver.Layout
@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Services

<div class="chat-side-panel">
    @if (showChatHistory)
    {
        <!-- Chat History Panel (full overlay) -->
        <div class="chat-history-fullscreen">
            <ChatHistorySelector SelectedConversationId="@selectedThreadPath"
                SelectedConversationIdChanged="OnThreadSelected"
                OnNewConversation="StartNewConversationAsync"
                OnClose="CloseChatHistory"
                @ref="chatHistorySelector"
                IsRightPanel="true" />
        </div>
    }
    else
    {
        <!-- Sticky Chat Header -->
        <div class="chat-header">
            <h3 class="chat-title">AI Chat</h3>
            <div class="chat-actions">
                <FluentButton BackgroundColor="transparent" OnClick="StartNewConversationAsync" Title="New Chat">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Add())" Color="Color.Neutral" />
                </FluentButton>
                <FluentButton BackgroundColor="transparent" OnClick="ToggleChatHistory" Title="Chat History">
                    <FluentIcon Value="@(new Icons.Regular.Size20.History())" Color="Color.Neutral" />
                </FluentButton>
                @if (!string.IsNullOrEmpty(selectedThreadPath))
                {
                    <FluentButton BackgroundColor="transparent" OnClick="OpenThreadFullScreen" Title="Open Full Screen">
                        <FluentIcon Value="@(new Icons.Regular.Size20.ArrowMaximize())" Color="Color.Neutral" />
                    </FluentButton>
                }
                <FluentButton BackgroundColor="transparent" Title="Chat Position" @onclick="@(() => positionMenuVisible = !positionMenuVisible)" Id="position-menu-anchor">
                    <FluentIcon Value="@(new Icons.Regular.Size20.WindowLocationTarget())" Color="Color.Neutral" />
                </FluentButton>
                <FluentMenu @bind-Open="positionMenuVisible" Anchor="position-menu-anchor">
                    <FluentMenuItem OnClick="@(() => ChangeChatPositionAsync(ChatPosition.Right))">
                        <FluentIcon Value="@(new Icons.Regular.Size16.PanelRight())" />
                        Right
                        @if (currentPosition == ChatPosition.Right)
                        {
                            <FluentIcon Value="@(new Icons.Regular.Size16.Checkmark())" Color="Color.Success" Style="margin-left: auto;" />
                        }
                    </FluentMenuItem>
                    <FluentMenuItem OnClick="@(() => ChangeChatPositionAsync(ChatPosition.Bottom))">
                        <FluentIcon Value="@(new Icons.Regular.Size16.ArrowDown())" />
                        Bottom
                        @if (currentPosition == ChatPosition.Bottom)
                        {
                            <FluentIcon Value="@(new Icons.Regular.Size16.Checkmark())" Color="Color.Success" Style="margin-left: auto;" />
                        }
                    </FluentMenuItem>
                </FluentMenu>
                <FluentButton BackgroundColor="transparent" OnClick="CloseChatAsync" Title="Close Chat">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Dismiss())" Color="Color.Neutral" />
                </FluentButton>
            </div>
        </div>

        <!-- Main Chat Area - ThreadChatView -->
        <div class="chat-content">
            <ThreadChatView @key="@threadChatKey" ViewModel="@GetThreadChatControl()" />
        </div>
    }
</div>
