@using Microsoft.FluentUI.AspNetCore.Components

<div class="reference-chip-collection">
    @foreach (var attachment in Attachments)
    {
        var isContext = attachment.IsContext;
        var chipClass = isContext ? "reference-chip context-chip" : "reference-chip";

        <div class="@chipClass" title="@attachment.Path" @onclick="@(() => OnChipClick.InvokeAsync(attachment.Path))">
            @if (isContext)
            {
                <FluentIcon Value="@(new Icons.Regular.Size16.Location())" Color="Color.Accent" />
            }
            else
            {
                <FluentIcon Value="@(new Icons.Regular.Size16.Link())" Color="Color.Neutral" />
            }
            <span class="chip-text">@GetDisplayName(attachment.Path, attachment.DisplayName)</span>
            <button type="button" class="chip-remove" @onclick:stopPropagation="true" @onclick="@(() => OnAttachmentRemoved.InvokeAsync(attachment.Path))" title="Remove">
                <FluentIcon Value="@(new Icons.Regular.Size12.Dismiss())" Color="Color.Neutral" />
            </button>
        </div>
    }
</div>

@code {
    /// <summary>
    /// Unified list of attachments (context + references).
    /// </summary>
    [Parameter]
    public IReadOnlyList<AttachmentInfo> Attachments { get; set; } = Array.Empty<AttachmentInfo>();

    /// <summary>
    /// Callback when an attachment is removed by clicking the X button.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnAttachmentRemoved { get; set; }

    /// <summary>
    /// Callback when a chip is clicked (for navigation).
    /// </summary>
    [Parameter]
    public EventCallback<string> OnChipClick { get; set; }

    private static string GetDisplayName(string path, string? displayName)
    {
        if (!string.IsNullOrEmpty(displayName))
            return displayName;

        // Extract last segment of path for display
        var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
        return segments.Length > 0 ? segments[^1] : path;
    }
}
