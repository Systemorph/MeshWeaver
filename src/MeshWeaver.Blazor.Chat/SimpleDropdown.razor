@typeparam TOption
@inject IJSRuntime JS
@implements IDisposable

<div class="simple-dropdown @(isOpen ? "open" : "") @Class"
     @ref="containerRef"
     data-dropdown-id="@componentId"
     @onclick:stopPropagation="true">
    <button type="button"
            class="simple-dropdown-button"
            @onclick="Toggle"
            title="@Tooltip">
        <span class="simple-dropdown-text">@DisplayText</span>
        <svg class="simple-dropdown-arrow" viewBox="0 0 12 12" fill="currentColor">
            <path d="M2 4l4 4 4-4z"/>
        </svg>
    </button>

    @if (isOpen)
    {
        <div class="simple-dropdown-panel" style="min-width: @PanelWidth;">
            @if (ShowSearch)
            {
                <input type="text"
                       class="simple-dropdown-search"
                       placeholder="@SearchPlaceholder"
                       @bind="searchText"
                       @bind:event="oninput"
                       @bind:after="OnSearchChanged"
                       @onkeydown="OnKeyDown"
                       @ref="searchInputRef" />
            }

            <div class="simple-dropdown-list">
                @if (isLoading)
                {
                    <div class="simple-dropdown-message">Loading...</div>
                }
                else if (displayItems.Count == 0)
                {
                    <div class="simple-dropdown-message">No results</div>
                }
                else
                {
                    @for (int i = 0; i < displayItems.Count; i++)
                    {
                        var item = displayItems[i];
                        var index = i;
                        <div class="simple-dropdown-item @(index == highlightedIndex ? "highlighted" : "")"
                             @onclick="() => SelectItem(item)"
                             @onmouseenter="() => highlightedIndex = index">
                            @ItemTemplate(item)
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private bool isOpen;
    private bool isLoading;
    private string searchText = "";
    private int highlightedIndex;
    private List<TOption> displayItems = new();
    private ElementReference searchInputRef;
    private ElementReference containerRef;
    private string componentId = Guid.NewGuid().ToString("N")[..8];

    [Parameter]
    public TOption? SelectedItem { get; set; }

    [Parameter]
    public EventCallback<TOption?> SelectedItemChanged { get; set; }

    [Parameter]
    public IEnumerable<TOption>? Items { get; set; }

    [Parameter]
    public Func<string, Task<IEnumerable<TOption>>>? OnSearch { get; set; }

    [Parameter]
    public Func<TOption, string>? GetDisplayText { get; set; }

    [Parameter]
    public RenderFragment<TOption> ItemTemplate { get; set; } = default!;

    [Parameter]
    public string Placeholder { get; set; } = "Select...";

    [Parameter]
    public string? Tooltip { get; set; }

    [Parameter]
    public string SearchPlaceholder { get; set; } = "Type to search...";

    [Parameter]
    public bool ShowSearch { get; set; } = true;

    [Parameter]
    public string PanelWidth { get; set; } = "280px";

    [Parameter]
    public string? Class { get; set; }

    private string DisplayText => SelectedItem != null && GetDisplayText != null
        ? GetDisplayText(SelectedItem)
        : Placeholder;

    private DotNetObjectReference<SimpleDropdown<TOption>>? dotNetRef;
    private bool jsInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);

            // Initialize the global helper function if it doesn't exist
            await JS.InvokeVoidAsync("eval", @"
                if (!window.meshweaverDropdown) {
                    window.meshweaverDropdown = {
                        refs: {},
                        setRef: function(id, ref) { this.refs[id] = ref; },
                        getRef: function(id) { return this.refs[id]; },
                        clearRef: function(id) { delete this.refs[id]; }
                    };
                }
            ");
        }

        // Initialize JS handler and store reference when dropdown opens
        if (isOpen && dotNetRef != null)
        {
            if (!jsInitialized)
            {
                // Register click-outside handler
                await JS.InvokeVoidAsync("eval", $@"
                    (function() {{
                        if (window['dropdown_{componentId}_handler']) return;
                        const handler = function(e) {{
                            const container = document.querySelector('[data-dropdown-id=""{componentId}""]');
                            if (container && !container.contains(e.target)) {{
                                const ref = window.meshweaverDropdown.getRef('{componentId}');
                                if (ref) {{
                                    ref.invokeMethodAsync('CloseFromOutside');
                                }}
                            }}
                        }};
                        window['dropdown_{componentId}_handler'] = handler;
                        document.addEventListener('click', handler);
                        window['dropdown_{componentId}_cleanup'] = () => {{
                            document.removeEventListener('click', handler);
                            window.meshweaverDropdown.clearRef('{componentId}');
                            window['dropdown_{componentId}_handler'] = null;
                        }};
                    }})();
                ");
                jsInitialized = true;
            }

            // Store the reference using the global helper
            await JS.InvokeVoidAsync("meshweaverDropdown.setRef", componentId, dotNetRef);

            if (ShowSearch && searchInputRef.Context != null)
            {
                try { await searchInputRef.FocusAsync(); } catch { }
            }
        }
    }

    protected override void OnParametersSet()
    {
        // If we have static Items and no search, filter locally
        if (Items != null && OnSearch == null && !isLoading)
        {
            FilterLocalItems();
        }
    }

    private void FilterLocalItems()
    {
        if (Items == null)
        {
            displayItems = new List<TOption>();
            return;
        }

        if (string.IsNullOrWhiteSpace(searchText) || GetDisplayText == null)
        {
            displayItems = Items.Take(20).ToList();
        }
        else
        {
            var search = searchText.ToLowerInvariant();
            displayItems = Items
                .Where(i => GetDisplayText(i).ToLowerInvariant().Contains(search))
                .Take(20)
                .ToList();
        }
    }

    private async Task Toggle()
    {
        isOpen = !isOpen;
        if (isOpen)
        {
            searchText = "";
            highlightedIndex = 0;
            await LoadItems();
        }
    }

    private async Task LoadItems()
    {
        if (OnSearch != null)
        {
            // Async search mode
            isLoading = true;
            StateHasChanged();

            try
            {
                var items = await OnSearch(searchText);
                displayItems = items.Take(20).ToList();
                highlightedIndex = 0;
            }
            catch
            {
                displayItems = new List<TOption>();
            }
            finally
            {
                isLoading = false;
            }
        }
        else
        {
            // Local filter mode
            FilterLocalItems();
        }
    }

    private async Task OnSearchChanged()
    {
        await LoadItems();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowDown":
                if (highlightedIndex < displayItems.Count - 1)
                    highlightedIndex++;
                break;

            case "ArrowUp":
                if (highlightedIndex > 0)
                    highlightedIndex--;
                break;

            case "Enter":
                if (displayItems.Count > 0 && highlightedIndex < displayItems.Count)
                    await SelectItem(displayItems[highlightedIndex]);
                break;

            case "Escape":
                isOpen = false;
                break;
        }
    }

    private async Task SelectItem(TOption item)
    {
        isOpen = false;
        await SelectedItemChanged.InvokeAsync(item);
    }

    [JSInvokable]
    public void CloseFromOutside()
    {
        if (isOpen)
        {
            isOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        try
        {
            JS.InvokeVoidAsync("eval", $"window['dropdown_{componentId}_cleanup']?.();");
        }
        catch { }

        dotNetRef?.Dispose();
    }
}
