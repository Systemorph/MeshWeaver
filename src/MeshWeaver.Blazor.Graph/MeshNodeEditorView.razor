@using Microsoft.Extensions.Logging
@using Microsoft.Extensions.DependencyInjection
@inherits BlazorView<MeshNodeEditorControl, MeshNodeEditorView>

<div class="mesh-node-editor" style="width: 100%; padding: 16px;">
    @if (_isLoading)
    {
        <FluentProgressRing />
    }
    else if (_node == null)
    {
        <FluentMessageBar Title="Not Found" Intent="MessageIntent.Error">
            Node not found at path: @ViewModel.NodePath
        </FluentMessageBar>
    }
    else
    {
        <div class="editor-section metadata-section" style="margin-bottom: 24px;">
            <h3>Metadata</h3>
            <div class="metadata-fields" style="display: flex; flex-direction: column; gap: 12px;">
                <FluentTextField Label="Display Name"
                                 Value="@_name"
                                 @oninput="@(e => OnNameChanged(e.Value?.ToString() ?? string.Empty))"
                                 Style="width: 100%;" />
            </div>
        </div>

        <div class="editor-section content-section">
            <h3>Content</h3>

            @if (_nodeType == "story")
            {
                <div style="height: 400px; border: 1px solid var(--neutral-stroke-rest);">
                    <MonacoEditorView @ref="_monacoEditor"
                                      Value="@_contentText"
                                      ValueChanged="OnContentChanged"
                                      Height="400px"
                                      MaxHeight="400px"
                                      Placeholder="Enter story content in Markdown..." />
                </div>
            }
            else if (_nodeType == "article")
            {
                <div style="height: 400px; border: 1px solid var(--neutral-stroke-rest);">
                    <MonacoEditorView @ref="_monacoEditor"
                                      Value="@_contentText"
                                      ValueChanged="OnContentChanged"
                                      Height="400px"
                                      MaxHeight="400px"
                                      Placeholder="Enter article with YAML frontmatter..."
                                      CompletionProvider="@GetArticleCompletionProvider()" />
                </div>
            }
            else
            {
                <FluentMessageBar Intent="MessageIntent.Info">
                    Content editing is only supported for Story and Article node types.
                </FluentMessageBar>
            }
        </div>

        <div class="editor-status" style="margin-top: 12px; font-size: 12px; color: var(--neutral-foreground-hint);">
            Changes are saved automatically.
        </div>
    }
</div>
