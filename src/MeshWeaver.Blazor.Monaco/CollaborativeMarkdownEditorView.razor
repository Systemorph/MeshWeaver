@using MeshWeaver.Layout
@using MeshWeaver.Layout.Client
@using MeshWeaver.Data
@using MeshWeaver.Blazor.Monaco
@using MeshWeaver.Markdown.Collaboration
@using System.Text.Json
@using System.Reactive.Linq
@using Microsoft.FluentUI.AspNetCore.Components
@implements IDisposable

<div class="collaborative-editor-container">
    @if (BoundShowCommentsPanel)
    {
        <div class="editor-main-content with-panel">
            <div class="editor-area">
                @if (BoundTrackChangesEnabled)
                {
                    <TrackChangesToolbar DocumentId="@BoundDocumentId"
                                          OnAcceptChange="@OnAcceptChange"
                                          OnRejectChange="@OnRejectChange"
                                          OnAcceptAll="@OnAcceptAllChanges"
                                          OnRejectAll="@OnRejectAllChanges" />
                }
                <MonacoEditorView @ref="editorRef"
                                  Value="@BoundValue"
                                  Language="markdown"
                                  Height="@BoundHeight"
                                  IsDisabled="@BoundReadonly"
                                  Placeholder="@BoundPlaceholder"
                                  ShowLineNumbers="true"
                                  ShowBorder="true"
                                  CodeEditMode="true"
                                  ValueChanged="@OnValueChanged" />
            </div>
            <CommentPanel DocumentId="@BoundDocumentId"
                          Comments="@Comments"
                          OnResolveComment="@OnResolveComment"
                          OnDeleteComment="@OnDeleteComment"
                          OnReplyToComment="@OnReplyToComment" />
        </div>
    }
    else
    {
        <div class="editor-main-content">
            <div class="editor-area">
                @if (BoundTrackChangesEnabled)
                {
                    <TrackChangesToolbar DocumentId="@BoundDocumentId"
                                          OnAcceptChange="@OnAcceptChange"
                                          OnRejectChange="@OnRejectChange"
                                          OnAcceptAll="@OnAcceptAllChanges"
                                          OnRejectAll="@OnRejectAllChanges" />
                }
                <MonacoEditorView @ref="editorRef"
                                  Value="@BoundValue"
                                  Language="markdown"
                                  Height="@BoundHeight"
                                  IsDisabled="@BoundReadonly"
                                  Placeholder="@BoundPlaceholder"
                                  ShowLineNumbers="true"
                                  ShowBorder="true"
                                  CodeEditMode="true"
                                  ValueChanged="@OnValueChanged" />
            </div>
        </div>
    }

    @if (BoundShowPreview)
    {
        <div class="preview-panel">
            <div class="preview-header">Preview</div>
            <div class="preview-content">
                @((MarkupString)RenderedPreview)
            </div>
        </div>
    }
</div>

@code {
    private MonacoEditorView? editorRef;
    private List<IDisposable> subscriptions = new();
    private bool isUpdatingFromStream = false;

    private string BoundValue = "";
    private string BoundDocumentId = "";
    private string BoundHeight = "400px";
    private bool BoundReadonly = false;
    private string BoundPlaceholder = "Start typing markdown...";
    private bool BoundTrackChangesEnabled = false;
    private bool BoundShowCommentsPanel = false;
    private bool BoundShowPreview = false;

    private List<RangeComment> Comments = new();
    private List<TrackedChange> TrackedChanges = new();
    private string RenderedPreview = "";

    // Store the data pointer for two-way binding
    private JsonPointerReference? ValuePointer;

    /// <summary>
    /// The view model for this collaborative markdown editor.
    /// </summary>
    [Parameter]
    public CollaborativeMarkdownEditorControl? ViewModel { get; set; }

    /// <summary>
    /// The synchronization stream (required by the view infrastructure).
    /// </summary>
    [Parameter]
    public ISynchronizationStream<JsonElement>? Stream { get; set; }

    /// <summary>
    /// The area name (required by the view infrastructure).
    /// </summary>
    [Parameter]
    public string? Area { get; set; }

    /// <summary>
    /// The data context for resolving data bindings.
    /// </summary>
    [CascadingParameter(Name = "DataContext")]
    public string? DataContext { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        DisposeSubscriptions();
        BindData();
    }

    private void DisposeSubscriptions()
    {
        foreach (var sub in subscriptions)
        {
            sub.Dispose();
        }
        subscriptions.Clear();
    }

    public void Dispose()
    {
        DisposeSubscriptions();
    }

    private void BindData()
    {
        if (ViewModel == null)
            return;

        // Store the value pointer for two-way binding
        ValuePointer = ViewModel.Value as JsonPointerReference;

        // First, get the initial value synchronously
        BoundValue = ResolveValue<string>(ViewModel.Value) ?? "";

        // Then set up reactive subscription for Value changes if it's a pointer reference
        if (Stream != null && ValuePointer != null)
        {
            var subscription = Stream
                .DataBind<string>(ValuePointer, GetEffectiveDataContext())
                .Subscribe(value =>
                {
                    if (value != null && value != BoundValue)
                    {
                        isUpdatingFromStream = true;
                        BoundValue = value;
                        UpdatePreview(value);
                        ExtractAnnotations(value);
                        InvokeAsync(StateHasChanged);
                        isUpdatingFromStream = false;
                    }
                });
            subscriptions.Add(subscription);
        }

        // Bind other properties (one-time, not reactive)
        BoundDocumentId = ResolveValue<string>(ViewModel.DocumentId) ?? Guid.NewGuid().ToString();
        BoundHeight = ResolveValue<string>(ViewModel.Height) ?? "400px";
        BoundReadonly = ResolveValue<bool?>(ViewModel.Readonly) ?? false;
        BoundPlaceholder = ResolveValue<string>(ViewModel.Placeholder) ?? "Start typing markdown...";
        BoundTrackChangesEnabled = ResolveValue<bool?>(ViewModel.TrackChangesEnabled) ?? false;
        BoundShowCommentsPanel = ResolveValue<bool?>(ViewModel.ShowCommentsPanel) ?? false;
        BoundShowPreview = ResolveValue<bool?>(ViewModel.ShowPreview) ?? false;

        // Initial extraction of annotations from content
        ExtractAnnotations(BoundValue);
        UpdatePreview(BoundValue);
    }

    private string? GetEffectiveDataContext()
    {
        return DataContext ?? ViewModel?.DataContext;
    }

    private T? ResolveValue<T>(object? value)
    {
        if (value == null)
            return default;

        // If we have a stream, try to resolve data bindings
        if (Stream != null)
        {
            return Stream.GetDataBoundValue<T>(value, GetEffectiveDataContext());
        }

        // Fall back to direct conversion
        if (value is T typedValue)
            return typedValue;

        if (value is JsonElement element)
        {
            try
            {
                return element.Deserialize<T>();
            }
            catch
            {
                return default;
            }
        }

        // Try string conversion for simple types
        if (typeof(T) == typeof(string))
            return (T)(object)value.ToString()!;

        return default;
    }

    private void ExtractAnnotations(string content)
    {
        if (string.IsNullOrEmpty(content))
        {
            Comments.Clear();
            TrackedChanges.Clear();
            return;
        }

        // Extract comments from embedded markers
        var annotations = MarkdownAnnotationParser.ExtractAllAnnotations(content);

        // Convert to RangeComment records for display
        Comments = annotations
            .Where(a => a.Type == AnnotationType.Comment)
            .Select(a => new RangeComment
            {
                Id = a.MarkerId,
                DocumentId = BoundDocumentId,
                MarkerId = a.MarkerId,
                Author = "Unknown", // TODO: Get from annotation metadata
                Text = "",
                CreatedAt = DateTimeOffset.UtcNow,
                State = CommentState.Active,
                OriginalSelectedText = a.AnnotatedText
            })
            .ToList();

        // Convert to TrackedChange records
        TrackedChanges = annotations
            .Where(a => a.Type == AnnotationType.Insert || a.Type == AnnotationType.Delete)
            .Select(a => new TrackedChange
            {
                Id = a.MarkerId,
                DocumentId = BoundDocumentId,
                MarkerId = a.MarkerId,
                Author = "Unknown",
                Type = a.Type == AnnotationType.Insert ? TrackedChangeType.Insertion : TrackedChangeType.Deletion,
                Status = TrackedChangeStatus.Pending
            })
            .ToList();
    }

    private void UpdatePreview(string content)
    {
        if (string.IsNullOrEmpty(content))
        {
            RenderedPreview = "";
            return;
        }

        // Strip markers for clean preview (TODO: render with highlights)
        var cleanContent = MarkdownAnnotationParser.StripAllMarkers(content);
        // Simple markdown to HTML (TODO: use full Markdig pipeline)
        RenderedPreview = $"<pre>{System.Web.HttpUtility.HtmlEncode(cleanContent)}</pre>";
    }

    private Task OnValueChanged(string value)
    {
        // Don't write back if this change came from the stream subscription
        if (isUpdatingFromStream)
            return Task.CompletedTask;

        // Only update if value actually changed
        if (BoundValue == value)
            return Task.CompletedTask;

        BoundValue = value;
        ExtractAnnotations(value);
        UpdatePreview(value);

        // Write back to stream if we have a data pointer
        if (Stream != null && ValuePointer != null)
        {
            Stream.UpdatePointer(value, GetEffectiveDataContext(), ValuePointer);
        }

        return Task.CompletedTask;
    }

    private async Task OnAcceptChange(string changeId)
    {
        var change = TrackedChanges.FirstOrDefault(c => c.Id == changeId);
        if (change == null) return;

        string newContent;
        if (change.Type == TrackedChangeType.Insertion)
        {
            // Accept insertion = remove markers, keep text
            newContent = MarkdownAnnotationParser.RemoveMarkers(BoundValue, changeId);
        }
        else
        {
            // Accept deletion = remove markers and text
            newContent = MarkdownAnnotationParser.RemoveMarkersAndContent(BoundValue, changeId);
        }

        await UpdateContent(newContent);
    }

    private async Task OnRejectChange(string changeId)
    {
        var change = TrackedChanges.FirstOrDefault(c => c.Id == changeId);
        if (change == null) return;

        string newContent;
        if (change.Type == TrackedChangeType.Insertion)
        {
            // Reject insertion = remove markers and text
            newContent = MarkdownAnnotationParser.RemoveMarkersAndContent(BoundValue, changeId);
        }
        else
        {
            // Reject deletion = remove markers, keep text
            newContent = MarkdownAnnotationParser.RemoveMarkers(BoundValue, changeId);
        }

        await UpdateContent(newContent);
    }

    private async Task OnAcceptAllChanges()
    {
        var content = BoundValue;
        foreach (var change in TrackedChanges.ToList())
        {
            if (change.Type == TrackedChangeType.Insertion)
            {
                content = MarkdownAnnotationParser.RemoveMarkers(content, change.Id);
            }
            else
            {
                content = MarkdownAnnotationParser.RemoveMarkersAndContent(content, change.Id);
            }
        }
        await UpdateContent(content);
    }

    private async Task OnRejectAllChanges()
    {
        var content = BoundValue;
        foreach (var change in TrackedChanges.ToList())
        {
            if (change.Type == TrackedChangeType.Insertion)
            {
                content = MarkdownAnnotationParser.RemoveMarkersAndContent(content, change.Id);
            }
            else
            {
                content = MarkdownAnnotationParser.RemoveMarkers(content, change.Id);
            }
        }
        await UpdateContent(content);
    }

    private async Task OnResolveComment(string commentId)
    {
        // Remove comment markers but keep the text
        var newContent = MarkdownAnnotationParser.RemoveMarkers(BoundValue, commentId);
        await UpdateContent(newContent);
    }

    private async Task OnDeleteComment(string commentId)
    {
        // Remove comment markers but keep the text
        var newContent = MarkdownAnnotationParser.RemoveMarkers(BoundValue, commentId);
        await UpdateContent(newContent);
    }

    private Task OnReplyToComment((string commentId, string reply) args)
    {
        // TODO: Implement reply functionality
        // This would typically post a reply to the comment thread
        return Task.CompletedTask;
    }

    private async Task UpdateContent(string newContent)
    {
        BoundValue = newContent;
        ExtractAnnotations(newContent);
        UpdatePreview(newContent);

        if (editorRef != null)
        {
            await editorRef.SetValueAsync(newContent);
        }

        if (Stream != null && ValuePointer != null)
        {
            Stream.UpdatePointer(newContent, GetEffectiveDataContext(), ValuePointer);
        }

        StateHasChanged();
    }

    public async ValueTask<string> GetValueAsync()
    {
        return editorRef != null ? await editorRef.GetValueAsync() : string.Empty;
    }

    public async Task SetValueAsync(string value)
    {
        if (editorRef != null)
        {
            await editorRef.SetValueAsync(value);
        }
    }

    /// <summary>
    /// Inserts a comment marker at the specified range.
    /// </summary>
    public async Task InsertCommentAsync(int startPos, int endPos, string commentText)
    {
        var markerId = Guid.NewGuid().ToString("N")[..8];
        var newContent = MarkdownAnnotationParser.InsertCommentMarker(BoundValue, startPos, endPos, markerId);
        await UpdateContent(newContent);

        // TODO: Also create the comment record
    }

    /// <summary>
    /// Inserts a track change (insertion) marker at the specified range.
    /// </summary>
    public async Task InsertSuggestionAsync(int startPos, int endPos)
    {
        var markerId = Guid.NewGuid().ToString("N")[..8];
        var newContent = MarkdownAnnotationParser.InsertInsertMarker(BoundValue, startPos, endPos, markerId);
        await UpdateContent(newContent);
    }

    /// <summary>
    /// Inserts a track change (deletion) marker at the specified range.
    /// </summary>
    public async Task InsertDeletionAsync(int startPos, int endPos)
    {
        var markerId = Guid.NewGuid().ToString("N")[..8];
        var newContent = MarkdownAnnotationParser.InsertDeleteMarker(BoundValue, startPos, endPos, markerId);
        await UpdateContent(newContent);
    }
}
