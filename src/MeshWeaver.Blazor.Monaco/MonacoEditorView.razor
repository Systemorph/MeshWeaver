@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.Extensions.Logging
@inject IJSRuntime JSRuntime
@inject ILogger<MonacoEditorView> Logger

<div class="monaco-editor-container" style="@ContainerStyle">
    <StandaloneCodeEditor @ref="editor"
                          Id="@EditorId"
                          ConstructionOptions="GetEditorOptions"
                          OnDidInit="OnEditorInit"
                          OnKeyDown="OnKeyDownHandler"
                          OnDidChangeModelContent="OnContentChanged"
                          CssClass="monaco-editor-view" />
</div>

@code {
    private StandaloneCodeEditor? editor;
    private string EditorId = $"monaco-editor-{Guid.NewGuid():N}";
    private bool isInitialized = false;
    private IJSObjectReference? jsModule;
    private DotNetObjectReference<MonacoEditorView>? dotNetRef;
    private bool isDarkMode = false;
    private bool completionProviderRegistered = false;
    private int lastCompletionItemCount = 0;

    [CascadingParameter(Name = "ThemeMode")]
    public DesignThemeModes Mode { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    [Parameter]
    public EventCallback OnSubmit { get; set; }

    [Parameter]
    public bool IsDisabled { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = "Type your message...";

    [Parameter]
    public string Height { get; set; } = "80px";

    [Parameter]
    public string MaxHeight { get; set; } = "200px";

    [Parameter]
    public CompletionProviderConfig? CompletionProvider { get; set; }

    /// <summary>
    /// Optional async callback for server-side completion with fuzzy scoring.
    /// When provided, this will be called instead of using static CompletionProvider items.
    /// </summary>
    [Parameter]
    public Func<string, Task<CompletionItem[]>>? AsyncCompletionCallback { get; set; }

    private string ContainerStyle => $"height: {Height}; max-height: {MaxHeight}; min-height: 40px;";

    private string GetMonacoTheme() => isDarkMode ? "vs-dark" : "vs";

    private StandaloneEditorConstructionOptions GetEditorOptions(StandaloneCodeEditor ed)
    {
        return new StandaloneEditorConstructionOptions
        {
            Value = Value ?? "",
            Language = "plaintext",
            Theme = GetMonacoTheme(),
            AutomaticLayout = true,
            LineNumbers = "off",
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false,
            WordWrap = "on",
            WrappingIndent = "none",
            FontSize = 14,
            LineHeight = 20,
            Padding = new EditorPaddingOptions { Top = 8, Bottom = 8 },
            RenderLineHighlight = "none",
            OverviewRulerLanes = 0,
            HideCursorInOverviewRuler = true,
            Scrollbar = new EditorScrollbarOptions
            {
                Vertical = "hidden",
                Horizontal = "hidden",
                HandleMouseWheel = true
            },
            QuickSuggestions = new QuickSuggestionsOptions { Other = "on", Comments = "off", Strings = "on" },
            SuggestOnTriggerCharacters = true,
            AcceptSuggestionOnEnter = "on",
            TabCompletion = "on",
            FixedOverflowWidgets = true,
            ReadOnly = IsDisabled,
            // Hide various UI elements
            Folding = false,
            GlyphMargin = false,
            LineDecorationsWidth = 0,
            LineNumbersMinChars = 0,
            RenderWhitespace = "none",
            Contextmenu = false
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        isDarkMode = await IsDarkModeAsync();
    }

    private async Task<bool> IsDarkModeAsync()
    {
        return Mode switch
        {
            DesignThemeModes.Dark => true,
            DesignThemeModes.Light => false,
            _ => await JSRuntime.InvokeAsync<bool>("themeHandler.isDarkMode")
        };
    }

    private async Task OnEditorInit()
    {
        Logger.LogDebug("OnEditorInit called. CompletionProvider={HasProvider}, Items={ItemCount}",
            CompletionProvider != null, CompletionProvider?.Items?.Count ?? 0);
        isInitialized = true;
        dotNetRef = DotNetObjectReference.Create(this);

        // Load custom JS module for placeholder and agent completion
        jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import",
            "./_content/MeshWeaver.Blazor.Monaco/MonacoEditorView.razor.js");

        if (jsModule != null)
        {
            await jsModule.InvokeVoidAsync("initEditor", EditorId, Placeholder, dotNetRef);

            // Register completion provider if configured
            await TryRegisterCompletionProvider();
        }
    }

    private async Task TryRegisterCompletionProvider()
    {
        if (jsModule == null)
            return;

        // Check if async mode should be used
        var useAsync = AsyncCompletionCallback != null;
        var currentItemCount = CompletionProvider?.Items?.Count ?? 0;

        // For async mode, we always register (the callback handles everything)
        // For sync mode, we need items
        if (!useAsync && currentItemCount == 0)
        {
            Logger.LogDebug("Skipping completion provider registration - no items and no async callback");
            return;
        }

        // Skip if already registered with same configuration
        if (completionProviderRegistered && !useAsync && currentItemCount == lastCompletionItemCount)
        {
            Logger.LogDebug("Skipping completion provider registration - already registered with same items");
            return;
        }

        var triggerCharacters = CompletionProvider?.TriggerCharacters ?? ["@"];

        if (useAsync)
        {
            // Async mode - pass minimal config, JS will call back to C#
            var config = new
            {
                triggerCharacters = triggerCharacters,
                useAsync = true,
                items = Array.Empty<object>()
            };
            Logger.LogDebug("Registering async completion provider with triggers: {Triggers}",
                string.Join(",", triggerCharacters));
            await jsModule.InvokeVoidAsync("registerCompletionProvider", EditorId, config);
        }
        else if (CompletionProvider != null)
        {
            // Sync mode - pass all items
            var config = new
            {
                triggerCharacters = triggerCharacters,
                useAsync = false,
                items = CompletionProvider.Items.Select(i => new
                {
                    label = i.Label,
                    insertText = i.InsertText ?? i.Label,
                    description = i.Description ?? "",
                    detail = i.Detail ?? "",
                    category = i.Category ?? ""
                }).ToArray()
            };
            Logger.LogDebug("Registering sync completion provider with {ItemCount} items, triggers: {Triggers}",
                config.items.Length, string.Join(",", triggerCharacters));
            await jsModule.InvokeVoidAsync("registerCompletionProvider", EditorId, config);
        }

        completionProviderRegistered = true;
        lastCompletionItemCount = currentItemCount;
    }

    private async Task OnContentChanged(ModelContentChangedEvent e)
    {
        if (editor != null)
        {
            var value = await editor.GetValue();
            if (value != Value)
            {
                Value = value;
                await ValueChanged.InvokeAsync(value);
            }
        }
    }

    private async Task OnKeyDownHandler(KeyboardEvent e)
    {
        // Handle Enter without Shift to submit
        if (e.Code == "Enter" && !e.ShiftKey && !e.CtrlKey && !e.AltKey)
        {
            // Check if autocomplete widget is visible
            var isWidgetVisible = false;
            if (jsModule != null)
            {
                isWidgetVisible = await jsModule.InvokeAsync<bool>("isAutocompleteVisible", EditorId);
            }

            if (!isWidgetVisible)
            {
                // Prevent default Enter behavior and submit
                await OnSubmit.InvokeAsync();
            }
        }
    }

    [JSInvokable]
    public async Task HandleSubmit()
    {
        await OnSubmit.InvokeAsync();
    }

    /// <summary>
    /// JSInvokable method called from JavaScript to get async completions.
    /// </summary>
    [JSInvokable]
    public async Task<object[]> GetAsyncCompletions(string query)
    {
        if (AsyncCompletionCallback == null)
        {
            return [];
        }

        try
        {
            var items = await AsyncCompletionCallback(query);
            return items.Select(i => new
            {
                label = i.Label,
                insertText = i.InsertText ?? i.Label,
                description = i.Description ?? "",
                detail = i.Detail ?? "",
                category = i.Category ?? ""
            }).ToArray<object>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error getting async completions for query: {Query}", query);
            return [];
        }
    }

    public async ValueTask<string> GetValueAsync()
    {
        if (editor != null)
        {
            return await editor.GetValue();
        }
        return string.Empty;
    }

    public async Task SetValueAsync(string value)
    {
        if (editor != null)
        {
            await editor.SetValue(value);
            Value = value;
        }
    }

    public async Task ClearAsync()
    {
        await SetValueAsync(string.Empty);
    }

    public async Task FocusAsync()
    {
        if (editor != null && isInitialized)
        {
            try
            {
                await editor.Focus();
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Error focusing editor - may not be fully initialized");
            }
        }
    }

    public async Task SetReadOnlyAsync(bool readOnly)
    {
        if (editor != null && isInitialized)
        {
            try
            {
                await editor.UpdateOptions(new EditorUpdateOptions { ReadOnly = readOnly });
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Error setting read-only state - editor may not be fully initialized");
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Only proceed if the editor is fully initialized
        if (!isInitialized || editor == null || jsModule == null)
        {
            return;
        }

        try
        {
            // Check if dark mode changed
            var newDarkMode = await IsDarkModeAsync();
            var themeChanged = newDarkMode != isDarkMode;
            isDarkMode = newDarkMode;

            // Update read-only state and theme
            await editor.UpdateOptions(new EditorUpdateOptions
            {
                ReadOnly = IsDisabled,
                Theme = themeChanged ? GetMonacoTheme() : null
            });

            // Try to register completion provider (will skip if already registered with same items)
            await TryRegisterCompletionProvider();
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Error in OnParametersSetAsync - editor may not be fully initialized");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (jsModule != null)
        {
            try
            {
                await jsModule.InvokeVoidAsync("dispose", EditorId);
            }
            catch
            {
                // Ignore errors during disposal
            }
            await jsModule.DisposeAsync();
        }
        dotNetRef?.Dispose();
    }
}
