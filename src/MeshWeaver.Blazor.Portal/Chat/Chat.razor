@page "/chat"
@using MeshWeaver.AI
@using MeshWeaver.Data
@using MeshWeaver.Layout
@using MeshWeaver.Messaging
@inject AccessService AccessService

@* The standalone /chat composer is the per-user ChatInput node's default ("")
   layout area — databinds message text + harness/agent/model to {user}/_Memex/ChatInput
   (see ChatInputView). Falls back to a direct ThreadChatControl while the user
   identity is still resolving. *@
@{ var chatInputArea = GetChatInputLayoutArea(); }
@if (chatInputArea is not null)
{
    <div style="height: 100%; min-height: 0; display: flex; flex-direction: column;">
        <LayoutAreaView ViewModel="@chatInputArea" Area="chat-input" />
    </div>
}
else
{
    <ThreadChatView ViewModel="@chatControl" />
}

@code {
    private readonly ThreadChatControl chatControl = new();

    private LayoutAreaControl? GetChatInputLayoutArea()
    {
        var userHome = AccessService.Context?.ObjectId ?? AccessService.CircuitContext?.ObjectId;
        return string.IsNullOrEmpty(userHome)
            ? null
            : new LayoutAreaControl(ChatInputNodeType.PathFor(userHome), new LayoutAreaReference(string.Empty));
    }
}
