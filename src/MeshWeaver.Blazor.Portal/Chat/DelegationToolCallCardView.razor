@inherits BlazorView<DelegationToolCallCardControl, DelegationToolCallCardView>
@using MeshWeaver.Layout

@* Rendered for one delegation tool call. Two IMeshNodeStreamCache.GetStream
   subscriptions back this card:
   1. cache.GetStream(MessagePath) → finds the matching ToolCallEntry by
      DelegationPath, reads live Status + Result (last-10-lines preview
      written by ChatClientAgentFactory.ExecuteDelegationAsync's projection).
   2. cache.GetStream(DelegationPath) → reads the sub-thread Name for the title.

   Both subscriptions share the process-wide cache; same path = same upstream
   handle. The whole card is wrapped in <a href> so clicking navigates to
   the sub-thread URL. *@

@if (!string.IsNullOrEmpty(delegationPath))
{
    <a class="delegation-card" href="/@delegationPath">
        <div class="delegation-card-header">
            <span class="delegation-card-badge @badgeCssClass">@badgeIcon @badgeText</span>
            <span class="delegation-card-title">
                @if (!string.IsNullOrEmpty(subThreadName))
                {
                    <strong>@subThreadName</strong>
                }
                @if (!string.IsNullOrEmpty(agentName))
                {
                    <span class="delegation-card-agent">(@agentName)</span>
                }
                @if (string.IsNullOrEmpty(subThreadName) && string.IsNullOrEmpty(agentName))
                {
                    <span>@(title ?? "Delegating…")</span>
                }
            </span>
        </div>
        @if (!string.IsNullOrEmpty(body))
        {
            <pre class="delegation-card-body">@body</pre>
        }
    </a>
}
