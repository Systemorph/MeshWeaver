@using System.Reactive.Linq
@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Services
@using MeshWeaver.Messaging
@using MeshWeaver.Reactive
@using Microsoft.Extensions.DependencyInjection

<SimpleDropdown TOption="QuerySuggestion"
                SelectedItem="@SelectedItem"
                SelectedItemChanged="@OnItemSelected"
                OnSearch="@OnSearch"
                GetDisplayText="@(s => s?.Path ?? Options.Placeholder)"
                Placeholder="@Options.Placeholder"
                SearchPlaceholder="@Options.SearchPlaceholder"
                PanelWidth="@Options.PanelWidth"
                ShowSearch="@Options.ShowSearch"
                Class="@Options.CssClass">
    <ItemTemplate Context="item">
        <div class="mesh-node-autocomplete-item-name">@item.Name</div>
        <div class="mesh-node-autocomplete-item-path">@item.Path</div>
        @if (!string.IsNullOrEmpty(item.NodeType))
        {
            <div class="mesh-node-autocomplete-item-type">@item.NodeType</div>
        }
    </ItemTemplate>
</SimpleDropdown>

@code {
    /// <summary>
    /// The message hub for accessing services.
    /// </summary>
    [Inject] private IMessageHub Hub { get; set; } = null!;

    /// <summary>
    /// Options for configuring the autocomplete behavior.
    /// </summary>
    [Parameter]
    public MeshNodeAutocompleteOptions Options { get; set; } = new();

    /// <summary>
    /// The currently selected item.
    /// </summary>
    [Parameter]
    public QuerySuggestion? SelectedItem { get; set; }

    /// <summary>
    /// Callback when the selected item changes.
    /// </summary>
    [Parameter]
    public EventCallback<QuerySuggestion?> SelectedItemChanged { get; set; }

    /// <summary>
    /// Optional filter by node type - only show nodes that can create this type.
    /// Takes precedence over Options.FilterByCreatableType.
    /// </summary>
    [Parameter]
    public string? FilterByCreatableType { get; set; }

    private string EffectiveCreatableTypeFilter => FilterByCreatableType ?? Options.FilterByCreatableType ?? "";

    private async Task OnItemSelected(QuerySuggestion? item)
    {
        SelectedItem = item;
        await SelectedItemChanged.InvokeAsync(item);
    }

    private IObservable<IReadOnlyList<QuerySuggestion>> OnSearch(string searchText)
    {
        var meshQuery = Hub.ServiceProvider.GetService<IMeshService>();
        if (meshQuery == null)
            return Observable.Return<IReadOnlyList<QuerySuggestion>>([]);

        IObservable<IReadOnlyList<QuerySuggestion>> source = Options.Queries is { Length: > 0 }
            ? QueryAutocompleteHelper.LoadSuggestions(meshQuery, Options.Queries, searchText)
            : meshQuery.Autocomplete(
                    basePath: Options.BasePath,
                    prefix: searchText ?? "",
                    mode: AutocompleteMode.RelevanceFirst,
                    limit: Options.Limit * 3)
                .Select(snapshot => (IReadOnlyList<QuerySuggestion>)snapshot
                    .Select(r => new QuerySuggestion(r.Path, r.Name ?? "", r.NodeType, r.Score, r.Icon))
                    .ToList());

        var limited = source.Select(list => (IReadOnlyList<QuerySuggestion>)list.Take(Options.Limit).ToArray());

        if (string.IsNullOrEmpty(EffectiveCreatableTypeFilter))
            return limited;

        // Filter by creatable type — fully reactive: per-suggestion CanCreate
        // observable folded through ScanTopN(int.MaxValue) into an incremental
        // snapshot. No await, no FirstAsync, no ToTask.
        return source.SelectMany(items =>
            FilterSuggestionsByCreatableType(items, EffectiveCreatableTypeFilter));
    }

    private IObservable<IReadOnlyList<QuerySuggestion>> FilterSuggestionsByCreatableType(
        IReadOnlyList<QuerySuggestion> items, string nodeTypePath)
    {
        var provider = Hub.ServiceProvider.GetService<ICreatableTypesProvider>();
        if (provider == null)
            return Observable.Return(items);

        // For each candidate suggestion, ask the provider whether nodeTypePath
        // is creatable at that path. Reactive: each per-suggestion observable
        // emits once with the verdict; merged + folded via ScanTopN.
        return items.ToObservable()
            .SelectMany(s => CanCreateTypeAtPath(provider, s.Path, nodeTypePath)
                .Where(can => can)
                .Select(_ => s))
            .ScanTopN(int.MaxValue, _bySuggestionOrder);
    }

    private static readonly IComparer<QuerySuggestion> _bySuggestionOrder =
        Comparer<QuerySuggestion>.Create((a, b) =>
            string.Compare(a.Path, b.Path, StringComparison.OrdinalIgnoreCase));

    /// <summary>
    /// Reactive check: does the provider include <paramref name="nodeTypePath"/>
    /// among the types creatable at <paramref name="nodePath"/>? Single
    /// emission, no Task bridge.
    /// </summary>
    private static IObservable<bool> CanCreateTypeAtPath(
        ICreatableTypesProvider provider,
        string nodePath,
        string nodeTypePath)
        => provider.GetCreatableTypes(nodePath, parentNode: null)
            .Take(1)
            .Select(types => types.Any(t =>
                t.NodeTypePath.Equals(nodeTypePath, StringComparison.OrdinalIgnoreCase)));
}
