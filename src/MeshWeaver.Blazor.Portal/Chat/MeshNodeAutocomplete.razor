@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Services
@using MeshWeaver.Messaging
@using Microsoft.Extensions.DependencyInjection

<SimpleDropdown TOption="QuerySuggestion"
                SelectedItem="@SelectedItem"
                SelectedItemChanged="@OnItemSelected"
                OnSearch="@OnSearchAsync"
                GetDisplayText="@(s => s?.Path ?? Options.Placeholder)"
                Placeholder="@Options.Placeholder"
                SearchPlaceholder="@Options.SearchPlaceholder"
                PanelWidth="@Options.PanelWidth"
                ShowSearch="@Options.ShowSearch"
                Class="@Options.CssClass">
    <ItemTemplate Context="item">
        <div class="mesh-node-autocomplete-item-name">@item.Name</div>
        <div class="mesh-node-autocomplete-item-path">@item.Path</div>
        @if (!string.IsNullOrEmpty(item.NodeType))
        {
            <div class="mesh-node-autocomplete-item-type">@item.NodeType</div>
        }
    </ItemTemplate>
</SimpleDropdown>

@code {
    /// <summary>
    /// The message hub for accessing services.
    /// </summary>
    [Inject] private IMessageHub Hub { get; set; } = null!;

    /// <summary>
    /// Options for configuring the autocomplete behavior.
    /// </summary>
    [Parameter]
    public MeshNodeAutocompleteOptions Options { get; set; } = new();

    /// <summary>
    /// The currently selected item.
    /// </summary>
    [Parameter]
    public QuerySuggestion? SelectedItem { get; set; }

    /// <summary>
    /// Callback when the selected item changes.
    /// </summary>
    [Parameter]
    public EventCallback<QuerySuggestion?> SelectedItemChanged { get; set; }

    /// <summary>
    /// Optional filter by node type - only show nodes that can create this type.
    /// Takes precedence over Options.FilterByCreatableType.
    /// </summary>
    [Parameter]
    public string? FilterByCreatableType { get; set; }

    private string EffectiveCreatableTypeFilter => FilterByCreatableType ?? Options.FilterByCreatableType ?? "";

    private async Task OnItemSelected(QuerySuggestion? item)
    {
        SelectedItem = item;
        await SelectedItemChanged.InvokeAsync(item);
    }

    private async Task<IEnumerable<QuerySuggestion>> OnSearchAsync(string searchText)
    {
        var meshQuery = Hub.ServiceProvider.GetService<IMeshQuery>();
        if (meshQuery == null)
        {
            return Enumerable.Empty<QuerySuggestion>();
        }

        try
        {
            // Use AutocompleteAsync with RelevanceFirst mode
            var suggestions = await meshQuery.AutocompleteAsync(
                basePath: Options.BasePath,
                prefix: searchText ?? "",
                mode: AutocompleteMode.RelevanceFirst,
                limit: Options.Limit * 3 // Get more to account for filtering
            ).ToListAsync();

            // If filtering by creatable type, post-filter results
            if (!string.IsNullOrEmpty(EffectiveCreatableTypeFilter))
            {
                suggestions = await FilterByCreatableTypeAsync(suggestions, EffectiveCreatableTypeFilter);
            }

            return suggestions.Take(Options.Limit);
        }
        catch
        {
            return Enumerable.Empty<QuerySuggestion>();
        }
    }

    /// <summary>
    /// Filters suggestions to only include nodes that can create the specified type.
    /// </summary>
    private async Task<List<QuerySuggestion>> FilterByCreatableTypeAsync(
        List<QuerySuggestion> suggestions,
        string nodeTypePath)
    {
        var nodeTypeService = Hub.ServiceProvider.GetService<INodeTypeService>();
        if (nodeTypeService == null)
        {
            return suggestions;
        }

        var result = new List<QuerySuggestion>();

        foreach (var suggestion in suggestions)
        {
            try
            {
                // Check if this node can create the specified type
                var canCreate = await CanCreateTypeAtPathAsync(nodeTypeService, suggestion.Path, nodeTypePath);
                if (canCreate)
                {
                    result.Add(suggestion);
                }
            }
            catch
            {
                // On error, skip this suggestion
            }
        }

        return result;
    }

    /// <summary>
    /// Checks if a specific node type can be created at the given path.
    /// </summary>
    private static async Task<bool> CanCreateTypeAtPathAsync(
        INodeTypeService nodeTypeService,
        string nodePath,
        string nodeTypePath)
    {
        await foreach (var creatableType in nodeTypeService.GetCreatableTypesAsync(nodePath))
        {
            if (creatableType.NodeTypePath.Equals(nodeTypePath, StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }
        return false;
    }
}
