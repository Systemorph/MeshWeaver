@using ChatMessage = Microsoft.Extensions.AI.ChatMessage
@using Microsoft.Extensions.Logging
@inject ILogger<MessageWrapper> Logger

<ChatMessageItem Message="@Message" InProgress="@InProgress" />

@code {
    [Parameter, EditorRequired]
    public required ChatMessage Message { get; set; }

    [Parameter]
    public bool InProgress { get; set; }

    private ChatMessage? previousMessage;
    private string? previousText;

    protected override bool ShouldRender()
    {
        // Only re-render if the message reference has changed
        if (previousMessage == null || !ReferenceEquals(previousMessage, Message))
        {
            Logger.LogDebug("ShouldRender: new message reference, rendering");
            previousMessage = Message;
            previousText = Message.Text;
            return true;
        }

        // For in-progress messages, we need to check if the text content has changed
        // Compare against stored previousText, not the message's current text (same object!)
        if (InProgress)
        {
            var currentText = Message.Text;
            var hasChanged = !string.Equals(previousText, currentText, StringComparison.Ordinal);
            Logger.LogDebug("ShouldRender: InProgress check, hasChanged={HasChanged}, prevLen={PrevLen}, currLen={CurrLen}",
                hasChanged, previousText?.Length ?? 0, currentText?.Length ?? 0);
            if (hasChanged)
            {
                previousText = currentText;
                return true;
            }
        }

        Logger.LogDebug("ShouldRender: returning false");
        return false;
    }
}