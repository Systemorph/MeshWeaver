@inherits BlazorView<ThreadChatControl, ThreadChatView>
@using MeshWeaver.AI
@using MeshWeaver.AI.Commands
@using MeshWeaver.Data
@using MeshWeaver.Layout
@using MeshWeaver.Blazor.Components
@using MeshWeaver.Blazor.Components.Monaco
@using MeshWeaver.Messaging
@using FluentAppearance = Microsoft.FluentUI.AspNetCore.Components.Appearance
@inject NavigationManager NavigationManager

<div class="thread-chat-container @(ViewModel.HideEmptyState ? "compact-mode" : "")" style="@Style">
@if (viewMode == ChatViewMode.ResumeThreads)
{
    <div class="thread-resume-view">
        <div class="resume-header">
            <FluentButton Appearance="FluentAppearance.Stealth" OnClick="SwitchToChatMode" Title="Back to chat">
                <FluentIcon Value="@(new Icons.Regular.Size16.ArrowLeft())" />
            </FluentButton>
            <span style="font-weight: 600;">Threads</span>
        </div>
        <div class="resume-threads-list">
            <MeshSearchView ViewModel="@GetResumeSearchControl()"
                            OnNodeSelected="@OnSelectThread"
                            SelectedPath="@threadPath"
                            Area="resume-threads" />
        </div>
    </div>
}
else
{
    <!-- Message history display (hidden in compact/dashboard mode) -->
    @if (!ViewModel.HideEmptyState)
    {
        <div class="thread-chat-messages" @ref="messagesContainer">
            @{
                var header = GetHeaderCell();
            }
            @if (header != null)
            {
                <LayoutAreaView @key="@($"hdr-{threadPath}")" ViewModel="@header" Stream="@Stream" Area="@($"hdr-{threadPath}")" />
            }
            @{
                var pendingTexts = ThreadViewModel?.PendingMessageTexts ?? Array.Empty<string>();
                var hasAnyMessage = ThreadMessages.Count > 0 || pendingTexts.Count > 0;
            }
            @* Chat history rendered inline per message — one
               IMeshNodeStreamCache subscription per visible id is opened by
               SyncMessageSubscriptions; this template just reads from the
               messageStates dictionary. No per-message LayoutAreaView server
               round-trip; the bubble is the chat's own DOM. *@
            @if (ThreadMessages.Count > 0)
            {
                @foreach (var msgId in ThreadMessages)
                {
                    var state = GetMessageState(msgId);
                    var isUser = state?.Role?.Equals("user", StringComparison.OrdinalIgnoreCase) ?? false;
                    var bubbleRoleClass = isUser ? "thread-msg-user" : "thread-msg-assistant";

                    <div @key="@msgId" class="thread-msg-bubble @bubbleRoleClass">
                    @if (state is null)
                    {
                        <div class="thread-msg-skeleton-line"></div>
                        <div class="thread-msg-skeleton-line" style="width: 80%;"></div>
                    }
                    else
                    {
                        <div class="thread-msg-author @(isUser ? "thread-msg-author-user" : "")">@state.AuthorName</div>
                        @if (!isUser && (!string.IsNullOrEmpty(state.ModelName) || state.Timestamp.HasValue))
                        {
                            <div class="thread-msg-meta">
                                @if (!string.IsNullOrEmpty(state.ModelName))
                                {
                                    <span>@state.ModelName</span>
                                }
                                @if (state.Timestamp.HasValue)
                                {
                                    <span>@state.Timestamp.Value.ToString("HH:mm:ss")</span>
                                }
                            </div>
                        }

                        @if (IsEditing(msgId))
                        {
                            <LayoutAreaView ViewModel="@(new LayoutAreaControl($"{threadPath}/{msgId}", new LayoutAreaReference("Edit")))"
                                            Stream="@Stream" Area="@($"edit-{msgId}")" />
                            <div class="thread-msg-edit-actions">
                                <button class="thread-msg-edit-cancel" @onclick="() => CancelEdit(msgId)">Done</button>
                            </div>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(state.Text))
                            {
                                <MarkdownView ViewModel="@(new MarkdownControl(state.Text).WithStyle("background: transparent;"))"
                                              Stream="@Stream" Area="@($"md-{msgId}")" />
                            }
                            @if (isUser)
                            {
                                <div class="thread-msg-inline-actions">
                                    <button class="thread-msg-action-btn" @onclick="() => StartEdit(msgId)" title="Edit">&#9998;</button>
                                    <button class="thread-msg-action-btn" @onclick="() => ResubmitMessage(msgId)" title="Resubmit">&#8635;</button>
                                    <button class="thread-msg-action-btn" @onclick="() => DeleteFromMessage(msgId)" title="Delete from here">&#128465;</button>
                                </div>
                            }
                        }

                        @if (state.ToolCalls is { Count: > 0 })
                        {
                            <div class="thread-msg-tool-calls">
                                @foreach (var call in state.ToolCalls)
                                {
                                    var isDelegation = !string.IsNullOrEmpty(call.DelegationPath);
                                    var isPending = call.Result == null;
                                    var summary = FormatToolCallSummary(call);

                                    @if (isDelegation)
                                    {
                                        @* Inline link only — sub-thread progress + status lives in the
                                           runtime panel below the chat (anchored near the input). Keeps
                                           the bubble compact and avoids the duplicate "tool call + embedded
                                           streaming area" the user flagged. *@
                                        var delHeader = GetDelegationHeader(call.DelegationPath);
                                        var title = delHeader?.Title ?? summary;
                                        var icon = delHeader?.Icon ?? "/static/NodeTypeIcons/chat.svg";
                                        var stateIcon = isPending
                                            ? "↗"
                                            : (call.IsSuccess ? "✓" : "✗");
                                        var stateClass = isPending
                                            ? "thread-msg-tool-delegation-pending"
                                            : (call.IsSuccess ? "thread-msg-tool-delegation-ok" : "thread-msg-tool-delegation-error");
                                        <a href="/@call.DelegationPath"
                                           class="thread-msg-tool-delegation @stateClass"
                                           title="@title">
                                            <span class="thread-msg-tool-delegation-state">@stateIcon</span>
                                            <img src="@icon" alt="" class="thread-msg-tool-delegation-icon" />
                                            <span class="thread-msg-tool-delegation-title">@title</span>
                                            <span class="thread-msg-tool-delegation-agent">@summary</span>
                                        </a>
                                    }
                                    else
                                    {
                                        var display = FormatToolCallDisplay(call);
                                        var change = display.IsNodeModifying ? FindChange(state.UpdatedNodes, display.Path) : null;

                                        <details class="thread-msg-tool-entry">
                                            <summary class="thread-msg-tool-entry-name">
                                                <span class="thread-msg-tool-done @(call.IsSuccess ? "" : "thread-msg-tool-error")">@(call.IsSuccess ? "✓" : "✗")</span>
                                                <span>@display.Verb</span>
                                                @if (!string.IsNullOrEmpty(display.Path))
                                                {
                                                    <text>&nbsp;</text>
                                                    <a href="/@display.Path" class="thread-msg-tool-path" @onclick:stopPropagation>@display.Path</a>
                                                }
                                                @if (change is not null)
                                                {
                                                    @if (change.VersionBefore.HasValue && change.VersionAfter.HasValue)
                                                    {
                                                        <a class="thread-msg-tool-action"
                                                           href="/@display.Path/VersionDiff?from=@(change.VersionBefore)&to=@(change.VersionAfter)"
                                                           @onclick:stopPropagation>Diff</a>
                                                    }
                                                    @if (change.VersionBefore.HasValue)
                                                    {
                                                        <a class="thread-msg-tool-action thread-msg-tool-action-muted"
                                                           href="/@display.Path/VersionDiff?version=@(change.VersionBefore)"
                                                           @onclick:stopPropagation>Revert v@(change.VersionBefore)</a>
                                                    }
                                                }
                                            </summary>
                                            @if (!string.IsNullOrEmpty(call.Arguments))
                                            {
                                                <pre class="thread-msg-tool-args">@call.Arguments</pre>
                                            }
                                            @if (!string.IsNullOrEmpty(call.Result))
                                            {
                                                <pre class="thread-msg-tool-result">@call.Result</pre>
                                            }
                                        </details>
                                    }
                                }
                            </div>
                        }
                    }
                    </div>
                }
            }
            @* Pending user messages (PendingMessageTexts) and running sub-threads
               moved OUT of the scrollable history into the runtime panel
               immediately above the input — see `.thread-runtime-panel` below.
               Keeps the chat history clean (only persisted messages) and pins
               in-flight state next to the input where the user is acting. *@
            @if (!hasAnyMessage && isCreatingThread)
            {
                <div class="empty-thread-message">
                    <FluentProgressRing />
                    <p>Creating thread...</p>
                </div>
            }
            else if (!hasAnyMessage && string.IsNullOrEmpty(threadPath))
            {
                <div class="empty-thread-message">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Chat())" Color="Color.Neutral" />
                    <p>Start a conversation</p>
                    <p class="hint">Use @("@") references to include context from other nodes</p>
                </div>
            }
        </div>
    }

    <!-- Execution status bar — shows when thread is executing -->
    @if (ThreadViewModel?.IsExecuting == true)
    {
        <div class="thread-exec-bar">
            <div class="thread-exec-header">
                <span class="thread-exec-star">&#10041;</span>
                <span class="thread-exec-status">@(ThreadViewModel.ExecutionStatus ?? "Generating response...")</span>
                <button class="thread-exec-cancel" @onclick="CancelExecution">
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" style="opacity: 0.7;"><rect x="3" y="3" width="10" height="10" rx="1"/></svg>
                    Stop
                </button>
            </div>
            @if (!string.IsNullOrEmpty(ThreadViewModel.StreamingText))
            {
                <div class="thread-exec-preview">@TruncateText(ThreadViewModel.StreamingText, 300)</div>
            }
            @if (ThreadViewModel.StreamingToolCalls is { Count: > 0 })
            {
                <div class="thread-exec-tools">
                    @foreach (var call in ThreadViewModel.StreamingToolCalls)
                    {
                        <span class="thread-exec-tool @(call.Result != null ? "done" : "pending")">
                            @(call.Result != null ? "✓" : "●") @(call.DisplayName ?? call.Name)
                        </span>
                    }
                </div>
            }
            @* Pending-user-message rendering moved INTO the chat history (above)
               so the user sees their submission immediately — including before
               round dispatch starts streaming. The exec-bar no longer duplicates
               the queue display. *@
        </div>
    }

    @* ─── Runtime panel ─────────────────────────────────────────────────
       Pinned just above the chat input. Two sections, top-down:
         (1) Running sub-threads — live cards for every delegation whose
             sub-thread currently has IsExecuting=true. Title, icon,
             ExecutionStatus, and a truncated preview of StreamingText.
             Drops out the moment the sub-thread settles.
         (2) Scheduled messages — entries the user typed while a round is
             in flight. They sit BELOW the running section so the visual
             ordering matches the lifecycle: "in flight" above,
             "waiting to be picked up" below. When the round completes
             and the inbox drains, they get promoted to real messages in
             the history. *@
    var runningSubThreads = GetRunningSubThreads().ToList();
    var runtimeScheduled = ThreadViewModel?.PendingMessageTexts ?? Array.Empty<string>();
    @if (runningSubThreads.Count > 0 || runtimeScheduled.Count > 0)
    {
        <div class="thread-runtime-panel">
            @if (runningSubThreads.Count > 0)
            {
                <div class="thread-runtime-section thread-runtime-subthreads">
                    <div class="thread-runtime-section-label">Running sub-threads</div>
                    @foreach (var (path, header) in runningSubThreads)
                    {
                        var subIcon = header.Icon ?? "/static/NodeTypeIcons/chat.svg";
                        var subTitle = header.Title ?? path;
                        var preview = !string.IsNullOrWhiteSpace(header.StreamingText)
                            ? TruncateText(header.StreamingText.Trim(), 200)
                            : (header.ExecutionStatus ?? "Working…");
                        <a class="thread-runtime-subthread-card" href="/@path" title="@subTitle">
                            <img src="@subIcon" alt="" class="thread-runtime-subthread-icon" />
                            <div class="thread-runtime-subthread-body">
                                <div class="thread-runtime-subthread-title">@subTitle</div>
                                <div class="thread-runtime-subthread-preview">@preview</div>
                            </div>
                            <span class="thread-runtime-subthread-pulse" aria-hidden="true">●</span>
                        </a>
                    }
                </div>
            }
            @if (runtimeScheduled.Count > 0)
            {
                <div class="thread-runtime-section thread-runtime-scheduled">
                    <div class="thread-runtime-section-label">
                        Scheduled <span class="thread-runtime-hint">— waiting for current round to finish</span>
                    </div>
                    @foreach (var pendingText in runtimeScheduled)
                    {
                        <div class="thread-runtime-scheduled-row" @key="@($"pending-{pendingText.GetHashCode()}")">
                            <span class="thread-runtime-scheduled-icon" aria-hidden="true">⏳</span>
                            <span class="thread-runtime-scheduled-text">@pendingText</span>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- Footer: input — pinned at bottom, never scrolls. The
         `is-allocating` modifier overlays the "Allocating agent…" banner
         INSIDE the existing input-area box rather than replacing the
         whole subtree, so the dialog keeps its full height (breadcrumb +
         editor + send + attachments stay laid out underneath, just
         dimmed + non-interactive). Without this the chat shrinks to a
         small panel during thread allocation and snaps back when the
         thread is ready, which the user noticed. -->
    <div class="thread-chat-footer">
        <div class="thread-chat-input-area @(showSubmissionProgress ? "is-allocating" : "")">
        @if (showSubmissionProgress)
        {
            <div class="thread-allocating-panel">
                <FluentProgressRing Style="width: 28px; height: 28px;" />
                <div class="thread-allocating-text">
                    <div class="thread-allocating-title">Allocating agent…</div>
                    <div class="thread-allocating-subtitle">Creating conversation and redirecting</div>
                </div>
            </div>
        }
        @{ var inputDimmed = showSubmissionProgress; }
        <div class="thread-chat-input-content @(inputDimmed ? "dimmed" : "")" aria-hidden="@(inputDimmed.ToString().ToLowerInvariant())">

        @* Active agent + model selectors. Sourced from the workspace synced
           query (agents from namespace:Agent, models from namespace:Model
           via the same nodeType:Agent|LanguageModel union). Selecting an
           agent updates the model to that agent's preferred model
           (GetPreferredModelInfoForAgent); the user can override per
           thread by picking a different model. Slash commands /agent and
           /model still work (ChatCommandRegistry) and update the same
           selection state. *@
        <div class="thread-chat-selectors">
            <SimpleDropdown TOption="AgentDisplayInfo"
                            SelectedItem="@selectedAgentInfo"
                            SelectedItemChanged="@OnAgentChanged"
                            Items="@agentDisplayInfos"
                            GetDisplayText="@(a => a?.Name ?? "Agent…")"
                            Placeholder="Agent…"
                            Tooltip="@(selectedAgentInfo?.Path ?? "Pick an agent (or type /agent)")"
                            PanelWidth="420px"
                            Class="selector-agent">
                <ItemTemplate Context="agent">
                    <div class="dropdown-icon-name">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Bot())" />
                        <span class="simple-dropdown-item-name">@agent.Name</span>
                    </div>
                    @if (!string.IsNullOrEmpty(agent.Description))
                    {
                        <div class="simple-dropdown-item-description">@TruncateText(agent.Description, 80)</div>
                    }
                </ItemTemplate>
            </SimpleDropdown>

            <SimpleDropdown TOption="ModelInfo"
                            SelectedItem="@selectedModelInfo"
                            SelectedItemChanged="@OnModelChanged"
                            Items="@availableModels"
                            GetDisplayText="@(m => m?.Name ?? (availableModels.Count == 0 ? "(no models)" : "Model…"))"
                            GetGroupKey="@(m => m.Provider)"
                            Placeholder="Model…"
                            Tooltip="@(selectedModelInfo != null ? $"{selectedModelInfo.Provider}: {selectedModelInfo.Name}" : "Pick a model (or type /model)")"
                            ShowSearch="false"
                            PanelWidth="360px"
                            Class="selector-model">
                <ItemTemplate Context="model">
                    <div class="dropdown-icon-name">
                        @{
                            var brand = ModelBadge(model);
                        }
                        <span class="model-badge @brand.Class" title="@brand.Tooltip">@brand.Label</span>
                        <span class="simple-dropdown-item-name">@model.Name</span>
                    </div>
                </ItemTemplate>
            </SimpleDropdown>

            @if (!string.IsNullOrEmpty(lastCommandStatus))
            {
                <span class="thread-chat-status-msg @(lastCommandStatusIsError ? "error" : "")">@lastCommandStatus</span>
            }
        </div>

        @* Inline picker rendered when /agent or /model was invoked without
           an argument. AgentCommand and ModelCommand return Widget = AgentPicker
           or ModelPicker; selection routes back through OnAgentPickerSelected
           / OnModelPickerSelected which is equivalent to running
           /agent <name> / /model <name>. *@
        @if (pendingWidget == ChatWidget.AgentPicker)
        {
            <div class="thread-chat-widget">
                <div class="thread-chat-widget-header">
                    <span>Pick an agent</span>
                    <FluentButton Appearance="FluentAppearance.Stealth" OnClick="DismissWidget" Title="Close">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Dismiss())" />
                    </FluentButton>
                </div>
                <div class="thread-chat-widget-list">
                    @foreach (var agent in agentDisplayInfos)
                    {
                        var captured = agent;
                        <button class="thread-chat-widget-item @(captured.Name == selectedAgentInfo?.Name ? "selected" : "")"
                                @onclick="() => OnAgentPickerSelected(captured)" type="button">
                            <div class="thread-chat-widget-item-name">@captured.Name</div>
                            @if (!string.IsNullOrEmpty(captured.Path) && captured.Path != captured.Name)
                            {
                                <div class="thread-chat-widget-item-path">@captured.Path</div>
                            }
                            @if (!string.IsNullOrEmpty(captured.Description))
                            {
                                <div class="thread-chat-widget-item-desc">@TruncateText(captured.Description, 90)</div>
                            }
                        </button>
                    }
                    @if (agentDisplayInfos.Count == 0)
                    {
                        <div class="thread-chat-widget-empty">No agents available.</div>
                    }
                </div>
            </div>
        }
        else if (pendingWidget == ChatWidget.ModelPicker)
        {
            <div class="thread-chat-widget">
                <div class="thread-chat-widget-header">
                    <span>Pick a model</span>
                    <FluentButton Appearance="FluentAppearance.Stealth" OnClick="DismissWidget" Title="Close">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Dismiss())" />
                    </FluentButton>
                </div>
                <div class="thread-chat-widget-list">
                    @foreach (var grp in availableModels.GroupBy(m => m.Provider).OrderBy(g => g.First().Order))
                    {
                        <div class="thread-chat-widget-group">@grp.Key</div>
                        @foreach (var model in grp)
                        {
                            var captured = model;
                            <button class="thread-chat-widget-item @(captured.Name == selectedModelInfo?.Name ? "selected" : "")"
                                    @onclick="() => OnModelPickerSelected(captured)" type="button">
                                <div class="thread-chat-widget-item-name">@captured.Name</div>
                            </button>
                        }
                    }
                    @if (availableModels.Count == 0)
                    {
                        <div class="thread-chat-widget-empty">No models available.</div>
                    }
                </div>
            </div>
        }

        @* Monaco editor for markdown input with completion. Stays visible during
           execution (Claude.ai pattern) — typing while a round is in flight is
           allowed; the SubmitMessageRequest gets queued via PendingUserMessages
           and dispatches when the current round completes. Esc on the editor
           cancels the in-flight round (CancelExecution); the typed text is
           preserved for the next send. *@
        <div class="input-container" @onkeydown="@OnInputKeyDown">
            <MonacoEditorView @ref="monacoEditor"
                              Value="@MessageText"
                              ValueChanged="@OnMessageTextChanged"
                              OnSubmit="SendMessage"
                              OnCompletionAccepted="OnCompletionItemAccepted"
                              Placeholder="@placeholderText"
                              Height="80px"
                              MaxHeight="200px"
                              CompletionProvider="@GetCompletionConfig()"
                              CompletionCallback="@GetCompletions" />
        </div>
        <!-- Send button row (agent + model dropdowns removed; use /agent and /model commands) -->
        <div class="selector-bar">
            @if (!submissionHandler.IsInputEnabled)
            {
                <FluentButton Appearance="FluentAppearance.Accent" Disabled="true" Title="Sending...">
                    <FluentProgressRing Style="width: 20px; height: 20px;" />
                </FluentButton>
            }
            else
            {
                <FluentButton Appearance="FluentAppearance.Accent" OnClick="SendMessage"
                              Disabled="@(string.IsNullOrWhiteSpace(MessageText))" Title="Send">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Send())" Color="Color.Neutral" />
                </FluentButton>
            }
        </div>

        @* Attachment chips — pinned to the bottom of the input dialog,
           below the send button. Removable; click navigates to the node. *@
        @if (attachments.Count > 0)
        {
            <div class="thread-chat-attachments">
                <ReferenceChipCollection
                    Attachments="@attachments"
                    OnAttachmentRemoved="@OnAttachmentRemoved"
                    OnChipClick="@OnChipClicked" />
            </div>
        }
        </div> @* /thread-chat-input-content *@
    </div>
    </div>
}

</div>
