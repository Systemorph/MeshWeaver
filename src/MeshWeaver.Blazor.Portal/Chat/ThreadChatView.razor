@inherits BlazorView<ThreadChatControl, ThreadChatView>
@using MeshWeaver.AI
@using MeshWeaver.Data
@using MeshWeaver.Layout
@using MeshWeaver.Blazor.Components
@using MeshWeaver.Blazor.Components.Monaco
@using MeshWeaver.Messaging
@using FluentAppearance = Microsoft.FluentUI.AspNetCore.Components.Appearance
@inject NavigationManager NavigationManager

<div class="thread-chat-container @(ViewModel.HideEmptyState ? "compact-mode" : "") @(HasNoMessages ? "no-messages" : "")" style="@Style">
@if (viewMode == ChatViewMode.ResumeThreads)
{
    <div class="thread-resume-view">
        <div class="resume-header">
            <FluentButton Appearance="FluentAppearance.Stealth" OnClick="SwitchToChatMode" Title="Back to chat">
                <FluentIcon Value="@(new Icons.Regular.Size16.ArrowLeft())" />
            </FluentButton>
            <span style="font-weight: 600;">Threads</span>
        </div>
        <div class="resume-threads-list">
            @* Live-bound to hub.GetQuery (synced, write-consistent snapshot) — see
               SwitchToResumeModeAsync. A thread UPDATE on submit re-emits the full set with the
               thread present, so it never drops out of the list the way the old MeshSearchView/
               IMeshService.Query binding did. *@
            @if (resumeLoading)
            {
                <FluentProgressRing Style="width: 24px; height: 24px; margin: 16px auto;" />
            }
            else if (resumeThreads.Count == 0)
            {
                <div class="resume-thread-date" style="padding: 12px; text-align: center;">No threads yet</div>
            }
            else
            {
                @foreach (var thread in resumeThreads)
                {
                    <div class="resume-thread-item @(thread.Path == threadPath ? "resume-thread-item-active" : "")"
                         @key="@thread.Path"
                         @onclick="@(() => OnSelectThread(thread))">
                        <div class="resume-thread-name">@(thread.Name ?? thread.Id)</div>
                        <div class="resume-thread-date">@thread.LastModified.LocalDateTime.ToString("MMM d, HH:mm")</div>
                    </div>
                }
            }
        </div>
    </div>
}
else
{
    @* ─── In-thread navigation menu ──────────────────────────────────────
       The thread's position in the hierarchy (ancestors → current → sub-threads),
       my OTHER open threads (all partitions), and the context chip. Toggles between
       a horizontal top bar, a vertical left rail, and hidden (CycleNavLayout); the
       whole shell captures Option-Tab to cycle the other open threads. Only on the
       full-page thread view (ShowFullHeader + a real thread). *@
    <div class="thread-nav-shell nav-@(_navLayout.ToString().ToLowerInvariant())" tabindex="0" @onkeydown="OnThreadShellKeyDown">
    @if (ShowThreadNav && _navLayout != ThreadNavLayout.Hidden)
    {
        var ancestors = ThreadAncestors();
        var others = OtherOpenThreads();
        var navCtx = ThreadViewModel?.InitialContext;
        <nav class="thread-nav-menu">
            <div class="thread-nav-toolbar">
                <button class="thread-nav-cycle" @onclick="CycleNavLayout"
                        title="@($"Navigation: {_navLayout} — click for next (top bar → left rail → hidden)")">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Navigation())" Color="Color.Neutral" />
                </button>
                <span class="thread-nav-title">Threads</span>
            </div>

            @if (!string.IsNullOrEmpty(navCtx))
            {
                <div class="thread-nav-section">
                    <button type="button" class="thread-context-chip thread-nav-context"
                            title="@($"Context: {navCtx} — click to open")"
                            @onclick="@(() => OnContextChipClicked(navCtx))">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Location())" Color="Color.Accent" />
                        <span class="thread-context-chip-text">@(ThreadViewModel?.InitialContextDisplayName ?? LastSegment(navCtx))</span>
                    </button>
                </div>
            }

            <div class="thread-nav-section thread-nav-hierarchy">
                <div class="thread-nav-section-label">This thread</div>
                @foreach (var anc in ancestors)
                {
                    <a class="thread-nav-item thread-nav-ancestor" href="/@anc.Path" title="@anc.Path">
                        <span class="thread-nav-item-glyph">&#8593;</span>
                        <span class="thread-nav-item-text">@anc.Label</span>
                    </a>
                }
                <div class="thread-nav-item thread-nav-current" title="@threadPath">
                    <span class="thread-nav-item-glyph">&#9679;</span>
                    <span class="thread-nav-item-text">@(string.IsNullOrWhiteSpace(ThreadViewModel?.Name) ? "This thread" : ThreadViewModel!.Name)</span>
                </div>
                @foreach (var child in childThreads)
                {
                    <a class="thread-nav-item thread-nav-child" href="/@child.Path" title="@child.Path">
                        <span class="thread-nav-item-glyph">&#8627;</span>
                        <span class="thread-nav-item-text">@(child.Name ?? child.Id)</span>
                    </a>
                }
            </div>

            <div class="thread-nav-section thread-nav-others">
                <div class="thread-nav-section-label">
                    <span>Other open threads</span>
                    @if (others.Count > 0) { <span class="thread-nav-count">@others.Count</span> }
                    <span class="thread-nav-hint" title="Option-Tab cycles through them">&#8997;&#8677;</span>
                </div>
                @if (others.Count == 0)
                {
                    <div class="thread-nav-empty">No other open threads</div>
                }
                else
                {
                    @foreach (var t in others.Take(30))
                    {
                        <a class="thread-nav-item" href="/@t.Path" title="@t.Path">
                            <span class="thread-nav-item-glyph">&#9211;</span>
                            <span class="thread-nav-item-text">@(t.Name ?? t.Id)</span>
                        </a>
                    }
                }
            </div>
        </nav>
    }
    else if (ShowThreadNav)
    {
        <button class="thread-nav-reveal" @onclick="CycleNavLayout" title="Show thread navigation">
            <FluentIcon Value="@(new Icons.Regular.Size16.Navigation())" Color="Color.Neutral" />
        </button>
    }
    <div class="thread-nav-body">
    <!-- Message history display (hidden in compact/dashboard mode) -->
    @if (!ViewModel.HideEmptyState)
    {
        <div class="thread-chat-messages" @ref="messagesContainer">
            @* Full-page hero header — rendered NATIVELY (not an embedded layout area) as the FIRST
               item INSIDE the scroll so it scrolls away with the conversation. Compact: a top row with
               the thread's starting-point context chip (right) + Mark Done, then a click-to-edit title,
               then a click-to-edit description as a smaller abstract. Side panel leaves ShowFullHeader
               false (and CSS hides .thread-full-header there) → only the compact Header area renders. *@
            @if (ViewModel.ShowFullHeader && !string.IsNullOrEmpty(threadPath))
            {
                <div class="thread-full-header">
                    <div class="thread-full-header-toprow">
                        @{
                            var hdrCtxPath = ThreadViewModel?.InitialContext;
                            var hdrCtxName = ThreadViewModel?.InitialContextDisplayName;
                        }
                        @if (!string.IsNullOrEmpty(hdrCtxPath))
                        {
                            <button type="button" class="thread-context-chip"
                                    title="@($"Context: {hdrCtxPath} — click to open")"
                                    @onclick="@(() => OnContextChipClicked(hdrCtxPath))">
                                <FluentIcon Value="@(new Icons.Regular.Size16.Location())" Color="Color.Accent" />
                                <span class="thread-context-chip-text">@(hdrCtxName ?? LastSegment(hdrCtxPath))</span>
                            </button>
                        }
                        @if (!IsReadOnlyThread && ThreadViewModel?.IsExecuting != true)
                        {
                            var isDone = ThreadViewModel?.IsDone == true;
                            <FluentButton Appearance="@(isDone ? FluentAppearance.Neutral : FluentAppearance.Accent)"
                                          IconStart="@(isDone ? (Icon)new Icons.Regular.Size16.ArrowUndo() : new Icons.Regular.Size16.Checkmark())"
                                          OnClick="ToggleThreadDone">
                                @(isDone ? "Reopen" : "Mark Done")
                            </FluentButton>
                        }
                    </div>

                    @* Title — nice headline; click to edit (writes the thread node's Name). *@
                    @if (isEditingTitle)
                    {
                        <FluentTextField @ref="_titleEditField" @bind-Value="editTitleText" Immediate="true"
                                         class="thread-header-title-input" Placeholder="Untitled thread"
                                         @onkeydown="OnTitleEditKeyDown" @onblur="CommitTitleEdit" />
                    }
                    else
                    {
                        var hasTitle = !string.IsNullOrWhiteSpace(ThreadViewModel?.Name);
                        <div class="thread-header-title @(IsReadOnlyThread ? "" : "editable") @(hasTitle ? "" : "untitled")"
                             @onclick="BeginTitleEdit"
                             title="@(IsReadOnlyThread ? null : "Click to edit title")">@(hasTitle ? ThreadViewModel!.Name : "Untitled thread")</div>
                    }

                    @* Description — smaller abstract; click to edit (writes the thread node's Description). *@
                    @if (isEditingDescription)
                    {
                        <FluentTextArea @ref="_descEditField" @bind-Value="editDescriptionText" Immediate="true"
                                        class="thread-header-desc-input" Rows="2" Placeholder="Add a description…"
                                        @onkeydown="OnDescriptionEditKeyDown" @onblur="CommitDescriptionEdit" />
                    }
                    else if (!string.IsNullOrWhiteSpace(ThreadViewModel?.Description))
                    {
                        <div class="thread-header-desc @(IsReadOnlyThread ? "" : "editable")"
                             @onclick="BeginDescriptionEdit"
                             title="@(IsReadOnlyThread ? null : "Click to edit description")">@ThreadViewModel!.Description</div>
                    }
                    else if (!IsReadOnlyThread)
                    {
                        <div class="thread-header-desc editable placeholder"
                             @onclick="BeginDescriptionEdit" title="Click to add a description">Add a description…</div>
                    }
                </div>
            }
            @{
                var header = GetHeaderCell();
            }
            @if (header != null)
            {
                <LayoutAreaView @key="@($"hdr-{threadPath}")" ViewModel="@header" Stream="@Stream" Area="@($"hdr-{threadPath}")" />
            }
            @{
                var pendingTexts = ThreadViewModel?.PendingMessageTexts ?? Array.Empty<string>();
                var hasAnyMessage = ThreadMessages.Count > 0 || pendingTexts.Count > 0;
            }
            @* Chat history rendered inline per message — one
               IMeshNodeStreamCache subscription per visible id is opened by
               SyncMessageSubscriptions; this template just reads from the
               messageStates dictionary. No per-message LayoutAreaView server
               round-trip; the bubble is the chat's own DOM. *@
            @if (ThreadMessages.Count > 0)
            {
                @foreach (var msgId in ThreadMessages)
                {
                    var state = GetMessageState(msgId);
                    var isUser = state?.Role?.Equals("user", StringComparison.OrdinalIgnoreCase) ?? false;
                    var bubbleRoleClass = isUser ? "thread-msg-user" : "thread-msg-assistant";

                    <div @key="@msgId" class="thread-msg-bubble @bubbleRoleClass @(IsMissing(msgId) ? "thread-msg-missing" : "") @(IsEditing(msgId) ? "thread-msg-editing" : "")">
                    @if (state is null && IsMissing(msgId))
                    {
                        @* Satellite cell never delivered an emission within the
                           probe window — either deleted, never materialised, or
                           denied by RLS. Surface as "Missing message" instead
                           of an indefinite skeleton so the user knows the chat
                           continued past this point. *@
                        <div class="thread-msg-author thread-msg-author-user">— message missing —</div>
                        <div class="thread-msg-meta">id: @msgId</div>
                    }
                    else if (state is null)
                    {
                        <div class="thread-msg-skeleton-line"></div>
                        <div class="thread-msg-skeleton-line" style="width: 80%;"></div>
                    }
                    else
                    {
                        <div class="thread-msg-author @(isUser ? "thread-msg-author-user" : "")">@state.AuthorName</div>
                        @* Assistant meta row: Harness · time · duration · in/out tokens.
                           Model name intentionally dropped — the harness is the headline
                           identity; for Claude Code / Copilot the model is implied. *@
                        @if (!isUser && (!string.IsNullOrEmpty(state.Harness) || state.Timestamp.HasValue))
                        {
                            <div class="thread-msg-meta">
                                @if (!string.IsNullOrEmpty(state.Harness))
                                {
                                    <span class="thread-msg-harness">@state.Harness</span>
                                }
                                @if (state.Timestamp.HasValue)
                                {
                                    <span>@state.Timestamp.Value.ToString("HH:mm:ss")</span>
                                }
                                @* Stream duration:
                                   • Live (ticker-driven, "0:12") ONLY while the THREAD is executing —
                                     a cell can't be streaming once the thread is idle. Gating on
                                     IsExecuting (not just the cell's Status string) is what STOPS the
                                     clock when the round ends: if a cell's Status lags/sticks at
                                     "Streaming" the bare-status check would tick forever.
                                   • CompletedAt set → frozen final ("1:23"). The terminal completion
                                     push always stamps CompletedAt, so an idle thread shows the frozen
                                     duration here.
                                   • Otherwise (legacy bubbles without Status/CompletedAt) → omit. *@
                                @{ var isLiveStreaming = state.Status == "Streaming" && ThreadViewModel?.IsExecuting == true; }
                                @if (isLiveStreaming && state.Timestamp.HasValue)
                                {
                                    <span class="thread-msg-elapsed thread-msg-elapsed-live" title="Streaming...">@FormatElapsed(state.Timestamp)</span>
                                }
                                else if (state.Timestamp.HasValue && state.CompletedAt.HasValue)
                                {
                                    <span class="thread-msg-elapsed" title="Stream duration">@FormatElapsed(state.Timestamp, state.CompletedAt)</span>
                                }
                                @if (state.InputTokens.HasValue || state.OutputTokens.HasValue)
                                {
                                    <span class="thread-msg-tokens" title="Token usage">@($"{state.InputTokens ?? 0:N0} in / {state.OutputTokens ?? 0:N0} out")</span>
                                }
                            </div>
                        }

                        @if (IsEditing(msgId))
                        {
                            <LayoutAreaView ViewModel="@(new LayoutAreaControl($"{threadPath}/{msgId}", new LayoutAreaReference("Edit")))"
                                            Stream="@Stream" Area="@($"edit-{msgId}")" />
                            <div class="thread-msg-edit-actions">
                                <button class="thread-msg-edit-cancel" @onclick="() => CancelEdit(msgId)">Done</button>
                            </div>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(state.Text))
                            {
                                <MarkdownView ViewModel="@(new MarkdownControl(state.Text).WithStyle("background: transparent;"))"
                                              Stream="@Stream" Area="@($"md-{msgId}")" />
                                @* Hover actions. Edit/Resubmit/Delete only for the user's OWN cells; "New
                                   thread from this cell" is available on ANY input/output cell — it opens a
                                   fresh side-panel composer prefilled with this cell's text (created on submit). *@
                                <div class="thread-msg-inline-actions">
                                    @if (isUser && !IsReadOnlyThread)
                                    {
                                        <button class="thread-msg-action-btn" @onclick="() => StartEdit(msgId)" title="Edit">&#9998;</button>
                                        <button class="thread-msg-action-btn" @onclick="() => ResubmitMessage(msgId)" title="Resubmit">&#8635;</button>
                                        <button class="thread-msg-action-btn" @onclick="() => DeleteFromMessage(msgId)" title="Delete from here">&#128465;</button>
                                    }
                                    <button class="thread-msg-action-btn" @onclick="() => NewThreadFromCell(msgId)" title="New thread from this cell">&#8599;</button>
                                </div>
                            }
                        }

                        @if (state.ToolCalls is { Count: > 0 })
                        {
                            @* Compact tool-call window: running on top, then pending, capped at 5
                               (ToolCallVisibility); completed backfill the leftover slots and a just-
                               finished call lingers ~5s before collapsing. The remainder folds behind a
                               "running · pending · completed" toggle. *@
                            var toolView = ToolCallVisibility.Partition(state.ToolCalls, DateTime.UtcNow);
                            var toolExpanded = IsToolCallsExpanded(msgId);

                            RenderFragment<ToolCallEntry> renderToolCall = call =>
                                @<text>
                                    @{
                                        var isDelegation = !string.IsNullOrEmpty(call.DelegationPath);
                                        var isPending = call.Result == null;
                                        var callSummary = FormatToolCallSummary(call);
                                    }
                                    @if (isDelegation)
                                    {
                                        var delHeader = GetDelegationHeader(call.DelegationPath);
                                        var title = delHeader?.Title ?? callSummary;
                                        var icon = delHeader?.Icon ?? "/static/NodeTypeIcons/chat.svg";
                                        var stateIcon = isPending
                                            ? "↗"
                                            : (call.IsSuccess ? "✓" : "✗");
                                        var stateClass = isPending
                                            ? "thread-msg-tool-delegation-pending"
                                            : (call.IsSuccess ? "thread-msg-tool-delegation-ok" : "thread-msg-tool-delegation-error");
                                        @* Inline link only — sub-thread progress + status lives in the
                                           runtime panel below the chat (anchored near the input). Keeps
                                           the bubble compact and avoids the duplicate "tool call + embedded
                                           streaming area" the user flagged. *@
                                        <a href="/@call.DelegationPath"
                                           class="thread-msg-tool-delegation @stateClass"
                                           title="@title">
                                            <span class="thread-msg-tool-delegation-state">@stateIcon</span>
                                            <img src="@icon" alt="" class="thread-msg-tool-delegation-icon" />
                                            <span class="thread-msg-tool-delegation-title">@title</span>
                                            <span class="thread-msg-tool-delegation-agent">@callSummary</span>
                                        </a>
                                    }
                                    else
                                    {
                                        var display = FormatToolCallDisplay(call);
                                        var change = display.IsNodeModifying ? FindChange(state.UpdatedNodes, display.Path) : null;
                                        <details class="thread-msg-tool-entry">
                                            <summary class="thread-msg-tool-entry-name">
                                                <span class="thread-msg-tool-done @(call.IsSuccess ? "" : "thread-msg-tool-error")">@(call.IsSuccess ? "✓" : "✗")</span>
                                                <span>@display.Verb</span>
                                                @if (!string.IsNullOrEmpty(display.Path))
                                                {
                                                    <text>&nbsp;</text>
                                                    <a href="/@display.Path" class="thread-msg-tool-path" title="@display.Path" @onclick:stopPropagation>@display.Path</a>
                                                }
                                                @if (change is not null)
                                                {
                                                    @if (change.VersionBefore.HasValue && change.VersionAfter.HasValue)
                                                    {
                                                        <a class="thread-msg-tool-action"
                                                           href="/@display.Path/VersionDiff?from=@(change.VersionBefore)&to=@(change.VersionAfter)"
                                                           @onclick:stopPropagation>Diff</a>
                                                    }
                                                    @if (change.VersionBefore.HasValue)
                                                    {
                                                        <a class="thread-msg-tool-action thread-msg-tool-action-muted"
                                                           href="/@display.Path/VersionDiff?version=@(change.VersionBefore)"
                                                           @onclick:stopPropagation>Revert v@(change.VersionBefore)</a>
                                                    }
                                                }
                                            </summary>
                                            @if (!string.IsNullOrEmpty(call.Arguments))
                                            {
                                                <pre class="thread-msg-tool-args">@call.Arguments</pre>
                                            }
                                            @if (!string.IsNullOrEmpty(call.Result))
                                            {
                                                <pre class="thread-msg-tool-result">@call.Result</pre>
                                            }
                                        </details>
                                    }
                                </text>;

                            @* Wrap the whole round's tool calls in a collapsible group so a long
                               tool-call history collapses to a single summary line once complete and
                               stops pushing the assistant's reply off-screen. Open while any call runs,
                               or when the cell has no assistant text (tool-only — the user needs to see
                               what was done); collapsed once complete with a reply present. *@
                            var anyPending = state.ToolCalls.Any(c => c.Result is null);
                            var failCount = state.ToolCalls.Count(c => !c.IsSuccess && c.Result is not null);
                            var anyFailed = failCount > 0;
                            var groupHasText = !string.IsNullOrWhiteSpace(state.Text);
                            var groupOpen = anyPending || !groupHasText;
                            var groupIcon = anyPending ? "↗" : (anyFailed ? "✗" : "✓");
                            var groupLabel = anyFailed
                                ? $"{state.ToolCalls.Count} tool calls ({failCount} failed)"
                                : $"{state.ToolCalls.Count} tool calls";
                            <details class="thread-msg-tool-group" open="@groupOpen">
                            <summary class="thread-msg-tool-group-summary">
                                <span class="thread-msg-tool-done @(anyFailed ? "thread-msg-tool-error" : "")">@groupIcon</span>
                                @groupLabel
                            </summary>
                            <div class="thread-msg-tool-calls">
                                @foreach (var call in toolView.Visible)
                                {
                                    @renderToolCall(call)
                                }
                                @if (toolView.HasHidden)
                                {
                                    <button type="button" class="thread-msg-tool-more@(toolExpanded ? " expanded" : "")"
                                            @onclick="() => ToggleToolCalls(msgId)"
                                            title="@(toolExpanded ? "Hide finished tool calls" : "Show all tool calls")">
                                        <span class="thread-msg-tool-more-caret">@(toolExpanded ? "▾" : "▸")</span>
                                        @if (toolView.RunningCount > 0)
                                        {
                                            <span class="thread-msg-tool-more-count running">@toolView.RunningCount running</span>
                                        }
                                        @if (toolView.PendingCount > 0)
                                        {
                                            <span class="thread-msg-tool-more-count pending">@toolView.PendingCount pending</span>
                                        }
                                        @if (toolView.CompletedCount > 0)
                                        {
                                            <span class="thread-msg-tool-more-count completed">@toolView.CompletedCount completed</span>
                                        }
                                    </button>
                                    @if (toolExpanded)
                                    {
                                        @foreach (var call in toolView.Hidden)
                                        {
                                            @renderToolCall(call)
                                        }
                                    }
                                }
                            </div>
                            </details>
                        }
                    }
                    </div>
                }
            }
            @* Pending user messages (PendingMessageTexts) and running sub-threads
               moved OUT of the scrollable history into the runtime panel
               immediately above the input — see `.thread-runtime-panel` below.
               Keeps the chat history clean (only persisted messages) and pins
               in-flight state next to the input where the user is acting. *@
            @if (!hasAnyMessage && isCreatingThread)
            {
                <div class="empty-thread-message">
                    <FluentProgressRing />
                    <p>Creating thread...</p>
                </div>
            }
            else if (!hasAnyMessage && string.IsNullOrEmpty(threadPath))
            {
                <div class="empty-thread-message">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Chat())" Color="Color.Neutral" />
                    <p>Start a conversation</p>
                    <p class="hint">Use @("@") references to include context from other nodes</p>
                </div>
            }
        </div>
    }

    @* ─── Bottom bar ───────────────────────────────────────────────────
       Everything pinned to the bottom of the screen, top-down: execution
       status ("where we are"), the runtime panel, then the input footer
       (harness selector + editor + send button). Grouped in one flex
       column so the chat history above scrolls and this block stays put. *@
    <div class="thread-chat-bottom">

    <!-- Execution status bar — shows when thread is executing -->
    @if (ThreadViewModel?.IsExecuting == true)
    {
        <div class="thread-exec-bar">
            <div class="thread-exec-header">
                <span class="thread-exec-star">&#10041;</span>
                <span class="thread-exec-status">@(ThreadViewModel.ExecutionStatus ?? "Generating response...")</span>
                @* Elapsed-time chip — driven by the 1 s ticker installed in OnInitialized.
                   ExecutionStartedAt is null until the round flips Status → Executing, so
                   the chip auto-hides for the brief StartingExecution window. *@
                @if (ThreadViewModel.ExecutionStartedAt is { } started)
                {
                    <span class="thread-exec-elapsed" title="Elapsed since round started">@FormatElapsed(started)</span>
                }
                @if (!IsReadOnlyThread)
                {
                    <button class="thread-exec-cancel" @onclick="CancelExecution">
                        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" style="opacity: 0.7;"><rect x="3" y="3" width="10" height="10" rx="1"/></svg>
                        Stop
                    </button>
                }
            </div>
            @if (!string.IsNullOrEmpty(ThreadViewModel.StreamingText))
            {
                <div class="thread-exec-preview">@TruncateText(ThreadViewModel.StreamingText, 300)</div>
            }
            @if (ThreadViewModel.StreamingToolCalls is { Count: > 0 })
            {
                <div class="thread-exec-tools">
                    @foreach (var call in ThreadViewModel.StreamingToolCalls)
                    {
                        <span class="thread-exec-tool @(call.Result != null ? "done" : "pending")">
                            @(call.Result != null ? "✓" : "●") @(call.DisplayName ?? call.Name)
                        </span>
                    }
                </div>
            }
            @* Pending-user-message rendering moved INTO the chat history (above)
               so the user sees their submission immediately — including before
               round dispatch starts streaming. The exec-bar no longer duplicates
               the queue display. *@
        </div>
    }

    @* ─── Runtime panel ─────────────────────────────────────────────────
       Pinned just above the chat input. Two sections, top-down:
         (1) Running sub-threads — live cards for every delegation whose
             sub-thread currently has IsExecuting=true. Title, icon,
             ExecutionStatus, and a truncated preview of StreamingText.
             Drops out the moment the sub-thread settles.
         (2) Scheduled messages — entries the user typed while a round is
             in flight. They sit BELOW the running section so the visual
             ordering matches the lifecycle: "in flight" above,
             "waiting to be picked up" below. When the round completes
             and the inbox drains, they get promoted to real messages in
             the history. *@
    @{
        var runningSubThreads = GetRunningSubThreads().ToList();
        var runtimeScheduled = ThreadViewModel?.PendingMessageTexts ?? Array.Empty<string>();
    }
    @if (runningSubThreads.Count > 0 || runtimeScheduled.Count > 0)
    {
        <div class="thread-runtime-panel">
            @if (runningSubThreads.Count > 0)
            {
                <div class="thread-runtime-section thread-runtime-subthreads">
                    <div class="thread-runtime-section-label">Running sub-threads</div>
                    @foreach (var (path, header) in runningSubThreads)
                    {
                        var subIcon = header.Icon ?? "/static/NodeTypeIcons/chat.svg";
                        var subTitle = header.Title ?? path;
                        var preview = !string.IsNullOrWhiteSpace(header.StreamingText)
                            ? TruncateText(header.StreamingText.Trim(), 200)
                            : (header.ExecutionStatus ?? "Working…");
                        <a class="thread-runtime-subthread-card" href="/@path" title="@subTitle">
                            <img src="@subIcon" alt="" class="thread-runtime-subthread-icon" />
                            <div class="thread-runtime-subthread-body">
                                <div class="thread-runtime-subthread-title">
                                    <span class="thread-runtime-subthread-title-text">@subTitle</span>
                                    @* Elapsed-time chip for the sub-thread — null StartedAt
                                       means the sub-thread is in StartingExecution and
                                       hasn't flipped LastActivityAt yet; chip auto-hides. *@
                                    @if (header.StartedAt is { } subStarted)
                                    {
                                        <span class="thread-runtime-subthread-elapsed" title="Elapsed since sub-thread started">@FormatElapsed(subStarted)</span>
                                    }
                                </div>
                                <div class="thread-runtime-subthread-preview">@preview</div>
                            </div>
                            <span class="thread-runtime-subthread-pulse" aria-hidden="true">●</span>
                        </a>
                    }
                </div>
            }
            @if (runtimeScheduled.Count > 0)
            {
                <div class="thread-runtime-section thread-runtime-scheduled">
                    <div class="thread-runtime-section-label">
                        Scheduled <span class="thread-runtime-hint">— waiting for current round to finish</span>
                    </div>
                    @foreach (var pendingText in runtimeScheduled)
                    {
                        <div class="thread-runtime-scheduled-row" @key="@($"pending-{pendingText.GetHashCode()}")">
                            <span class="thread-runtime-scheduled-icon" aria-hidden="true">⏳</span>
                            <span class="thread-runtime-scheduled-text">@pendingText</span>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- Footer: input — pinned at bottom, never scrolls. The
         `is-allocating` modifier overlays the "Allocating agent…" banner
         INSIDE the existing input-area box rather than replacing the
         whole subtree, so the dialog keeps its full height (breadcrumb +
         editor + send + attachments stay laid out underneath, just
         dimmed + non-interactive). Without this the chat shrinks to a
         small panel during thread allocation and snaps back when the
         thread is ready, which the user noticed. -->
    @* Input footer — only for editable threads. Other users' threads are
       read-only (threads are editable only by their owner). *@
    @if (!IsReadOnlyThread)
    {
    <div class="thread-chat-footer">
        <div class="thread-chat-input-area @(showSubmissionProgress ? "is-allocating" : "")">
        @if (showSubmissionProgress)
        {
            <div class="thread-allocating-panel">
                <FluentProgressRing Style="width: 28px; height: 28px;" />
                <div class="thread-allocating-text">
                    <div class="thread-allocating-title">Allocating agent…</div>
                    <div class="thread-allocating-subtitle">Creating conversation and redirecting</div>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(lastSubmittedText))
            {
                @* Echo the just-submitted message under the progress so it's visible during create+redirect. *@
                <div class="thread-allocating-submitted">
                    <div class="thread-allocating-submitted-label">You</div>
                    <div class="thread-allocating-submitted-text">@lastSubmittedText</div>
                </div>
            }
        }
        @{ var inputDimmed = showSubmissionProgress; }
        <div class="thread-chat-input-content @(inputDimmed ? "dimmed" : "")" aria-hidden="@(inputDimmed.ToString().ToLowerInvariant())">

        @* Thin, READ-ONLY thread status — what this thread uses (harness · agent · model)
           plus a token-usage chip, fully data-bound to the composer selections
           (boundHarness/boundAgentPath/boundModelPath). The chip reads the per-model TokenUsage
           satellites ({threadPath}/_Usage/*). Selection itself is via the /harness, /agent and
           /model slash-commands — this row only displays. *@
        @if (!string.IsNullOrEmpty(boundHarness) || !string.IsNullOrEmpty(boundModelPath) || !string.IsNullOrEmpty(boundAgentPath))
        {
            var harnessId = LastSegment(boundHarness);
            var isClaudeCode = string.Equals(harnessId, "ClaudeCode", StringComparison.OrdinalIgnoreCase);
            var isCopilot = string.Equals(harnessId, "Copilot", StringComparison.OrdinalIgnoreCase);
            <div class="thread-chat-status-row">
                @if (!string.IsNullOrEmpty(boundHarness))
                {
                    <button type="button" class="thread-chat-status-item is-clickable"
                            title="Harness — click to switch runtime" @onclick='() => OnStatusChipClick("harness", false)'>
                        @HarnessIcon(boundHarness) @harnessId
                    </button>
                }
                @if (isClaudeCode || isCopilot)
                {
                    @* Claude Code and GitHub Copilot run the user's OWN CLI subscription — there is no mesh
                       agent to pick, and the model is the CLI's OWN (probed from its init/hello message),
                       NOT the user's mesh Model-partition selection. Claude Code adds reasoning effort.
                       These chips forward /model|/effort 1:1 to the CLI (cliOwned: true). *@
                    @* harnessId is non-null here: this branch is gated by isClaudeCode || isCopilot,
                       which are false when harnessId is null (string.Equals(null, "ClaudeCode") == false). *@
                    var harnessRt = harnessRuntimes.GetValueOrDefault(harnessId!);
                    <button type="button" class="thread-chat-status-item is-clickable"
                            title="Model (reported by @harnessId) — click to change" @onclick='() => OnStatusChipClick("model", true)'>
                        @ChipSvg("model") @(string.IsNullOrEmpty(harnessRt?.Model) ? "…" : harnessRt!.Model)
                    </button>
                    @if (isClaudeCode)
                    {
                        <button type="button" class="thread-chat-status-item is-clickable"
                                title="Reasoning effort — click to change" @onclick='() => OnStatusChipClick("effort", true)'>
                            @ChipSvg("effort") @(string.IsNullOrEmpty(harnessRt?.Effort) ? "…" : harnessRt!.Effort)
                        </button>
                    }
                }
                else
                {
                    @if (!string.IsNullOrEmpty(boundAgentPath))
                    {
                        <button type="button" class="thread-chat-status-item is-clickable"
                                title="Agent — click to change" @onclick='() => OnStatusChipClick("agent", false)'>
                            @ChipSvg("agent") @LastSegment(boundAgentPath)
                        </button>
                    }
                    @if (!string.IsNullOrEmpty(boundModelPath))
                    {
                        <button type="button" class="thread-chat-status-item is-clickable"
                                title="Model: @boundModelPath — click to change" @onclick='() => OnStatusChipClick("model", false)'>
                            @ChipSvg("model") @LastSegment(boundModelPath)
                        </button>
                    }
                }
                @* The token chip renders its own leading separator only when it has usage data,
                   so it sits inline after the model/effort chip on this same row (no dangling "·"). *@
                <ThreadTokenChip ThreadPath="@threadPath" />
            </div>
        }

        @* GENERIC node picker — every node-pick command (/agent, /model, /harness, and any
           module-defined one) pops THIS one menu. The command supplied the query + title; the
           host queried the mesh (OpenPicker) and listed the nodes; clicking one writes its PATH
           to the command's composer field. No per-command widget. *@
        @* Interactive login (Connect) dialog — /login opens it. (1) choose a method, (2) account →
           redirect to the browser auth URL, (3) paste a code/token only if the flow needs it; a still-valid
           token completes silently. API key / gateway store a pasted credential. *@
        @if (LoginDialogOpen)
        {
            @* stopPropagation on the ROOT div (a native element) so Enter/Esc/arrows in the dialog don't
               bubble to the thread shell's global shortcuts — the modifier can't sit on the FluentTextField
               components (it conflicts with their @onkeydown parameter), so it lives here. *@
            <div class="thread-chat-widget" @onkeydown:stopPropagation="true">
                <div class="thread-chat-widget-header">
                    <span>Log in to @(_loginHarness!.Definition.DisplayName)</span>
                    <button class="thread-msg-action-btn" @onclick="CancelConnect" title="Close">&#10005;</button>
                </div>
                <FluentStack Orientation="Microsoft.FluentUI.AspNetCore.Components.Orientation.Vertical" VerticalGap="10"
                             Style="padding:12px 14px; flex:1 1 auto; min-height:0; overflow-y:auto;">
                    @if (_loginMethod is null)
                    {
                        <div style="color:var(--neutral-foreground-hint);">How do you want to sign in?</div>
                        @if (_connectProvider is not null)
                        {
                            <FluentButton Appearance="FluentAppearance.Accent" Style="width:100%;"
                                          OnClick="@(() => ChooseLoginMethod("account"))">
                                Log in with your @(_loginHarness!.Definition.DisplayName) account (browser)
                            </FluentButton>
                        }
                        <FluentButton Appearance="FluentAppearance.Neutral" Style="width:100%;"
                                      OnClick="@(() => ChooseLoginMethod("apiKey"))">Use an API key</FluentButton>
                        <FluentButton Appearance="FluentAppearance.Neutral" Style="width:100%;"
                                      OnClick="@(() => ChooseLoginMethod("gateway"))">Use a gateway / proxy</FluentButton>
                    }
                    else if (_loginMethod == "account")
                    {
                        @switch (_connectStatus)
                        {
                            case MeshWeaver.AI.Connect.ConnectStatus.Connected:
                                <div style="color:var(--success-foreground, #16a34a);">&#10003; Connected — you can chat now.</div>
                                break;

                            case MeshWeaver.AI.Connect.ConnectStatus.Error err:
                                <div style="color:var(--error-foreground, #dc2626);">@err.Reason</div>
                                <FluentButton Appearance="FluentAppearance.Accent"
                                              OnClick="@(() => StartHarnessConnect(_loginHarness!))">Try again</FluentButton>
                                <FluentButton Appearance="FluentAppearance.Neutral"
                                              OnClick="@(() => ChooseLoginMethod("apiKey"))">Use an API key instead</FluentButton>
                                break;

                            case MeshWeaver.AI.Connect.ConnectStatus.Connecting c when !string.IsNullOrEmpty(c.Challenge.VerificationUrl):
                                <div><strong>1</strong>&nbsp; Open the authorization page and approve:</div>
                                <FluentAnchor Href="@c.Challenge.VerificationUrl" Target="_blank"
                                              Appearance="FluentAppearance.Accent">Open authorization page&nbsp;↗</FluentAnchor>
                                @if (c.Challenge.RequiresPastedCode)
                                {
                                    <div style="margin-top:4px;"><strong>2</strong>&nbsp; Paste the code shown, then submit:</div>
                                    <FluentTextField @bind-Value="_connectCode" Immediate="true" Placeholder="Paste code"
                                                     @onkeydown="OnConnectInputKeyDown" Style="width:100%;" />
                                    <FluentButton Appearance="FluentAppearance.Accent" Style="width:100%;"
                                                  Disabled="@(_connectBusy || string.IsNullOrWhiteSpace(_connectCode))"
                                                  OnClick="SubmitConnectCode">@(_connectBusy ? "Verifying…" : "Submit code")</FluentButton>
                                }
                                else if (!string.IsNullOrEmpty(c.Challenge.UserCode))
                                {
                                    <div>Enter this code in the browser: <strong>@c.Challenge.UserCode</strong></div>
                                    <div style="color:var(--neutral-foreground-hint);">Waiting for authorization…</div>
                                }
                                break;

                            default:
                                <div style="color:var(--neutral-foreground-hint);">Starting login…</div>
                                break;
                        }
                    }
                    else
                    {
                        @if (_connectStatus is MeshWeaver.AI.Connect.ConnectStatus.Error keyErr)
                        {
                            <div style="color:var(--error-foreground, #dc2626);">@keyErr.Reason</div>
                        }
                        @if (_loginMethod == "gateway")
                        {
                            <div>Gateway base URL:</div>
                            <FluentTextField @bind-Value="_connectBaseUrl" Immediate="true" Placeholder="https://…" Style="width:100%;" />
                            <div style="margin-top:4px;">Gateway token:</div>
                        }
                        else
                        {
                            <div>Paste your Anthropic Console API key (starts with
                                <span style="font-family:var(--monospace-font-family,ui-monospace,monospace);">sk-ant-api</span>):</div>
                        }
                        <FluentTextField @bind-Value="_connectCode" Immediate="true"
                                         Placeholder="@(_loginMethod == "gateway" ? "token" : "sk-ant-api…")"
                                         TextFieldType="Microsoft.FluentUI.AspNetCore.Components.TextFieldType.Password"
                                         @onkeydown="OnConnectInputKeyDown" Style="width:100%;" />
                        <FluentButton Appearance="FluentAppearance.Accent" Style="width:100%;"
                                      Disabled="@(_connectBusy || string.IsNullOrWhiteSpace(_connectCode))"
                                      OnClick="SubmitLoginCredential">Save</FluentButton>
                        <FluentButton Appearance="FluentAppearance.Neutral" Style="width:100%;"
                                      OnClick="@(() => { _loginMethod = null; _connectStatus = null; _connectCode = string.Empty; _connectBaseUrl = string.Empty; })">← Back</FluentButton>
                    }
                </FluentStack>
            </div>
        }
        @if (pendingPicker is { } picker)
        {
            <div class="thread-chat-widget"
                 tabindex="0"
                 @ref="_pickerWidget"
                 @onkeydown="OnPickerKeyDown"
                 @onkeydown:preventDefault="true"
                 @onkeydown:stopPropagation="true">
                <div class="thread-chat-widget-header">
                    <span>@picker.Title</span>
                    <button class="thread-msg-action-btn" @onclick="DismissWidget" title="Close">&#10005;</button>
                </div>
                <div class="thread-chat-widget-list">
                    @for (var i = 0; i < pickerNodes.Count; i++)
                    {
                        var node = pickerNodes[i];
                        @if (IsPickerHeaderNode(node))
                        {
                            @* Non-selectable group title (e.g. a model provider). Its models
                               render as selectable items underneath. *@
                            <div class="thread-chat-widget-group">
                                @if (!string.IsNullOrEmpty(node.Icon) && !node.Icon.TrimStart().StartsWith("<"))
                                {
                                    <img class="thread-chat-widget-group-icon" src="@node.Icon" alt="" />
                                }
                                <span class="thread-chat-widget-group-name">@(node.Name ?? LastSegment(node.Path))</span>
                            </div>
                        }
                        else
                        {
                            var isActive = i == _pickerHighlight;
                            <button class="thread-chat-widget-item @(isActive ? "thread-chat-widget-item--active" : "")"
                                    @onclick="@(() => SelectFromPicker(picker, node))">
                                @if (!string.IsNullOrEmpty(node.Icon))
                                {
                                    @if (node.Icon.TrimStart().StartsWith("<"))
                                    {
                                        <span class="thread-chat-widget-item-icon">@((MarkupString)node.Icon)</span>
                                    }
                                    else
                                    {
                                        <img class="thread-chat-widget-item-icon" src="@node.Icon" alt="" />
                                    }
                                }
                                <span class="thread-chat-widget-item-text">
                                    <span class="thread-chat-widget-item-name">@(node.Name ?? node.Id)</span>
                                    @if (!string.IsNullOrEmpty(node.Description))
                                    {
                                        <span class="thread-chat-widget-item-desc">@node.Description</span>
                                    }
                                </span>
                            </button>
                        }
                    }
                    @if (pickerNodes.Count == 0)
                    {
                        <div class="thread-chat-widget-empty">Nothing to pick.</div>
                    }
                    else if (_pickerHighlight < 0)
                    {
                        @* Titles only, nothing selectable — e.g. providers present but no models. *@
                        <div class="thread-chat-widget-empty">No models available to select.</div>
                    }
                </div>
            </div>
        }


        @* Monaco editor for markdown input with completion. Stays visible during
           execution (Claude.ai pattern) — typing while a round is in flight is
           allowed; it queues via PendingUserMessages and dispatches when the round
           completes. Esc cancels the in-flight round; the typed text is preserved. *@
        @* @onclick FocusComposerAsync: any click in the composer region focuses the
           editor. Defuses the thread-nav-shell amplifier (issue #199): the shell is
           tabindex="0" with outline:none for Alt-Tab thread cycling, so a click that
           misses Monaco's hit-target would otherwise focus the shell and every
           printable keystroke would be silently discarded while the input LOOKS
           active. Focusing an already-focused editor is a no-op. *@
        <div class="input-container" @onkeydown="@OnInputKeyDown" @onclick="@FocusComposerAsync">
            @* AutoGrow: the composer expands with the content from 80px up to the adaptive
               max (mirrors the command palette's min(440px, calc(100vh - 180px)) pattern),
               then scrolls internally — no more invisible scrolling in a fixed 80px box. *@
            <MonacoEditorView @ref="monacoEditor"
                              Value="@MessageText"
                              ValueChanged="@OnMessageTextChanged"
                              OnSubmit="SendMessage"
                              OnCompletionAccepted="OnCompletionItemAccepted"
                              Placeholder="@placeholderText"
                              Height="80px"
                              MaxHeight="min(400px, calc(100vh - 280px))"
                              AutoGrow="true"
                              CompletionProvider="@GetCompletionConfig()"
                              CompletionCallback="@GetCompletions" />
        </div>

        @* Attachments split: the navigation-context chip(s) sit inline in the compact bottom
           row (next to the harness combobox + Send); any extra @@-reference attachments get
           their own section above the row so the row never overflows. *@
        @{
            var contextChips = attachments.Where(a => a.IsContext).ToList();
            var referenceChips = attachments.Where(a => !a.IsContext).ToList();
        }
        @if (referenceChips.Count > 0)
        {
            <div class="thread-chat-attachments">
                <ReferenceChipCollection
                    Attachments="@referenceChips"
                    OnAttachmentRemoved="@OnAttachmentRemoved"
                    OnChipClick="@OnChipClicked" />
            </div>
        }

        @* Compact bottom row: context chip(s) + Send. Harness/agent/model are chosen via the
           /harness /agent /model slash-commands (which write the same composer node) — the in-footer
           MeshNodePicker comboboxes were removed: eagerly resolving a picked agent whose model is not
           wired threw out of the embedded area and tore the whole composer down (the "choosing
           Assistant crashes the chat" defect). Slash-command selection records the choice on the
           composer without building the agent, so it can never crash the footer. *@
        <div class="thread-chat-bottom-row" style="display: flex; align-items: center; gap: 8px; flex-wrap: nowrap; margin-top: 4px;">
            @if (contextChips.Count > 0)
            {
                <div class="thread-chat-context" style="flex: 1 1 auto; min-width: 0; overflow: hidden;">
                    @* Context chip → open the context object in the OPPOSITE panel (OnContextChipClicked):
                       main-view chat peeks it in the side panel, side-panel chat brings it to the main
                       view. @-reference chips above use OnChipClicked (modal preview) instead. *@
                    <ReferenceChipCollection
                        Attachments="@contextChips"
                        OnAttachmentRemoved="@OnAttachmentRemoved"
                        OnChipClick="@OnContextChipClicked" />
                </div>
            }
            <div class="selector-bar" style="flex: 0 0 auto; margin-left: auto;">
                @if (!submissionHandler.IsInputEnabled)
                {
                    <FluentButton Appearance="FluentAppearance.Accent" Disabled="true" Title="Sending...">
                        <FluentProgressRing Style="width: 20px; height: 20px;" />
                    </FluentButton>
                }
                else
                {
                    @* Never block on the running round. A message sent mid-round is accepted immediately
                       (echoed via PendingUserMessages) and drained when the current round finishes — the
                       composer clears on submit and is ready for the next message right away. Esc cancels
                       the in-flight round. Disabled ONLY for genuinely un-sendable states: empty text or
                       no model. *@
                    <FluentButton Appearance="FluentAppearance.Accent" OnClick="SendMessage"
                                  Disabled="@(string.IsNullOrWhiteSpace(MessageText))"
                                  Title="Send">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Send())" Color="Color.Neutral" />
                    </FluentButton>
                }
            </div>
        </div>
        @if (HasNoModels)
        {
            <span class="thread-chat-status-msg error">
                No language model is available. Add one in Settings → Language Models
                (or configure a provider's models for this deployment) to start chatting.
            </span>
        }
        @if (!string.IsNullOrEmpty(lastCommandStatus))
        {
            <span class="thread-chat-status-msg @(lastCommandStatusIsError ? "error" : "")">@lastCommandStatus</span>
        }
        </div> @* /thread-chat-input-content *@
    </div>
    </div>
    }
    </div> @* /thread-chat-bottom *@
    </div> @* /thread-nav-body *@
    </div> @* /thread-nav-shell *@
}

</div>
