@inherits BlazorView<ThreadChatControl, ThreadChatView>
@using MeshWeaver.AI.Commands
@using MeshWeaver.Layout
@using MeshWeaver.Blazor.Components.Monaco
@using FluentAppearance = Microsoft.FluentUI.AspNetCore.Components.Appearance
@inject NavigationManager NavigationManager

<div class="thread-chat-container @(ViewModel.HideEmptyState ? "compact-mode" : "")" style="@Style">
@if (viewMode == ChatViewMode.ResumeThreads)
{
    <div class="thread-resume-view">
        <div class="resume-header">
            <FluentButton Appearance="FluentAppearance.Stealth" OnClick="SwitchToChatMode" Title="Back to chat">
                <FluentIcon Value="@(new Icons.Regular.Size16.ArrowLeft())" />
            </FluentButton>
            <span style="font-weight: 600;">Threads</span>
        </div>
        <div class="resume-threads-list">
            <MeshSearchView ViewModel="@GetResumeSearchControl()"
                            OnNodeSelected="@OnSelectThread"
                            SelectedPath="@threadPath"
                            Area="resume-threads" />
        </div>
    </div>
}
else
{
    <!-- Message history display (hidden in compact/dashboard mode) -->
    @if (!ViewModel.HideEmptyState)
    {
        <div class="thread-chat-messages" @ref="messagesContainer">
            @{
                var header = GetHeaderCell();
            }
            @if (header != null)
            {
                <LayoutAreaView @key="@($"hdr-{threadPath}")" ViewModel="@header" Stream="@Stream" Area="@($"hdr-{threadPath}")" />
            }
            @if (ThreadMessages.Count > 0)
            {
                @foreach (var msgId in ThreadMessages)
                {
                    var cell = GetMessageCell(msgId);
                    @if (cell != null)
                    {
                        <LayoutAreaView @key="@msgId" ViewModel="@cell" Stream="@Stream" Area="@($"msg-{msgId}")" />
                    }
                }
            }
            else if (isCreatingThread)
            {
                <div class="empty-thread-message">
                    <FluentProgressRing />
                    <p>Creating thread...</p>
                </div>
            }
            else if (string.IsNullOrEmpty(threadPath))
            {
                <div class="empty-thread-message">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Chat())" Color="Color.Neutral" />
                    <p>Start a conversation</p>
                    <p class="hint">Use @("@") references to include context from other nodes</p>
                </div>
            }
        </div>
    }

    <!-- Execution status bar — shows when thread is executing -->
    @if (ThreadViewModel?.IsExecuting == true)
    {
        <div class="thread-exec-bar">
            <div class="thread-exec-header">
                <span class="thread-exec-star">&#10041;</span>
                <span class="thread-exec-status">@(ThreadViewModel.ExecutionStatus ?? "Generating response...")</span>
                <button class="thread-exec-cancel" @onclick="CancelExecution">
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" style="opacity: 0.7;"><rect x="3" y="3" width="10" height="10" rx="1"/></svg>
                    Stop
                </button>
            </div>
            @if (!string.IsNullOrEmpty(ThreadViewModel.StreamingText))
            {
                <div class="thread-exec-preview">@TruncateText(ThreadViewModel.StreamingText, 300)</div>
            }
            @if (ThreadViewModel.StreamingToolCalls is { Count: > 0 })
            {
                <div class="thread-exec-tools">
                    @foreach (var call in ThreadViewModel.StreamingToolCalls)
                    {
                        <span class="thread-exec-tool @(call.Result != null ? "done" : "pending")">
                            @(call.Result != null ? "✓" : "●") @(call.DisplayName ?? call.Name)
                        </span>
                    }
                </div>
            }
        </div>
    }

    <!-- Footer: input — pinned at bottom, never scrolls. The
         `is-allocating` modifier overlays the "Allocating agent…" banner
         INSIDE the existing input-area box rather than replacing the
         whole subtree, so the dialog keeps its full height (breadcrumb +
         editor + send + attachments stay laid out underneath, just
         dimmed + non-interactive). Without this the chat shrinks to a
         small panel during thread allocation and snaps back when the
         thread is ready, which the user noticed. -->
    <div class="thread-chat-footer">
        <div class="thread-chat-input-area @(showSubmissionProgress ? "is-allocating" : "")">
        @if (showSubmissionProgress)
        {
            <div class="thread-allocating-panel">
                <FluentProgressRing Style="width: 28px; height: 28px;" />
                <div class="thread-allocating-text">
                    <div class="thread-allocating-title">Allocating agent…</div>
                    <div class="thread-allocating-subtitle">Creating conversation and redirecting</div>
                </div>
            </div>
        }
        @{ var inputDimmed = showSubmissionProgress; }
        <div class="thread-chat-input-content @(inputDimmed ? "dimmed" : "")" aria-hidden="@(inputDimmed.ToString().ToLowerInvariant())">

        @* Active agent + model selectors. Sourced from the workspace synced
           query (agents from namespace:Agent, models from namespace:Model
           via the same nodeType:Agent|LanguageModel union). Selecting an
           agent updates the model to that agent's preferred model
           (GetPreferredModelInfoForAgent); the user can override per
           thread by picking a different model. Slash commands /agent and
           /model still work (ChatCommandRegistry) and update the same
           selection state. *@
        <div class="thread-chat-selectors">
            <SimpleDropdown TOption="AgentDisplayInfo"
                            SelectedItem="@selectedAgentInfo"
                            SelectedItemChanged="@OnAgentChanged"
                            Items="@agentDisplayInfos"
                            GetDisplayText="@(a => a?.Name ?? "Agent…")"
                            Placeholder="Agent…"
                            Tooltip="@(selectedAgentInfo?.Path ?? "Pick an agent (or type /agent)")"
                            PanelWidth="420px"
                            Class="selector-agent">
                <ItemTemplate Context="agent">
                    <div class="dropdown-icon-name">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Bot())" />
                        <span class="simple-dropdown-item-name">@agent.Name</span>
                    </div>
                    @if (!string.IsNullOrEmpty(agent.Description))
                    {
                        <div class="simple-dropdown-item-description">@TruncateText(agent.Description, 80)</div>
                    }
                </ItemTemplate>
            </SimpleDropdown>

            <SimpleDropdown TOption="ModelInfo"
                            SelectedItem="@selectedModelInfo"
                            SelectedItemChanged="@OnModelChanged"
                            Items="@availableModels"
                            GetDisplayText="@(m => m?.Name ?? (availableModels.Count == 0 ? "(no models)" : "Model…"))"
                            GetGroupKey="@(m => m.Provider)"
                            Placeholder="Model…"
                            Tooltip="@(selectedModelInfo != null ? $"{selectedModelInfo.Provider}: {selectedModelInfo.Name}" : "Pick a model (or type /model)")"
                            ShowSearch="false"
                            PanelWidth="360px"
                            Class="selector-model">
                <ItemTemplate Context="model">
                    <div class="dropdown-icon-name">
                        @{
                            var brand = ModelBadge(model);
                        }
                        <span class="model-badge @brand.Class" title="@brand.Tooltip">@brand.Label</span>
                        <span class="simple-dropdown-item-name">@model.Name</span>
                    </div>
                </ItemTemplate>
            </SimpleDropdown>

            @if (!string.IsNullOrEmpty(lastCommandStatus))
            {
                <span class="thread-chat-status-msg @(lastCommandStatusIsError ? "error" : "")">@lastCommandStatus</span>
            }
        </div>

        @* Inline picker rendered when /agent or /model was invoked without
           an argument. AgentCommand and ModelCommand return Widget = AgentPicker
           or ModelPicker; selection routes back through OnAgentPickerSelected
           / OnModelPickerSelected which is equivalent to running
           /agent <name> / /model <name>. *@
        @if (pendingWidget == ChatWidget.AgentPicker)
        {
            <div class="thread-chat-widget">
                <div class="thread-chat-widget-header">
                    <span>Pick an agent</span>
                    <FluentButton Appearance="FluentAppearance.Stealth" OnClick="DismissWidget" Title="Close">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Dismiss())" />
                    </FluentButton>
                </div>
                <div class="thread-chat-widget-list">
                    @foreach (var agent in agentDisplayInfos)
                    {
                        var captured = agent;
                        <button class="thread-chat-widget-item @(captured.Name == selectedAgentInfo?.Name ? "selected" : "")"
                                @onclick="() => OnAgentPickerSelected(captured)" type="button">
                            <div class="thread-chat-widget-item-name">@captured.Name</div>
                            @if (!string.IsNullOrEmpty(captured.Path) && captured.Path != captured.Name)
                            {
                                <div class="thread-chat-widget-item-path">@captured.Path</div>
                            }
                            @if (!string.IsNullOrEmpty(captured.Description))
                            {
                                <div class="thread-chat-widget-item-desc">@TruncateText(captured.Description, 90)</div>
                            }
                        </button>
                    }
                    @if (agentDisplayInfos.Count == 0)
                    {
                        <div class="thread-chat-widget-empty">No agents available.</div>
                    }
                </div>
            </div>
        }
        else if (pendingWidget == ChatWidget.ModelPicker)
        {
            <div class="thread-chat-widget">
                <div class="thread-chat-widget-header">
                    <span>Pick a model</span>
                    <FluentButton Appearance="FluentAppearance.Stealth" OnClick="DismissWidget" Title="Close">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Dismiss())" />
                    </FluentButton>
                </div>
                <div class="thread-chat-widget-list">
                    @foreach (var grp in availableModels.GroupBy(m => m.Provider).OrderBy(g => g.First().Order))
                    {
                        <div class="thread-chat-widget-group">@grp.Key</div>
                        @foreach (var model in grp)
                        {
                            var captured = model;
                            <button class="thread-chat-widget-item @(captured.Name == selectedModelInfo?.Name ? "selected" : "")"
                                    @onclick="() => OnModelPickerSelected(captured)" type="button">
                                <div class="thread-chat-widget-item-name">@captured.Name</div>
                            </button>
                        }
                    }
                    @if (availableModels.Count == 0)
                    {
                        <div class="thread-chat-widget-empty">No models available.</div>
                    }
                </div>
            </div>
        }

        @* Monaco editor for markdown input with completion *@
        <div class="input-container" style="@(!submissionHandler.IsInputEnabled ? "display: none;" : "")">
            <MonacoEditorView @ref="monacoEditor"
                              Value="@MessageText"
                              ValueChanged="@OnMessageTextChanged"
                              OnSubmit="SendMessage"
                              OnCompletionAccepted="OnCompletionItemAccepted"
                              IsDisabled="@(!submissionHandler.IsInputEnabled)"
                              Placeholder="@placeholderText"
                              Height="80px"
                              MaxHeight="200px"
                              CompletionProvider="@GetCompletionConfig()"
                              CompletionCallback="@GetCompletions" />
        </div>
        <!-- Send button row (agent + model dropdowns removed; use /agent and /model commands) -->
        <div class="selector-bar">
            @if (!submissionHandler.IsInputEnabled)
            {
                <FluentButton Appearance="FluentAppearance.Accent" Disabled="true" Title="Sending...">
                    <FluentProgressRing Style="width: 20px; height: 20px;" />
                </FluentButton>
            }
            else
            {
                <FluentButton Appearance="FluentAppearance.Accent" OnClick="SendMessage"
                              Disabled="@(string.IsNullOrWhiteSpace(MessageText))" Title="Send">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Send())" Color="Color.Neutral" />
                </FluentButton>
            }
        </div>

        @* Attachment chips — pinned to the bottom of the input dialog,
           below the send button. Removable; click navigates to the node. *@
        @if (attachments.Count > 0)
        {
            <div class="thread-chat-attachments">
                <ReferenceChipCollection
                    Attachments="@attachments"
                    OnAttachmentRemoved="@OnAttachmentRemoved"
                    OnChipClick="@OnChipClicked" />
            </div>
        }
        </div> @* /thread-chat-input-content *@
    </div>
    </div>
}

</div>
