@inherits BlazorView<ThreadMessageItemControl, ThreadMessageItemView>
@using MeshWeaver.Layout
@using MeshWeaver.Markdown

@* Per-item view rendered inside the chat's ItemTemplateControl. ONE cache
   subscription per visible message; the role-based dispatch happens here in
   Razor rather than through two separate top-level controls — see
   Doc/GUI/ItemTemplateMeshNodeStreamBinding ("One template, role dispatch"). *@

@if (isPending && string.IsNullOrEmpty(messageText))
{
    @* The satellite cell hasn't materialised yet — render the typed text
       immediately as a placeholder so the user sees their submission without
       waiting for the round-trip. First non-null cache emission swaps this
       for the live ThreadMessage.Text seamlessly. *@
    <div class="chat-item chat-item-user chat-item-pending">
        <div class="chat-item-author">You</div>
        <div class="chat-item-body">@pendingText</div>
    </div>
}
else if (IsUser)
{
    <div class="chat-item chat-item-user">
        <div class="chat-item-author">@AuthorName</div>
        <div class="chat-item-body">@messageText</div>
    </div>
}
else
{
    <div class="chat-item chat-item-assistant">
        <div class="chat-item-author">
            @AuthorName
            @if (!string.IsNullOrEmpty(modelName))
            {
                <span class="chat-item-model">@modelName</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(messageText))
        {
            <div class="chat-item-body">
                <MarkdownView ViewModel="@MarkdownVm" Stream="@Stream" Area="@($"{Area}/md")" />
            </div>
        }
        @if (toolCalls is { Count: > 0 })
        {
            <div class="chat-item-toolcalls">
                @foreach (var call in toolCalls)
                {
                    @if (!string.IsNullOrEmpty(call.DelegationPath))
                    {
                        @* Delegation tool calls render as a live card. The card view
                           opens its own two cache subscriptions (message + sub-thread)
                           and binds title + body + status from those streams. *@
                        <DelegationToolCallCardView ViewModel="@CardFor(call)"
                                                    Stream="@Stream"
                                                    Area="@($"{Area}/del-{call.DelegationPath}")" />
                    }
                    else
                    {
                        <span class="chat-item-toolcall @(call.Status == ToolCallStatus.Streaming ? "pending" : "done")">
                            @(call.Status == ToolCallStatus.Streaming ? "●" : "✓") @(call.DisplayName ?? call.Name)
                        </span>
                    }
                }
            </div>
        }
    </div>
}
