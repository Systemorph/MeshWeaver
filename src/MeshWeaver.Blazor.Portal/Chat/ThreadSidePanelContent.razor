@namespace MeshWeaver.Blazor.Portal.Chat

@using MeshWeaver.Layout
@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Services

<ChatSidePanel OnCloseRequested="@OnCloseRequested" Title="@SidePanelTitle">
    <ToolbarContent>
        <FluentButton BackgroundColor="transparent" OnClick="OnNewChat" Title="New Chat">
            <FluentIcon Value="@(new Icons.Regular.Size20.Add())" Color="Color.Neutral" />
        </FluentButton>
        @if (!string.IsNullOrEmpty(selectedThreadPath))
        {
            <FluentButton BackgroundColor="transparent" OnClick="OpenThreadFullScreen" Title="Open Full Screen">
                <FluentIcon Value="@(new Icons.Regular.Size20.ArrowMaximize())" Color="Color.Neutral" />
            </FluentButton>
        }
        <FluentButton BackgroundColor="transparent" Title="Chat Position" @onclick="@(() => positionMenuVisible = !positionMenuVisible)" Id="position-menu-anchor">
            <FluentIcon Value="@(new Icons.Regular.Size20.WindowLocationTarget())" Color="Color.Neutral" />
        </FluentButton>
        <FluentMenu @bind-Open="positionMenuVisible" Anchor="position-menu-anchor">
            <FluentMenuItem OnClick="@(() => ChangeChatPosition(SidePanelPosition.Right))">
                <FluentIcon Value="@(new Icons.Regular.Size16.PanelRight())" />
                Right
                @if (SidePanelState.Position == SidePanelPosition.Right) { <FluentIcon Value="@(new Icons.Regular.Size16.Checkmark())" Color="Color.Success" Style="margin-left: auto;" /> }
            </FluentMenuItem>
            <FluentMenuItem OnClick="@(() => ChangeChatPosition(SidePanelPosition.Bottom))">
                <FluentIcon Value="@(new Icons.Regular.Size16.ArrowDown())" />
                Bottom
                @if (SidePanelState.Position == SidePanelPosition.Bottom) { <FluentIcon Value="@(new Icons.Regular.Size16.Checkmark())" Color="Color.Success" Style="margin-left: auto;" /> }
            </FluentMenuItem>
        </FluentMenu>
    </ToolbarContent>
    <ChildContent>
        @if (!string.IsNullOrEmpty(selectedThreadPath))
        {
            @* Render the thread's layout area — same as main panel. LayoutAreaView manages its own stream.
               Wrapped in ChatErrorBoundary (like the new-chat fallback below) so a render/lifecycle throw
               in the area's control tree surfaces as an inline error instead of tearing down the whole
               circuit — the "side panel disappeared, must refresh" symptom. LayoutAreaView already contains
               its own STREAM onErrors (keep last-good display); this covers the synchronous render path it can't. *@
            <ChatErrorBoundary @key="@($"thread-eb-{selectedThreadPath}")">
                <LayoutAreaView @key="@selectedThreadPath"
                                ViewModel="@GetThreadLayoutArea()"
                                Area="@($"sidepanel-{selectedThreadPath}")" />
            </ChatErrorBoundary>
        }
        else if (GetThreadComposerLayoutArea() is { } chatInputArea)
        {
            @* New chat (out of thread) — the composer is the per-user ThreadComposer node's
               default ("") layout area, databinding message text + harness/agent/model to
               {user}/_Thread/ThreadComposer (see ThreadComposerView). @key includes the primary path so
               it rebuilds on context change. *@
            <div style="flex: 1; min-height: 0; display: flex; flex-direction: column;">
                <ChatErrorBoundary @key="@($"chatinput-eb-{lastPrimaryPath ?? string.Empty}")">
                    <LayoutAreaView @key="@($"chatinput-{lastPrimaryPath ?? string.Empty}")"
                                    ViewModel="@chatInputArea"
                                    Area="@($"chatinput-{lastPrimaryPath ?? string.Empty}")" />
                </ChatErrorBoundary>
            </div>
        }
        else
        {
            @* Fallback while the user identity is still resolving (no home path yet). *@
            <ChatErrorBoundary @key="@($"newchat-{lastPrimaryPath ?? string.Empty}")"><ThreadChatView @key="@($"newchat-{lastPrimaryPath ?? string.Empty}")"
                            ViewModel="@GetNewChatControl()" /></ChatErrorBoundary>
        }
    </ChildContent>
</ChatSidePanel>
