@namespace MeshWeaver.Blazor.Portal.Chat

@using MeshWeaver.Layout
@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Services

<ChatSidePanel OnCloseRequested="@OnCloseRequested">
    <ToolbarContent>
        <FluentButton BackgroundColor="transparent" OnClick="OnNewChat" Title="New Chat">
            <FluentIcon Value="@(new Icons.Regular.Size20.Add())" Color="Color.Neutral" />
        </FluentButton>
        <FluentButton BackgroundColor="transparent" OnClick="ToggleThreadList" Title="Chat History">
            <FluentIcon Value="@(new Icons.Regular.Size20.History())" Color="Color.Neutral" />
        </FluentButton>
        @if (!string.IsNullOrEmpty(selectedThreadPath))
        {
            <FluentButton BackgroundColor="transparent" OnClick="OpenThreadFullScreen" Title="Open Full Screen">
                <FluentIcon Value="@(new Icons.Regular.Size20.ArrowMaximize())" Color="Color.Neutral" />
            </FluentButton>
        }
        <FluentButton BackgroundColor="transparent" Title="Chat Position" @onclick="@(() => positionMenuVisible = !positionMenuVisible)" Id="position-menu-anchor">
            <FluentIcon Value="@(new Icons.Regular.Size20.WindowLocationTarget())" Color="Color.Neutral" />
        </FluentButton>
        <FluentMenu @bind-Open="positionMenuVisible" Anchor="position-menu-anchor">
            <FluentMenuItem OnClick="@(() => ChangeChatPosition(SidePanelPosition.Right))">
                <FluentIcon Value="@(new Icons.Regular.Size16.PanelRight())" />
                Right
                @if (SidePanelState.Position == SidePanelPosition.Right) { <FluentIcon Value="@(new Icons.Regular.Size16.Checkmark())" Color="Color.Success" Style="margin-left: auto;" /> }
            </FluentMenuItem>
            <FluentMenuItem OnClick="@(() => ChangeChatPosition(SidePanelPosition.Bottom))">
                <FluentIcon Value="@(new Icons.Regular.Size16.ArrowDown())" />
                Bottom
                @if (SidePanelState.Position == SidePanelPosition.Bottom) { <FluentIcon Value="@(new Icons.Regular.Size16.Checkmark())" Color="Color.Success" Style="margin-left: auto;" /> }
            </FluentMenuItem>
        </FluentMenu>
    </ToolbarContent>
    <ChildContent>
        @if (showThreadList)
        {
            <div style="display: flex; flex-direction: column; height: 100%; overflow: hidden;">
                <div style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; border-bottom: 1px solid var(--neutral-stroke-rest);">
                    <FluentButton Appearance="Microsoft.FluentUI.AspNetCore.Components.Appearance.Stealth" OnClick="ToggleThreadList" Title="Back">
                        <FluentIcon Value="@(new Icons.Regular.Size16.ArrowLeft())" />
                    </FluentButton>
                    <span style="font-weight: 600;">Threads</span>
                </div>
                <div style="flex: 1; overflow-y: auto; padding: 4px;">
                    @if (isLoadingThreads)
                    {
                        <div style="display: flex; justify-content: center; padding: 24px;">
                            <FluentProgressRing Style="width: 24px; height: 24px;" />
                        </div>
                    }
                    else if (threadList.Count == 0)
                    {
                        <div style="text-align: center; padding: 24px; color: var(--neutral-foreground-hint);">
                            No threads found
                        </div>
                    }
                    else
                    {
                        @foreach (var thread in threadList)
                        {
                            <div class="@($"thread-list-item {(thread.Path == selectedThreadPath ? "thread-list-item-active" : "")}")"
                                 @onclick="() => SelectThread(thread)">
                                <div class="thread-list-name">@(thread.Name ?? thread.Id)</div>
                                @if (thread.LastModified != default)
                                {
                                    <div class="thread-list-date">@thread.LastModified.ToString("g")</div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(selectedThreadPath))
        {
            @* Render the thread's layout area — same as main panel. LayoutAreaView manages its own stream. *@
            <LayoutAreaView @key="@selectedThreadPath"
                            ViewModel="@GetThreadLayoutArea()"
                            Area="@($"sidepanel-{selectedThreadPath}")" />
        }
        else
        {
            @* New chat — render ThreadChatControl directly (no thread hub yet) *@
            <ThreadChatView ViewModel="@GetNewChatControl()" />
        }
    </ChildContent>
</ChatSidePanel>

<style>
    .thread-list-item {
        padding: 10px 12px;
        border-radius: 6px;
        cursor: pointer;
        transition: background-color 0.15s;
    }
    .thread-list-item:hover {
        background-color: var(--neutral-fill-secondary-hover);
    }
    .thread-list-item-active {
        background-color: var(--neutral-fill-secondary-rest);
        border-left: 3px solid var(--accent-fill-rest);
    }
    .thread-list-name {
        font-weight: 500;
        font-size: 0.9rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .thread-list-date {
        font-size: 0.75rem;
        color: var(--neutral-foreground-hint);
        margin-top: 2px;
    }
</style>
