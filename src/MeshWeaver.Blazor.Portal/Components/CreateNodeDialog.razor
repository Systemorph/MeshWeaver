@using MeshWeaver.Blazor.Chat
@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Services
@using MeshWeaver.Messaging
@using Microsoft.Extensions.DependencyInjection
@using Appearance = Microsoft.FluentUI.AspNetCore.Components.Appearance
@implements IDialogContentComponent<CreateNodeDialogData>

<div class="create-node-dialog">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Style="width: 100%;">
        @* Namespace field with autocomplete dropdown *@
        <div class="field-group">
            <label class="field-label">Namespace *</label>
            <MeshNodeAutocomplete SelectedItem="@selectedNamespace"
                                  SelectedItemChanged="@OnNamespaceSelectedAsync"
                                  FilterByCreatableType="@selectedType?.NodeTypePath"
                                  Options="@namespaceAutocompleteOptions" />
            @if (!string.IsNullOrEmpty(namespaceError))
            {
                <span class="field-error">@namespaceError</span>
            }
        </div>

        @* Type dropdown *@
        <div class="field-group">
            <label class="field-label">Type *</label>
            @if (isLoadingTypes)
            {
                <FluentProgressRing Style="width: 20px; height: 20px;" />
            }
            else
            {
                <FluentSelect TOption="CreatableTypeInfo"
                              Items="@creatableTypes"
                              @bind-SelectedOption="selectedType"
                              OptionText="@(t => t?.NodeTypePath ?? "")"
                              Placeholder="Select a type..."
                              Style="width: 100%;">
                    <OptionTemplate>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            @if (!string.IsNullOrEmpty(context?.Icon))
                            {
                                @if (IsEmoji(context.Icon))
                                {
                                    <span style="font-size: 1.2em;">@context.Icon</span>
                                }
                                else
                                {
                                    <img src="@context.Icon" alt="" style="width: 20px; height: 20px;" />
                                }
                            }
                            else
                            {
                                <span style="font-size: 1.2em;">📄</span>
                            }
                            <span>@(context?.NodeTypePath ?? "")</span>
                        </div>
                    </OptionTemplate>
                </FluentSelect>
            }
            @if (!string.IsNullOrEmpty(typeError))
            {
                <span class="field-error">@typeError</span>
            }
        </div>

        @* Name field - autocomplete disabled *@
        <div class="field-group">
            <label class="field-label">Name *</label>
            <FluentTextField @bind-Value="nodeName"
                             @bind-Value:after="OnNameChanged"
                             Placeholder="Enter a name..."
                             Autocomplete="off"
                             Style="width: 100%;" />
            @if (!string.IsNullOrEmpty(nameError))
            {
                <span class="field-error">@nameError</span>
            }
        </div>

        @* Id field - autocomplete disabled *@
        <div class="field-group">
            <label class="field-label">Id</label>
            <FluentTextField @bind-Value="nodeId"
                             Placeholder="Auto-generated from name..."
                             Autocomplete="off"
                             Style="width: 100%;" />
            <span class="field-hint">This will be used as the node's identifier in the path</span>
        </div>

        @* Progress message *@
        @if (isCreating)
        {
            <FluentMessageBar Intent="MessageIntent.Info" Style="width: 100%;">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                    <FluentProgressRing Style="width: 20px; height: 20px;" />
                    <span>Creating node...</span>
                </FluentStack>
            </FluentMessageBar>
        }

        @* Error message *@
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <FluentMessageBar Intent="MessageIntent.Error" Style="width: 100%;">
                @errorMessage
            </FluentMessageBar>
        }
    </FluentStack>
</div>

<FluentDialogFooter>
    <FluentButton Appearance="Appearance.Accent"
                  Disabled="@isCreating"
                  OnClick="@OnCreateClickedAsync">
        @if (isCreating)
        {
            <FluentProgressRing Style="width: 16px; height: 16px; margin-right: 8px;" />
            <span>Creating...</span>
        }
        else
        {
            <span>Create</span>
        }
    </FluentButton>
    <FluentButton Appearance="Appearance.Neutral"
                  Disabled="@isCreating"
                  OnClick="@CancelAsync">
        Cancel
    </FluentButton>
</FluentDialogFooter>

@code {
    [Parameter]
    public CreateNodeDialogData Content { get; set; } = default!;

    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

    // Injected services
    [Inject] private IMessageHub Hub { get; set; } = null!;
    [Inject] private INavigationService NavigationService { get; set; } = null!;

    // Form state
    private QuerySuggestion? selectedNamespace;
    private List<CreatableTypeInfo> creatableTypes = new();
    private CreatableTypeInfo? selectedType;
    private string nodeName = "";
    private string nodeId = "";
    private bool isLoadingTypes;
    private bool isCreating;
    private bool isIdManuallyEdited;

    // Autocomplete options
    private readonly MeshNodeAutocompleteOptions namespaceAutocompleteOptions = new()
    {
        Placeholder = "Select namespace...",
        SearchPlaceholder = "Type to search...",
        PanelWidth = "100%",
        Limit = 15
    };

    // Validation errors
    private string? namespaceError;
    private string? typeError;
    private string? nameError;
    private string? errorMessage;

    private string SelectedNamespacePath => selectedNamespace?.Path ?? Content?.InitialNamespace ?? "";

    protected override async Task OnInitializedAsync()
    {
        // Set initial namespace from current context if available
        if (!string.IsNullOrEmpty(Content?.InitialNamespace))
        {
            selectedNamespace = new QuerySuggestion(Content.InitialNamespace, GetLastSegment(Content.InitialNamespace), null, 1.0);
            await LoadCreatableTypesAsync(Content.InitialNamespace);
        }

        // Pre-select type if provided
        if (Content?.InitialType != null)
        {
            selectedType = Content.InitialType;
            // If type is in the loaded list, ensure it's selected; otherwise add it
            if (!creatableTypes.Contains(Content.InitialType))
            {
                creatableTypes.Insert(0, Content.InitialType);
            }
        }
    }

    private async Task OnNamespaceSelectedAsync(QuerySuggestion? selected)
    {
        selectedNamespace = selected;
        if (selected != null)
        {
            await LoadCreatableTypesAsync(selected.Path);
        }
    }

    private async Task LoadCreatableTypesAsync(string namespacePath)
    {
        isLoadingTypes = true;
        StateHasChanged();

        try
        {
            var nodeTypeService = Hub.ServiceProvider.GetService<INodeTypeService>();
            if (nodeTypeService != null)
            {
                creatableTypes = await nodeTypeService
                    .GetCreatableTypesAsync(namespacePath)
                    .ToListAsync();

                // Keep selected type if it's still valid, otherwise select first
                if (selectedType == null || !creatableTypes.Any(t => t.NodeTypePath == selectedType.NodeTypePath))
                {
                    selectedType = creatableTypes.FirstOrDefault();
                }
            }
        }
        catch
        {
            creatableTypes = new();
        }
        finally
        {
            isLoadingTypes = false;
            StateHasChanged();
        }
    }

    private void OnNameChanged()
    {
        // Only auto-generate Id if user hasn't manually edited it
        if (!isIdManuallyEdited)
        {
            nodeId = GenerateIdFromName(nodeName);
        }
    }

    private async Task OnCreateClickedAsync()
    {
        // Clear previous errors
        namespaceError = null;
        typeError = null;
        nameError = null;
        errorMessage = null;

        // Validate
        if (string.IsNullOrWhiteSpace(SelectedNamespacePath))
        {
            namespaceError = "Namespace is required";
            return;
        }

        if (selectedType == null)
        {
            typeError = "Type is required";
            return;
        }

        if (string.IsNullOrWhiteSpace(nodeName))
        {
            nameError = "Name is required";
            return;
        }

        // Generate Id if empty
        if (string.IsNullOrWhiteSpace(nodeId))
        {
            nodeId = GenerateIdFromName(nodeName);
        }

        isCreating = true;
        StateHasChanged();

        try
        {
            // Create node path using user-provided Id
            var finalId = nodeId.Trim();
            var subPartition = selectedType.SubNamespace ?? GetLastSegment(selectedType.NodeTypePath);
            var nodeNamespace = $"{SelectedNamespacePath}/{subPartition}";
            var nodePath = $"{nodeNamespace}/{finalId}";

            // Send CreateNodeRequest to create transient node
            var meshCatalog = Hub.ServiceProvider.GetRequiredService<IMeshCatalog>();

            // Check if a node already exists at this path
            var existingNode = await meshCatalog.GetNodeAsync(new Address(nodePath));
            if (existingNode != null && existingNode.State != MeshNodeState.Transient)
            {
                errorMessage = $"A node already exists at path: {nodePath}";
                return;
            }

            // Create the transient node
            var transientNode = MeshNode.FromPath(nodePath) with
            {
                Name = nodeName.Trim(),
                NodeType = selectedType.NodeTypePath,
                State = MeshNodeState.Transient
            };

            await meshCatalog.CreateTransientNodeAsync(transientNode);

            // Store result data for navigation
            Content.ResultPath = nodePath;
            Content.ResultSuccess = true;

            // Close dialog
            await Dialog.CloseAsync(Content);

            // Navigate to the Create area for the transient node
            NavigationService.NavigateTo($"/{nodePath}/Create");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message.Contains("Access denied") || ex.Message.Contains("Unauthorized")
                ? "You do not have permission to create nodes in this namespace."
                : $"Failed to create node: {ex.Message}";
        }
        finally
        {
            isCreating = false;
            StateHasChanged();
        }
    }

    private async Task CancelAsync()
    {
        await Dialog.CancelAsync();
    }

    private static string GenerateIdFromName(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "";

        // Split by spaces and other separators, convert to PascalCase
        var words = System.Text.RegularExpressions.Regex.Split(name, @"[\s\-_]+")
            .Where(w => !string.IsNullOrEmpty(w))
            .Select(w => char.ToUpperInvariant(w[0]) + w.Substring(1).ToLowerInvariant());

        var pascalCase = string.Join("", words);

        // Remove any remaining non-alphanumeric characters
        pascalCase = System.Text.RegularExpressions.Regex.Replace(pascalCase, @"[^a-zA-Z0-9]", "");

        return pascalCase;
    }

    private static string GetLastSegment(string path)
    {
        var lastSlash = path.LastIndexOf('/');
        return lastSlash >= 0 ? path[(lastSlash + 1)..] : path;
    }

    private static bool IsEmoji(string? value)
    {
        if (string.IsNullOrEmpty(value))
            return false;

        // Emojis are typically 1-4 characters (including surrogate pairs and modifiers)
        // SVG paths start with / or http or contain .svg
        if (value.Length > 8)
            return false;

        if (value.StartsWith("/") || value.StartsWith("http") || value.Contains(".svg"))
            return false;

        return true;
    }
}
