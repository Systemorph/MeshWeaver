@using MeshWeaver.Blazor.Chat
@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Services
@using MeshWeaver.Messaging
@using Microsoft.Extensions.DependencyInjection
@using Appearance = Microsoft.FluentUI.AspNetCore.Components.Appearance
@implements IDialogContentComponent<ImportNodeDialogData>

<div class="import-node-dialog">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Style="width: 100%;">
        @* Namespace field with autocomplete dropdown *@
        <div class="field-group">
            <label class="field-label">Namespace *</label>
            <MeshNodeAutocomplete SelectedItem="@selectedNamespace"
                                  SelectedItemChanged="@OnNamespaceSelected"
                                  Options="@namespaceAutocompleteOptions" />
            @if (!string.IsNullOrEmpty(namespaceError))
            {
                <span class="field-error">@namespaceError</span>
            }
        </div>

        @* File picker *@
        <div class="field-group">
            <label class="field-label">Files *</label>
            <div class="file-picker-row">
                <FluentButton Id="import-file-upload"
                              Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.ArrowUpload())"
                              Disabled="@isImporting">
                    Select Files
                </FluentButton>
                @if (uploadedFileNames.Count > 0)
                {
                    <span class="file-info">@uploadedFileNames.Count file(s) selected</span>
                }
            </div>
            <FluentInputFile @ref="@inputFile"
                             AnchorId="import-file-upload"
                             DragDropZoneVisible="false"
                             Mode="InputFileMode.Stream"
                             Multiple="true"
                             Accept=".md,.json,.cs"
                             MaximumFileSize="@(100 * 1024 * 1024)"
                             OnFileUploaded="@OnFileUploadedAsync"
                             OnCompleted="@OnUploadCompletedAsync" />
            @if (uploadedFileNames.Count > 0)
            {
                <div class="file-list">
                    @foreach (var name in uploadedFileNames)
                    {
                        <span class="file-chip">@name</span>
                    }
                </div>
            }
            <span class="field-hint">Select .md, .json, or .cs node files. Sibling folders with matching names will be included automatically.</span>
            @if (!string.IsNullOrEmpty(fileError))
            {
                <span class="field-error">@fileError</span>
            }
        </div>

        @* Force re-import checkbox *@
        <div class="field-group">
            <FluentCheckbox @bind-Value="@forceReimport" Label="Force re-import (overwrite existing data)" />
        </div>

        @* Progress *@
        @if (isImporting)
        {
            <div style="width: 100%;">
                <FluentProgress Min="0" Max="100" Value="@progressPercent" Visible="true" />
                <p style="margin-top: 8px; color: var(--neutral-foreground-hint); font-size: 0.85rem;">@progressMessage</p>
            </div>
        }

        @* Result *@
        @if (importResult != null)
        {
            @if (importResult.Success)
            {
                <FluentMessageBar Intent="MessageIntent.Success" Style="width: 100%;">
                    Imported @importResult.NodesImported nodes, @importResult.PartitionsImported partitions
                    (@importResult.Elapsed.TotalSeconds.ToString("F1")s).
                    Skipped @importResult.NodesSkipped nodes, @importResult.PartitionsSkipped partitions.
                </FluentMessageBar>
            }
            else
            {
                <FluentMessageBar Intent="MessageIntent.Error" Style="width: 100%;">
                    @importResult.Error
                </FluentMessageBar>
            }
        }

        @* Error message *@
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <FluentMessageBar Intent="MessageIntent.Error" Style="width: 100%;">
                @errorMessage
            </FluentMessageBar>
        }
    </FluentStack>
</div>

<FluentDialogFooter>
    @if (importResult is { Success: true })
    {
        <FluentButton Appearance="Appearance.Accent" OnClick="@ResetForAnotherImport">
            Import Another
        </FluentButton>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@CloseAsync">
            Done
        </FluentButton>
    }
    else
    {
        <FluentButton Appearance="Appearance.Accent"
                      Disabled="@(isImporting || isUploading)"
                      OnClick="@OnImportClickedAsync">
            @if (isImporting)
            {
                <FluentProgressRing Style="width: 16px; height: 16px; margin-right: 8px;" />
                <span>Importing...</span>
            }
            else
            {
                <span>Import</span>
            }
        </FluentButton>
        <FluentButton Appearance="Appearance.Neutral"
                      Disabled="@isImporting"
                      OnClick="@CancelAsync">
            Cancel
        </FluentButton>
    }
</FluentDialogFooter>

@code {
    [Parameter]
    public ImportNodeDialogData Content { get; set; } = default!;

    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

    [Inject] private IMessageHub Hub { get; set; } = null!;

    // Upload
    private FluentInputFile inputFile = default!;
    private string? tempDir;
    private readonly List<string> uploadedFileNames = new();
    private bool isUploading;

    // Form state
    private QuerySuggestion? selectedNamespace;
    private bool forceReimport;
    private bool isImporting;
    private int progressPercent;
    private string progressMessage = "";
    private ImportNodesResponse? importResult;

    // Autocomplete options
    private readonly MeshNodeAutocompleteOptions namespaceAutocompleteOptions = new()
    {
        Placeholder = "Select namespace...",
        SearchPlaceholder = "Type to search...",
        PanelWidth = "100%",
        Limit = 15
    };

    // Validation errors
    private string? namespaceError;
    private string? fileError;
    private string? errorMessage;

    private string SelectedNamespacePath => selectedNamespace?.Path ?? Content?.InitialNamespace ?? "";

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Content?.InitialNamespace))
        {
            selectedNamespace = new QuerySuggestion(Content.InitialNamespace, GetLastSegment(Content.InitialNamespace), null, 1.0);
        }

        forceReimport = Content?.Force ?? false;
    }

    private void OnNamespaceSelected(QuerySuggestion? selected)
    {
        selectedNamespace = selected;
        namespaceError = null;
    }

    private void EnsureTempDir()
    {
        tempDir ??= Path.Combine(Path.GetTempPath(), "meshweaver-import-" + Guid.NewGuid().ToString("N")[..8]);
        Directory.CreateDirectory(tempDir);
    }

    private async Task OnFileUploadedAsync(FluentInputFileEventArgs file)
    {
        if (file.Stream == null)
            return;

        isUploading = true;
        fileError = null;
        EnsureTempDir();

        var fileName = file.Name;
        uploadedFileNames.Add(fileName);

        // Save file to temp directory (flat, at root)
        var targetPath = Path.Combine(tempDir!, fileName);
        var targetDir = Path.GetDirectoryName(targetPath);
        if (targetDir != null)
            Directory.CreateDirectory(targetDir);

        await using var fs = File.Create(targetPath);
        await file.Stream.CopyToAsync(fs);

        StateHasChanged();
    }

    private Task OnUploadCompletedAsync(IEnumerable<FluentInputFileEventArgs> files)
    {
        isUploading = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OnImportClickedAsync()
    {
        // Clear previous errors
        namespaceError = null;
        fileError = null;
        errorMessage = null;
        importResult = null;

        // Validate
        if (string.IsNullOrWhiteSpace(SelectedNamespacePath))
        {
            namespaceError = "Namespace is required";
            return;
        }

        if (uploadedFileNames.Count == 0)
        {
            fileError = "Please select files to import";
            return;
        }

        isImporting = true;
        progressPercent = 10;
        progressMessage = "Preparing import...";
        StateHasChanged();

        string? importDir = null;
        try
        {
            // Create a structured import directory:
            // importDir/{namespace}/NodeFile.md  (so FileSystemStorageAdapter derives correct namespace)
            importDir = Path.Combine(Path.GetTempPath(), "meshweaver-import-" + Guid.NewGuid().ToString("N")[..8]);
            var namespacePath = SelectedNamespacePath.Replace('/', Path.DirectorySeparatorChar);
            var namespaceDir = Path.Combine(importDir, namespacePath);
            Directory.CreateDirectory(namespaceDir);

            // Copy uploaded files into the namespace subdirectory
            foreach (var fileName in uploadedFileNames)
            {
                var src = Path.Combine(tempDir!, fileName);
                var dest = Path.Combine(namespaceDir, fileName);
                File.Copy(src, dest);
            }

            progressPercent = 30;
            progressMessage = "Importing nodes...";
            StateHasChanged();

            // Call import service with rootPath=null so it scans from importDir root
            var importService = Hub.ServiceProvider.GetService<IMeshImportService>();
            if (importService == null)
            {
                errorMessage = "Import service is not available.";
                isImporting = false;
                return;
            }

            // Always use force=true — the idempotency check in ImportHelper checks
            // the entire target storage, not just the target namespace, making it
            // useless for incremental imports via the UI.
            importResult = await importService.ImportNodesAsync(
                importDir,
                targetRootPath: null,
                force: true,
                onProgress: (nodes, partitions, currentPath) =>
                {
                    progressPercent = Math.Min(30 + (nodes + partitions) * 5, 99);
                    progressMessage = $"Importing... {nodes} nodes, {partitions} partitions ({currentPath})";
                    InvokeAsync(StateHasChanged);
                },
                ct: CancellationToken.None);

            progressPercent = 100;
            progressMessage = "Done!";

            if (importResult.Success)
            {
                Content.ResultSuccess = true;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Import failed: {ex.Message}";
        }
        finally
        {
            isImporting = false;

            // Clean up
            if (importDir != null)
            {
                try { Directory.Delete(importDir, true); } catch { }
            }
            if (tempDir != null)
            {
                try { Directory.Delete(tempDir, true); } catch { }
                tempDir = null;
            }

            StateHasChanged();
        }
    }

    private void ResetForAnotherImport()
    {
        importResult = null;
        errorMessage = null;
        uploadedFileNames.Clear();
        progressPercent = 0;
        progressMessage = "";
        CleanupTempDir();
        StateHasChanged();
    }

    private async Task CloseAsync()
    {
        CleanupTempDir();
        await Dialog.CloseAsync(Content);
    }

    private async Task CancelAsync()
    {
        CleanupTempDir();
        await Dialog.CancelAsync();
    }

    private void CleanupTempDir()
    {
        if (tempDir != null)
        {
            try { Directory.Delete(tempDir, true); } catch { }
            tempDir = null;
        }
    }

    private static string GetLastSegment(string path)
    {
        var lastSlash = path.LastIndexOf('/');
        return lastSlash >= 0 ? path[(lastSlash + 1)..] : path;
    }
}
