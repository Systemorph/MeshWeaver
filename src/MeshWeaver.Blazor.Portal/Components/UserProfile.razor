@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.FluentUI.AspNetCore.Components

<AuthorizeView>
    <Authorized>
        <div class="profile-menu-container">
            <FluentProfileMenu Initials="@initials"
                               EMail="@username"
                               FullName="@name"
                               ButtonSize="@ButtonSize"
                               FooterLink="">
                <HeaderTemplate>
                    <FluentStack VerticalAlignment="VerticalAlignment.Center">
                        <FluentLabel>Logged in as:</FluentLabel>
                        <FluentSpacer />
                        <FluentButton Appearance="Appearance.Stealth" OnClick="Logout">Sign out</FluentButton>
                    </FluentStack>
                </HeaderTemplate>
                <ChildContent>
                    <FluentStack class="inner-persona-container" @onclick="NavigateToUserNode" Style="cursor: pointer;">
                        <FluentPersona Initials="@initials" ImageSize="@ImageSize" Class="inner-persona">
                            <div class="full-name">@name</div>
                            <div class="user-id">@username</div>
                        </FluentPersona>
                    </FluentStack>
                    @if (showFrontendToggle)
                    {
                        <FluentStack VerticalAlignment="VerticalAlignment.Center" Style="margin-top: 8px;">
                            <FluentButton Appearance="Appearance.Stealth" OnClick="SwitchToNewFrontend">Try the new frontend</FluentButton>
                        </FluentStack>
                    }
                    @* Platform info — What's New feed + About (exact build). *@
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="2" Style="margin-top: 8px;">
                        <FluentButton Appearance="Appearance.Stealth" OnClick="NavigateToWhatsNew"
                                      IconStart="@(new Icons.Regular.Size20.Sparkle())">What's New</FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="NavigateToAbout"
                                      IconStart="@(new Icons.Regular.Size20.Info())">About</FluentButton>
                    </FluentStack>
                </ChildContent>
            </FluentProfileMenu>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="login-button-container">
            <FluentButton Appearance="Appearance.Stealth" OnClick="Login">Login</FluentButton>
        </div>
    </NotAuthorized>
</AuthorizeView>
