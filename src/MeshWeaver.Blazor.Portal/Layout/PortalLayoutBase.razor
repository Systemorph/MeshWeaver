@using Orientation = Microsoft.FluentUI.AspNetCore.Components.Orientation
@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase
@inject IDialogService DialogService

<div class="layout @(IsPresentMode ? "present-mode" : "") @(IsSidePanelVisible ? $"panel-visible panel-position-{SidePanelPositionValue.ToString().ToLower()}" : "")"
    style="@(IsNavMenuOpen ? "overflow: hidden;" : string.Empty)">
    @* Present mode ( /Present ) is chrome-free: hide the logo tile, header top bar, side nav
       and the message bar so the slide stage is truly full-screen. *@
    @if (!IsPresentMode)
    {
    <div class="meshweaver-icon">
        <FluentAnchor Appearance="Appearance.Stealth" Href="/" Class="logo" title="MeshWeaver" aria-label="MeshWeaver">
            <MeshWeaverLogo></MeshWeaverLogo>
        </FluentAnchor>
    </div>

    @if (ViewportInformation.IsDesktop)
    {
        <FluentHeader>
            <FluentAnchor Appearance="Appearance.Stealth" Href="/" Class="logo">
                MESHWEAVER
            </FluentAnchor>
            <FluentSpacer />
            <div class="links">
                <div class="search-container">
                    <SearchBar />
                </div>
                @* Authenticated-only menus — Node/Mesh/Settings/Chat require a hub
                   workspace, which isn't available to anonymous users. Wrapping in
                   AuthorizeView prevents both render-time and click-time errors. *@
                <AuthorizeView>
                    <Authorized>
                        @* Node menu (Cube icon) — per-node operations *@
                        <FluentMenu Anchor="node-menu-anchor" Open="@isNodeMenuOpen" OpenChanged="@OnNodeMenuOpenChanged">
                            @if (!string.IsNullOrEmpty(CurrentNodeName))
                            {
                                <div style="padding: 6px 12px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--neutral-foreground-hint); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 260px;" title="@CurrentNodeName">@CurrentNodeName</div>
                                <hr style="margin: 4px 8px; border: none; border-top: 1px solid var(--neutral-stroke-divider-rest);" />
                            }
                            @foreach (var menuItem in FlattenMenuItems(GetNodeMenuItems()))
                            {
                                var item = menuItem;
                                @if (item.Area == "_separator")
                                {
                                    <hr style="margin: 4px 8px; border: none; border-top: 1px solid var(--neutral-stroke-divider-rest);" />
                                }
                                else
                                {
                                    <FluentMenuItem OnClick="@(() => HandleMenuItemClick(item))" title="@(item.Tooltip ?? item.Label)">
                                        @if (!string.IsNullOrEmpty(item.Icon))
                                        {
                                            if (IsEmoji(item.Icon))
                                            {
                                                <span style="margin-right: 8px;">@item.Icon</span>
                                            }
                                            else
                                            {
                                                <img src="@item.Icon" alt="" style="width: 16px; height: 16px; margin-right: 8px;" />
                                            }
                                        }
                                        @item.Label
                                    </FluentMenuItem>
                                }
                            }
                        </FluentMenu>
                        <FluentButton Id="node-menu-anchor" Appearance="Appearance.Stealth" BackgroundColor="transparent"
                            Title="Node menu" aria-label="Node menu"
                            OnClick="@ToggleNodeMenu">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Cube())" Color="Color.FillInverse" />
                        </FluentButton>

                        @* Mesh menu — mesh-level operations (Create, Import, Export) *@
                        <FluentMenu Anchor="mesh-menu-anchor" Open="@isMeshMenuOpen" OpenChanged="@OnMeshMenuOpenChanged">
                            @if (!string.IsNullOrEmpty(CurrentNodeName))
                            {
                                <div style="padding: 6px 12px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--neutral-foreground-hint); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 260px;" title="@CurrentNodeName">@CurrentNodeName</div>
                                <hr style="margin: 4px 8px; border: none; border-top: 1px solid var(--neutral-stroke-divider-rest);" />
                            }
                            @foreach (var menuItem in FlattenMenuItems(GetMeshMenuItems()))
                            {
                                var item = menuItem;
                                @if (item.Area == "_separator")
                                {
                                    <hr style="margin: 4px 8px; border: none; border-top: 1px solid var(--neutral-stroke-divider-rest);" />
                                }
                                else
                                {
                                    <FluentMenuItem OnClick="@(() => HandleMenuItemClick(item))" title="@(item.Tooltip ?? item.Label)">
                                        @if (!string.IsNullOrEmpty(item.Icon))
                                        {
                                            if (IsEmoji(item.Icon))
                                            {
                                                <span style="margin-right: 8px;">@item.Icon</span>
                                            }
                                            else
                                            {
                                                <img src="@item.Icon" alt="" style="width: 16px; height: 16px; margin-right: 8px;" />
                                            }
                                        }
                                        @item.Label
                                    </FluentMenuItem>
                                }
                            }
                        </FluentMenu>
                        <FluentButton Id="mesh-menu-anchor" Appearance="Appearance.Stealth" BackgroundColor="transparent"
                            Title="Mesh menu" aria-label="Mesh menu"
                            OnClick="@ToggleMeshMenu">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Grid())" Color="Color.FillInverse" />
                        </FluentButton>

                        @* AI menu — Threads / Models / Agents / Skills, each opens mesh search grouped by namespace *@
                        <FluentMenu Anchor="ai-menu-anchor" Open="@isAiMenuOpen" OpenChanged="@OnAiMenuOpenChanged">
                            @foreach (var menuItem in FlattenMenuItems(GetAiMenuItems()))
                            {
                                var item = menuItem;
                                @if (item.Area == "_separator")
                                {
                                    <hr style="margin: 4px 8px; border: none; border-top: 1px solid var(--neutral-stroke-divider-rest);" />
                                }
                                else
                                {
                                    <FluentMenuItem OnClick="@(() => HandleMenuItemClick(item))" title="@(item.Tooltip ?? item.Label)">
                                        @if (!string.IsNullOrEmpty(item.Icon))
                                        {
                                            if (IsEmoji(item.Icon))
                                            {
                                                <span style="margin-right: 8px;">@item.Icon</span>
                                            }
                                            else
                                            {
                                                <img src="@item.Icon" alt="" style="width: 16px; height: 16px; margin-right: 8px;" />
                                            }
                                        }
                                        @item.Label
                                    </FluentMenuItem>
                                }
                            }
                        </FluentMenu>
                        <FluentButton Id="ai-menu-anchor" Appearance="Appearance.Stealth" BackgroundColor="transparent"
                            Title="AI" aria-label="AI menu"
                            OnClick="@ToggleAiMenu">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Sparkle())" Color="Color.FillInverse" />
                        </FluentButton>

                        @* Instance sync lives in the Node menu ("Synchronizations") — no separate dropdown. *@

                        @* GitHub menu — GitHub sync actions; shown only when the Space has GitHub configured *@
                        @if (GetGitHubMenuItems().Count > 0)
                        {
                            <FluentMenu Anchor="github-menu-anchor" Open="@isGitHubMenuOpen" OpenChanged="@OnGitHubMenuOpenChanged">
                                @foreach (var menuItem in FlattenMenuItems(GetGitHubMenuItems()))
                                {
                                    var item = menuItem;
                                    @if (item.Area == "_separator")
                                    {
                                        <hr style="margin: 4px 8px; border: none; border-top: 1px solid var(--neutral-stroke-divider-rest);" />
                                    }
                                    else
                                    {
                                        <FluentMenuItem OnClick="@(() => HandleMenuItemClick(item))" title="@(item.Tooltip ?? item.Label)">@item.Label</FluentMenuItem>
                                    }
                                }
                            </FluentMenu>
                            <FluentButton Id="github-menu-anchor" Appearance="Appearance.Stealth" BackgroundColor="transparent"
                                Title="GitHub" aria-label="GitHub menu"
                                OnClick="@ToggleGitHubMenu">
                                <FluentIcon Value="@(new Icons.Regular.Size20.BranchFork())" Color="Color.FillInverse" />
                            </FluentButton>
                        }

                        @* Settings — direct navigation *@
                        <FluentButton Appearance="Appearance.Stealth" BackgroundColor="transparent"
                            Title="Settings" aria-label="Settings"
                            OnClick="@NavigateToSettings">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Settings())" Color="Color.FillInverse" />
                        </FluentButton>
                    </Authorized>
                </AuthorizeView>
                @* Light/dark theme toggle — top-bar chrome, matching the mobile client. Owns a
                   FluentDesignTheme sharing StorageName="theme" so flipping ThemeMode re-themes the
                   whole app and persists. Visible to everyone (outside AuthorizeView). *@
                <FluentDesignTheme @bind-Mode="@ThemeMode" StorageName="theme" />
                <FluentButton Appearance="Appearance.Stealth" BackgroundColor="transparent"
                    Title="@ThemeToggleTitle" aria-label="@ThemeToggleTitle"
                    OnClick="@ToggleTheme">
                    <FluentIcon Value="@ThemeToggleIcon" Color="Color.FillInverse" />
                </FluentButton>
                @HeaderLinks
            </div>
            <div class="notifications">
                <NotificationCenter />
            </div>
            <AuthorizeView>
                <Authorized>
                    <div class="side-panel-toggle">
                        @* Context-aware icon: open → close-panel; closed on a thread → show-context;
                           closed elsewhere → chat (open a new conversation). *@
                        <FluentButton BackgroundColor="transparent" OnClick="ToggleSidePanel" Title="@SidePanelToggleTitle">
                            @if (IsSidePanelVisible)
                            {
                                <FluentIcon Value="@(new Icons.Regular.Size20.PanelRightContract())" Color="Color.Neutral" />
                            }
                            else if (HasThreadContext)
                            {
                                <FluentIcon Value="@(new Icons.Regular.Size20.PanelRightExpand())" Color="Color.Neutral" />
                            }
                            else
                            {
                                <FluentIcon Value="@(new Icons.Regular.Size20.Chat())" Color="Color.Neutral" />
                            }
                        </FluentButton>
                    </div>
                </Authorized>
            </AuthorizeView>
            <UserProfile />
        </FluentHeader>

        @DesktopNavMenu
    }
    else
    {
        <FluentHeader>
            <FluentSpacer />

            <UserProfile />
            <FluentButton
                IconEnd="@(IsNavMenuOpen ? new Icons.Regular.Size24.Dismiss() : new Icons.Regular.Size24.Navigation())"
                Title="Menu" Appearance="Appearance.Stealth" BackgroundColor="transparent"
                OnClick="@ToggleNavMenu" Class="navigation-button" />
        </FluentHeader>

        @MobileNavMenu
    }

    @* Breadcrumb bar — the chrome-level "where am I" trail (⌂ Home › Doc › Architecture …),
       the Blazor peer of the React-Native shell's breadcrumb toolbar and the server-side
       BuildBreadcrumbs content trail. Each ancestor crumb links to its default page
       (/{cumulative}); the current node is plain bold text; a trailing "· {area}" shows the
       active area when it isn't the node's default content page. Desktop only, and hidden at
       the mesh root (no segments) so it never adds an empty chrome row. *@
    @if (ViewportInformation.IsDesktop && Breadcrumbs.Count > 0)
    {
        <nav class="breadcrumb-bar" aria-label="Breadcrumb">
            <a class="crumb crumb-home" href="/" title="Home">⌂ Home</a>
            @foreach (var crumb in Breadcrumbs)
            {
                <span class="crumb-sep" aria-hidden="true">›</span>
                @if (crumb.IsLast)
                {
                    <span class="crumb crumb-current" aria-current="page">@crumb.Label</span>
                }
                else
                {
                    <a class="crumb" href="@crumb.Href">@crumb.Label</a>
                }
            }
            @if (!string.IsNullOrEmpty(CurrentBreadcrumbArea))
            {
                <span class="crumb-area">· @CurrentBreadcrumbArea</span>
            }
        </nav>
    }

    <div class="messagebar-container">
        <FluentMessageBarProvider Section="@MessageBarSection" Class="top-messagebar" />
    </div>
    }

    <FluentDialogProvider />
    <PortalErrorModal />
    <FluentTooltipProvider />
    <FluentMenuProvider />
    <FluentToastProvider MaxToastCount="10" />
    <FluentKeyCodeProvider />

    @* Main content area — splitter always rendered to preserve side panel component state.
       When closed, inline styles collapse the second pane to zero. *@
    <FluentMultiSplitter Orientation="@(SidePanelPositionValue == SidePanelPosition.Bottom ? Orientation.Vertical : Orientation.Horizontal)"
                         Style="grid-area: main; height: 100%; width: 100%; overflow: hidden;"
                         Class="@(IsSidePanelVisible ? "body-splitter" : "body-splitter panel-collapsed")"
                         BarSize="@(IsSidePanelVisible ? "16" : "0")">
        <FluentMultiSplitterPane Size="@(IsSidePanelVisible ? MainPaneSize : "100%")" Min="100px" Collapsible="false">
            <div class="body-content">
                <FluentToastProvider MaxToastCount="3" Timeout="5000" />
                @Body
            </div>
        </FluentMultiSplitterPane>
        <FluentMultiSplitterPane Size="@(IsSidePanelVisible ? SidePanelPaneSize : "0")"
                                  Min="@(IsSidePanelVisible ? "250px" : "0")"
                                  Max="@(IsSidePanelVisible ? "85%" : "0")"
                                  Collapsible="false"
                                  Resizable="@IsSidePanelVisible"
                                  Style="@(IsSidePanelVisible ? "" : "display:none")">
            @if (IsSidePanelVisible)
            {
                <div class="side-panel-wrapper">
                    <SidePanel @key="@("side-panel-singleton")" OnCloseRequested="ToggleSidePanel">
                        <ChildContent>
                            @* IsInSidePanel lets panel-hosted views (e.g. ThreadChatView's context chip)
                               target the OPPOSITE panel — a side-panel chat opens its context in the
                               main view, a main-view chat peeks it here. IsFixed: the value never changes
                               for this subtree, so descendants skip change-tracking subscriptions. *@
                            <CascadingValue Name="IsInSidePanel" Value="@true" IsFixed="true">
                                @if (sidePanelViewModel != null)
                                {
                                    @* Resolved content — render via LayoutAreaView (same as main page).
                                       Fill=true (NOT Top — that would hijack the page title/menu) so a
                                       full-height editor fills the panel instead of collapsing to ~4 lines. *@
                                    <LayoutAreaView @key="@SidePanelState.ContentPath"
                                                    ViewModel="@sidePanelViewModel"
                                                    Fill="true"
                                                    Area="@($"sidepanel-{SidePanelState.ContentPath}")" />
                                }
                                else
                                {
                                    @* New chat — no thread yet *@
                                    <ChatErrorBoundary @key="@sidePanelContentKey"><ThreadChatView @key="@sidePanelContentKey" ViewModel="@GetSidePanelControl()" /></ChatErrorBoundary>
                                }
                            </CascadingValue>
                        </ChildContent>
                    </SidePanel>
                </div>
            }
        </FluentMultiSplitterPane>
    </FluentMultiSplitter>

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Try reloading the page.</a>
        <a class="dismiss">🗙</a>
    </div>
</div>
