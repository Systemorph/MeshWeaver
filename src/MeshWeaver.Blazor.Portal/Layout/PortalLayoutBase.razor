@using Orientation = Microsoft.FluentUI.AspNetCore.Components.Orientation
@inherits LayoutComponentBase
@inject IDialogService DialogService

<div class="layout @(IsAIChatVisible ? $"chat-visible chat-position-{ChatPositionValue.ToString().ToLower()}" : "")"
    style="@(IsNavMenuOpen ? "overflow: hidden;" : string.Empty)">
    <div class="meshweaver-icon">
        <FluentAnchor Appearance="Appearance.Stealth" Href="/" Class="logo" title="MeshWeaver" aria-label="MeshWeaver">
            <MeshWeaverLogo></MeshWeaverLogo>
        </FluentAnchor>
    </div>

    @if (ViewportInformation.IsDesktop)
    {
        <FluentHeader>
            <FluentAnchor Appearance="Appearance.Stealth" Href="https://www.meshweaver.cloud" Class="logo">
                MESHWEAVER
            </FluentAnchor>
            <FluentSpacer />
            <div class="links">
                <div class="search-container">
                    <SearchBar />
                </div>
                @* Create menu - available in all portal layouts *@
                <FluentButton Appearance="Appearance.Stealth" Id="create-menu-button"
                    Title="Create new" aria-label="Create new" @onclick="@(() => isCreateMenuOpen = !isCreateMenuOpen)">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Add())" Color="Color.FillInverse" />
                </FluentButton>
                <FluentMenu Anchor="create-menu-button" @bind-Open="isCreateMenuOpen">
                    @if (IsLoadingCreatableTypes && CreatableTypes.Count == 0)
                    {
                        <FluentMenuItem Disabled="true">Loading...</FluentMenuItem>
                    }
                    else if (CreatableTypes.Count == 0)
                    {
                        <FluentMenuItem Disabled="true">No types available</FluentMenuItem>
                    }
                    else
                    {
                        @foreach (var typeInfo in CreatableTypes)
                        {
                            <FluentMenuItem OnClick="@(async () => await NavigateToCreateAsync(typeInfo.NodeTypePath))">
                                New @(typeInfo.DisplayName ?? typeInfo.NodeTypePath)
                            </FluentMenuItem>
                        }
                    }
                </FluentMenu>
                @HeaderLinks
            </div>
            <div class="notifications">
                <NotificationCenter />
            </div>
            <div class="chat">
                <FluentButton BackgroundColor="transparent" OnClick="ToggleAIChatVisibility" Title="AI Chat">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Chat())" Color="Color.Neutral" />
                </FluentButton>
            </div>
            <div class="settings">
                <FluentButton BackgroundColor="transparent" OnClick="OpenSiteSettingsAsync" Title="Site settings">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Settings())" Color="Color.Neutral"
                        Title="Site settings" />
                </FluentButton>
            </div>
            <UserProfile />
        </FluentHeader>

        @DesktopNavMenu
    }
    else
    {
        <FluentHeader>
            <FluentSpacer />

            <UserProfile />
            <FluentButton
                IconEnd="@(IsNavMenuOpen ? new Icons.Regular.Size24.Dismiss() : new Icons.Regular.Size24.Navigation())"
                Title="Menu" Appearance="Appearance.Stealth" BackgroundColor="transparent"
                OnClick="@ToggleNavMenu" Class="navigation-button" />
        </FluentHeader>

        @MobileNavMenu
    }

    <div class="messagebar-container">
        <FluentMessageBarProvider Section="@MessageBarSection" Class="top-messagebar" />
    </div>

    <FluentDialogProvider />
    <FluentTooltipProvider />
    <FluentMenuProvider />
    <FluentToastProvider MaxToastCount="10" />
    <FluentKeyCodeProvider />

    @* Main content area with splitter at top level (in grid-area: main).
       @Body goes in first pane with body-content class. Chat is in second pane. *@
    <FluentMultiSplitter Orientation="@(ChatPositionValue == ChatPosition.Bottom ? Orientation.Vertical : Orientation.Horizontal)"
                         Style="grid-area: main; height: 100%; width: 100%; overflow: hidden;"
                         Class="body-splitter">
        <FluentMultiSplitterPane Size="@MainPaneSizeWithChat" Min="200px">
            @* Page content - body-content class applies grid-area styles *@
            <div class="body-content">
                <FluentToastProvider MaxToastCount="3" Timeout="5000" />
                @Body
            </div>
        </FluentMultiSplitterPane>
        <FluentMultiSplitterPane Size="@ChatPaneSizeWithVisibility" Min="@(IsAIChatVisible ? "250px" : "0")" Max="60%" Resizable="@IsAIChatVisible" Collapsible="true" Collapsed="@(!IsAIChatVisible)">
            @* Chat panel - persists across navigation, independent from @Body *@
            <div class="ai-chat-content" style="@(IsAIChatVisible ? "" : "display: none;")">
                <AgentChatView @key="@("chat-singleton")" @ref="chatComponent" ViewModel="@chatControl" OnCloseRequested="ToggleAIChatVisibility" OnPositionChanged="HandleChatPositionChanged" />
            </div>
        </FluentMultiSplitterPane>
    </FluentMultiSplitter>

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Try reloading the page.</a>
        <a class="dismiss">🗙</a>
    </div>
</div>
