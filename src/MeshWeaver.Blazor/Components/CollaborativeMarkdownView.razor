@using MeshWeaver.Blazor
@using MeshWeaver.Layout
@using MeshWeaver.Markdown
@using MeshWeaver.Mesh
@using Microsoft.Extensions.Logging
@namespace MeshWeaver.Blazor.Components
@inherits BlazorView<CollaborativeMarkdownControl, CollaborativeMarkdownView>

<div class="collab-md-container @ViewModeClass" data-theme="@Mode.ToString().ToLower()" @ref="containerRef">
    @* View mode toolbar — only shown when document has annotations *@
    @if (HasAnnotations || HasCommentAnnotations)
    {
        <div class="collab-md-toolbar">
            @if (HasAnnotations)
            {
                <FluentSelect TOption="string"
                              Value="@CurrentViewMode"
                              ValueChanged="@OnViewModeChanged"
                              Label="View"
                              Style="min-width: 140px;">
                    <FluentOption Value="Markup">Markup</FluentOption>
                    <FluentOption Value="HideMarkup">Hide Markup</FluentOption>
                    <FluentOption Value="Original">Original</FluentOption>
                </FluentSelect>
            }

            @if (HasCommentAnnotations)
            {
                <FluentSelect TOption="string"
                              Value="@CurrentCommentFilter"
                              ValueChanged="@OnCommentFilterChanged"
                              Label="Comments"
                              Style="min-width: 160px;">
                    <FluentOption Value="Unresolved">Unresolved</FluentOption>
                    <FluentOption Value="All">All Comments</FluentOption>
                    <FluentOption Value="None">No Comments</FluentOption>
                </FluentSelect>
            }

            @if (BoundCanEdit && HasAnnotations)
            {
                <div class="collab-md-toolbar-separator"></div>

                <FluentButton Appearance="Microsoft.FluentUI.AspNetCore.Components.Appearance.Stealth"
                              OnClick="@OnAcceptAll"
                              Style="color: var(--annotation-insert-border); font-size: 0.85rem;">Accept All</FluentButton>
                <FluentButton Appearance="Microsoft.FluentUI.AspNetCore.Components.Appearance.Stealth"
                              OnClick="@OnRejectAll"
                              Style="color: var(--annotation-delete-border); font-size: 0.85rem;">Reject All</FluentButton>
            }
        </div>
    }

    @* Split layout: content + annotation cards *@
    <div class="collab-md-split @(HasSideAnnotations ? "with-sidebar" : "")">
        <div class="collab-md-content markdown-annotations-container markdown-body" data-theme="@Mode.ToString().ToLower()" style="background-color: var(--neutral-layer-1);" @ref="contentRef">
            @((RenderFragment)RenderContentHtml)
        </div>

        @if (HasSideAnnotations)
        {
            <div class="collab-md-sidebar annotations-column" @onclick:stopPropagation="true">
                @foreach (var comment in SidebarComments)
                {
                    var id = comment.MarkerId!;
                    <div class="annotation-card annotation-for-@id annotation-type-comment @(comment.Status == CommentStatus.Resolved ? "resolved" : "") @(activeAnnotationId == id ? "active" : "")"
                         @onclick="() => HighlightAnnotation(id)">
                        <div class="comment-header">
                            <span class="comment-author">@comment.Author</span>
                            <span class="comment-time">@FormatTimeAgo(comment.CreatedAt)</span>
                            <div class="comment-actions">
                                @if (comment.Status != CommentStatus.Resolved)
                                {
                                    <button class="btn-resolve" title="Resolve" @onclick="() => ResolveComment(id)" @onclick:stopPropagation="true">&#x2713;</button>
                                }
                                <button class="btn-delete" title="Delete" @onclick="() => DeleteComment(id)" @onclick:stopPropagation="true">&#x2715;</button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(comment.HighlightedText))
                        {
                            <div class="comment-quote">"@Truncate(comment.HighlightedText, 60)"</div>
                        }
                        @if (!string.IsNullOrEmpty(comment.Text))
                        {
                            <div class="comment-text">@comment.Text</div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @if (string.IsNullOrWhiteSpace(_processedHtml))
    {
        <p style="color: var(--neutral-foreground-hint); font-style: italic;">No content yet. Click Edit to add content.</p>
    }

    @* Comment input dialog — appears when user selects text and clicks Comment *@
    @if (_showCommentInput)
    {
        <div class="comment-input-overlay" @onclick="CancelSelectionComment">
            <div class="comment-input-dialog" @onclick:stopPropagation="true">
                <div class="comment-input-header">Add Comment</div>
                @if (!string.IsNullOrEmpty(_pendingSelectionText))
                {
                    <div class="comment-input-quote">&ldquo;@Truncate(_pendingSelectionText, 120)&rdquo;</div>
                }
                <textarea class="comment-input-textarea" @bind="_pendingCommentText" @bind:event="oninput" placeholder="Write your comment..." rows="3"></textarea>
                <div class="comment-input-actions">
                    <button class="comment-btn comment-btn-cancel" @onclick="CancelSelectionComment">Cancel</button>
                    <button class="comment-btn comment-btn-submit" @onclick="SubmitSelectionComment">Add Comment</button>
                </div>
            </div>
        </div>
    }

    @* Bottom page comment section *@
    @if (!string.IsNullOrEmpty(BoundNodePath))
    {
        <div class="page-comment-section">
            @if (_showPageCommentInput)
            {
                <div class="page-comment-form">
                    <textarea class="comment-input-textarea" @bind="_pageCommentText" @bind:event="oninput" placeholder="Write your comment..." rows="3"></textarea>
                    <div class="comment-input-actions">
                        <button class="comment-btn comment-btn-cancel" @onclick="CancelPageComment">Cancel</button>
                        <button class="comment-btn comment-btn-submit" @onclick="SubmitPageComment">Add Comment</button>
                    </div>
                </div>
            }
            else
            {
                <button class="add-page-comment-btn" @onclick="StartPageComment">+ Add Comment</button>
            }
        </div>
    }
</div>
