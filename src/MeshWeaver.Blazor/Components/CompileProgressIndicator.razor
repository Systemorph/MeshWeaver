@* Code-behind moved to CompileProgressIndicator.razor.cs *@

@if (CompilingPath is not null)
{
    <div class="compile-progress">
        <FluentProgressRing style="width: 24px; height: 24px;" />
        <span>
            Compiling <strong>@CompilingPath</strong>
            @if (Seconds > 0)
            {
                <text> (@Seconds s)</text>
            }
            …
        </span>
    </div>
}
