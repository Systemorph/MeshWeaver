@using System.Reactive.Linq
@using Microsoft.Extensions.Logging
@using Orientation = Microsoft.FluentUI.AspNetCore.Components.Orientation
@inherits BlazorView<ItemTemplateControl, ItemTemplate>

@if (Data != null)
{
    <FluentStack Class="@Class" Style="@Style" Orientation="@Orientation" Wrap="@Wrap">
        @for (int i = 0; i < Data.Count; ++i)
        {
            <DispatchView ViewModel="@GetViewWithPath(i)" Stream="@Stream" Area="@ViewArea" />
        }
    </FluentStack>
}

@code
{
    private IReadOnlyCollection<object> Data { get; set; } = Array.Empty<object>();
    private Orientation Orientation { get; set; } = Orientation.Vertical;
    private bool Wrap { get; set; }
    private UiControl? RenderedView { get; set; }

    private string ViewArea => $"{Area}/{ItemTemplateControl.ViewArea}";

    protected override void BindData()
    {
        base.BindData();
        DataBind(ViewModel.Data, x => x.Data);
        DataBind(ViewModel.Orientation, x => x.Orientation,
            (val, def) => val != null ? (Orientation)Convert.ToInt32(val) : def);
        DataBind(ViewModel.Wrap, x => x.Wrap);

        if (Stream is not null)
        {
            AddBinding(Stream.GetControlStream(ViewArea)
                .Subscribe(
                    v =>
                    {
                        if (IsViewDisposed) return;
                        InvokeAsync(() =>
                        {
                            if (IsViewDisposed) return;
                            RenderedView = v;
                            RequestStateChange();
                        });
                    },
                    // A faulting control stream with no onError propagates UNHANDLED on the Rx
                    // scheduler and tears down the circuit (blank app). Log + keep the last-good
                    // item view; teardown (ObjectDisposedException) is benign.
                    ex =>
                    {
                        if (IsViewDisposed || ex is ObjectDisposedException)
                        {
                            Logger.LogDebug(ex, "Suppressed teardown error in item-template control stream for area {Area}", ViewArea);
                            return;
                        }
                        Logger.LogWarning(ex, "Error in item-template control stream for area {Area} — keeping last-good view", ViewArea);
                    }));
        }
    }

    private UiControl GetViewWithPath(int i) => (RenderedView ?? ViewModel.View) with
    {
        DataContext = $"{ViewModel.DataContext}{ViewModel.Data}/{i}"
    };

}
