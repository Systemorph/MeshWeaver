@using MeshWeaver.Mesh.Services
@inject INavigationService NavigationService

<LayoutAreaView ViewModel="@ViewModel" Top="@Top"/>

@code {
    [Parameter] public string? Address { get; set; }
    [Parameter] public string? Area { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter] public bool ShowProgress { get; set; }
    [Parameter] public string? ProgressMessage { get; set; } = "Loading";
    [Parameter] public bool Top { get; set; }

    private LayoutAreaControl ViewModel =>
        new(
            Address ?? string.Empty,
            new(Area ?? "") { Id = Id }
        )
        {
            ShowProgress = ShowProgress,
            ProgressMessage = ProgressMessage
        };

    protected override void OnParametersSet()
    {
        // Set the current namespace so creatable types are loaded for this address
        if (!string.IsNullOrEmpty(Address))
        {
            NavigationService.SetCurrentNamespace(Address);
        }
    }
}