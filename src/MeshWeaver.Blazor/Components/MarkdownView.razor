@using Microsoft.JSInterop
@inherits BlazorView<MarkdownControl, MarkdownView>

<HeadContent>
    <FluentDesignTheme StorageName="theme" @bind-Mode="@Mode" />
    <link href="https://cdn.jsdelivr.net/npm/github-markdown-css@5.8.1/github-markdown.min.css" rel="stylesheet" />
    <link href="_content/MeshWeaver.Blazor/css/collaborative-annotations.css" rel="stylesheet" />
</HeadContent>

<article class="markdown-body" data-theme="@Mode.ToString().ToLower()" style="@Style">
    @((RenderFragment)RenderHtml)
</article>

