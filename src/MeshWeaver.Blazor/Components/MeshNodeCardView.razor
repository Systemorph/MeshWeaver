@using MeshWeaver.Graph
@using Microsoft.FluentUI.AspNetCore.Components
@inherits BlazorView<MeshNodeCardControl, MeshNodeCardView>

@if (DisableNavigation)
{
    @CardContent
}
else
{
    <a href="/@NodePath" style="text-decoration: none; color: inherit; display: block;">
        @CardContent
    </a>
}

@code {
    private string NodePath { get; set; } = "";
    private string? Title { get; set; }
    private string? Description { get; set; }
    private string? ImageUrl { get; set; }
    private bool IsInlineSvg => ImageUrl?.TrimStart().StartsWith("<svg", StringComparison.OrdinalIgnoreCase) == true;
    private bool IsEmoji => !string.IsNullOrEmpty(ImageUrl) && !IsInlineSvg && !ImageUrl.Contains('/') && !ImageUrl.StartsWith("data:");
    private string? ItemArea { get; set; }
    private bool DisableNavigation { get; set; }

    private string Initial => !string.IsNullOrEmpty(Title) ? Title[0].ToString().ToUpper() : "?";

    /// <summary>
    /// Hard cap on the title so a very long name can never overflow the card (a backstop to the
    /// CSS single-line ellipsis, which can't kick in when a parent doesn't constrain width).
    /// </summary>
    private string TruncatedTitle => Title?.Length > 64
        ? Title[..63].TrimEnd() + "…"
        : Title ?? "";

    private string TruncatedDescription => Description?.Length > 100
        ? Description[..97] + "..."
        : Description ?? "";

    /// <summary>Default glyph for a node that carries no icon/avatar/logo — a generic document
    /// outline, so an icon-less node still reads as a node rather than a bare letter.</summary>
    private static readonly MarkupString DefaultNodeIcon = (MarkupString)(
        "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">" +
        "<path d=\"M6 3h7l5 5v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linejoin=\"round\"/>" +
        "<path d=\"M13 3v5h5M8 13h8M8 17h8M8 9h2\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>");

    private LayoutAreaControl GetLayoutArea() =>
        new LayoutAreaControl(NodePath, new LayoutAreaReference(ItemArea!))
            .WithShowProgress(false);

    private RenderFragment CardContent => __builder =>
    {
        if (!string.IsNullOrEmpty(ItemArea))
        {
            <LayoutAreaView ViewModel="@GetLayoutArea()" Stream="@Stream" Area="@($"card-{NodePath}-{ItemArea}")" />
        }
        else
        {
            <FluentCard Class="mesh-node-card" Style="cursor: pointer;">
                <div class="mesh-node-card-content">
                    @if (!string.IsNullOrEmpty(ImageUrl))
                    {
                        @if (IsInlineSvg)
                        {
                            <div class="mesh-node-card-image" style="display: flex; align-items: center; justify-content: center;">@((MarkupString)ImageUrl)</div>
                        }
                        else if (IsEmoji)
                        {
                            <div class="mesh-node-card-placeholder" style="background: transparent; font-size: 32px;">@ImageUrl</div>
                        }
                        else
                        {
                            <img src="@ImageUrl" alt="@Title" class="mesh-node-card-image" />
                        }
                    }
                    else
                    {
                        <div class="mesh-node-card-placeholder">@DefaultNodeIcon</div>
                    }
                    <div class="mesh-node-card-text">
                        <div class="mesh-node-card-title" title="@Title">@TruncatedTitle</div>
                        @if (!string.IsNullOrEmpty(Description))
                        {
                            <div class="mesh-node-card-description">@TruncatedDescription</div>
                        }
                    </div>
                </div>
            </FluentCard>
        }
    };

    protected override void BindData()
    {
        base.BindData();
        DataBind(ViewModel.NodePath, x => x.NodePath);
        DataBind(ViewModel.Title, x => x.Title);
        DataBind(ViewModel.Description, x => x.Description);
        DataBind(ViewModel.ImageUrl, x => x.ImageUrl);
        DataBind(ViewModel.ItemArea, x => x.ItemArea);
        DataBind(ViewModel.DisableNavigation, x => x.DisableNavigation);
    }
}
