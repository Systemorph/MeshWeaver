@using MeshWeaver.Mesh
@using MeshWeaver.Graph
@inherits BlazorView<MeshWeaver.Layout.MeshNodeCollectionControl, MeshNodeCollectionView>
@inject NavigationManager NavigationManager
@inject MeshWeaver.Mesh.Services.IMeshQuery MeshQuery

<div class="mesh-node-collection" style="@Style">
    @if (_isLoading)
    {
        <FluentProgressRing Style="margin: 8px;" />
    }
    else if (_items.Count == 0 && !(ViewModel?.ShowAdd ?? true))
    {
        <div style="color: var(--neutral-foreground-hint); padding: 8px;">No items.</div>
    }
    else
    {
        @foreach (var node in _items)
        {
            var capturedNode = node;
            var initial = GetInitial(node);
            var imageUrl = GetImageUrl(node);
            var entries = GetSubEntries(node);

            <div class="mesh-node-collection-item" @onclick="() => NavigateToItem(capturedNode.Path)">
                @if (!string.IsNullOrEmpty(imageUrl))
                {
                    <img src="@imageUrl" alt="@(node.Name ?? node.Id)" class="mesh-node-collection-avatar-img" />
                }
                else
                {
                    <div class="mesh-node-collection-avatar">@initial</div>
                }
                <div class="mesh-node-collection-info">
                    <div class="mesh-node-collection-name">@(node.Name ?? node.Id)</div>
                    @if (entries != null && entries.Count > 0)
                    {
                        <div class="mesh-node-collection-chips">
                            @foreach (var entry in entries)
                            {
                                var capturedEntry = entry;
                                <span class="mesh-node-collection-chip @(entry.IsDenied ? "denied" : "")">
                                    @entry.Label
                                    @if (ViewModel?.Deletable == true)
                                    {
                                        <button type="button" class="mesh-node-collection-chip-x"
                                                @onclick="() => RemoveSubEntry(capturedNode, capturedEntry.Index)"
                                                @onclick:stopPropagation="true">×</button>
                                    }
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mesh-node-collection-type">@(node.NodeType ?? "")</div>
                    }
                </div>
                @if (ViewModel?.Deletable == true)
                {
                    <button type="button" class="mesh-node-collection-delete" @onclick="() => DeleteItem(capturedNode.Path)" @onclick:stopPropagation="true">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Delete())" />
                    </button>
                }
            </div>
        }
    }

    @if (ViewModel?.ShowAdd == true && ViewModel.IsClickable)
    {
        <button type="button" class="mesh-node-collection-add" @onclick="OnAddClick">
            <FluentIcon Value="@(new Icons.Regular.Size16.Add())" />
        </button>
    }
</div>

<style>
    .mesh-node-collection {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .mesh-node-collection-item {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 10px;
        padding: 6px 12px;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.15s;
    }

    .mesh-node-collection-item:hover {
        background: var(--neutral-fill-secondary-hover);
    }

    .mesh-node-collection-avatar {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        background: var(--accent-fill-rest);
        color: var(--foreground-on-accent-rest);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 15px;
        flex-shrink: 0;
    }

    .mesh-node-collection-avatar-img {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .mesh-node-collection-info {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
    }

    .mesh-node-collection-name {
        font-weight: 600;
        font-size: 0.9rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .mesh-node-collection-type {
        font-size: 0.78rem;
        color: var(--neutral-foreground-hint);
    }

    .mesh-node-collection-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-top: 2px;
    }

    .mesh-node-collection-chip {
        display: inline-flex;
        align-items: center;
        gap: 2px;
        padding: 1px 8px;
        border-radius: 12px;
        background: var(--neutral-fill-secondary-rest);
        font-size: 0.75rem;
        line-height: 1.4;
    }

    .mesh-node-collection-chip.denied {
        text-decoration: line-through;
        opacity: 0.6;
    }

    .mesh-node-collection-chip-x {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0 1px;
        font-size: 0.8rem;
        line-height: 1;
        color: var(--neutral-foreground-hint);
        display: inline-flex;
        align-items: center;
    }

    .mesh-node-collection-chip-x:hover {
        color: var(--error-foreground);
    }

    .mesh-node-collection-delete {
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
        border-radius: 4px;
        color: var(--neutral-foreground-hint);
        display: flex;
        align-items: center;
    }

    .mesh-node-collection-delete:hover {
        background: var(--neutral-fill-stealth-hover);
        color: var(--error-foreground);
    }

    .mesh-node-collection-add {
        background: none;
        border: 1px dashed var(--neutral-stroke-rest);
        cursor: pointer;
        padding: 8px;
        border-radius: 6px;
        color: var(--accent-foreground-rest);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: 4px;
        transition: background 0.15s, border-color 0.15s;
    }

    .mesh-node-collection-add:hover {
        background: var(--accent-fill-hover);
        color: var(--foreground-on-accent-rest);
        border-color: var(--accent-fill-hover);
    }
</style>

@code {
    private static string GetInitial(MeshNode node)
    {
        var name = node.Name ?? node.Id;
        return !string.IsNullOrEmpty(name) ? name[0].ToString().ToUpper() : "?";
    }

    private static string? GetImageUrl(MeshNode node)
    {
        if (node.Content is System.Text.Json.JsonElement json)
        {
            if (json.TryGetProperty("avatar", out var a) && a.ValueKind == System.Text.Json.JsonValueKind.String) return a.GetString();
            if (json.TryGetProperty("Avatar", out var A) && A.ValueKind == System.Text.Json.JsonValueKind.String) return A.GetString();
            if (json.TryGetProperty("logo", out var l) && l.ValueKind == System.Text.Json.JsonValueKind.String) return l.GetString();
            if (json.TryGetProperty("Logo", out var L) && L.ValueKind == System.Text.Json.JsonValueKind.String) return L.GetString();
        }
        return MeshNodeImageHelper.GetIconAsImageUrl(node.Icon);
    }
}
