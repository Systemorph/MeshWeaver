@using MeshWeaver.Blazor.Components.Monaco
@using MeshWeaver.Graph
@using MeshWeaver.Layout
@using MeshWeaver.Mesh
@using Microsoft.FluentUI.AspNetCore.Components

<div class="mesh-search-container">
    @if (BoundShowSearchBox || !string.IsNullOrEmpty(BoundTitle) || ShowCreateButton)
    {
        <div class="mesh-search-box">
            <div class="mesh-search-box-inner">
                @if (!string.IsNullOrEmpty(BoundTitle))
                {
                    <div class="mesh-search-title">@BoundTitle</div>
                }
                @if (BoundShowSearchBox)
                {
                    <div class="mesh-search-box-input">
                        <MonacoEditorView @ref="monacoEditor"
                                          Value="@_currentValue"
                                          ValueChanged="@OnValueChanged"
                                          OnSubmit="HandleSearch"
                                          Placeholder="@BoundPlaceholder"
                                          Height="38px"
                                          MaxHeight="38px"
                                          ShowBorder="true"
                                          CodeEditMode="false"
                                          CompletionCallback="@GetCompletions" />
                    </div>
                    <button type="button" class="mesh-search-button" @onclick="HandleSearch">
                        Search
                    </button>
                    <button type="button" class="mesh-search-options-button" @onclick="ToggleSearchOptions"
                            title="Search options">
                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Settings())" />
                    </button>
                }
                @if (ShowCreateButton)
                {
                    <button type="button" class="mesh-search-create-button" @onclick="HandleCreateClick"
                            title="Create new">
                        +
                    </button>
                }
            </div>
        </div>
    }

    @if (_showSearchOptions)
    {
        <div class="mesh-search-options-panel">
            <div class="mesh-search-options-header">
                <span>Query</span>
                <button type="button" class="mesh-search-options-close" @onclick="ToggleSearchOptions">&times;</button>
            </div>
            <textarea class="mesh-search-options-query" rows="2"
                      @bind="_editableHiddenQuery" @bind:event="oninput" />
            <div class="mesh-search-options-actions">
                <button type="button" class="mesh-search-button" @onclick="ApplySearchOptions">Apply</button>
            </div>
        </div>
    }

    <div class="mesh-search-results">
        @if (IsNamespaceTreeMode)
        {
            @if (TreeHasSearchText)
            {
                @* Subtree search: flat results regrouped into nested namespace sections *@
                @if (_treeSearchLoading && _treeSearchItems == null)
                {
                    @RenderTreeLoading()
                }
                else if (_treeSearchItems == null || _treeSearchItems.Count == 0)
                {
                    <FluentLabel Typo="Microsoft.FluentUI.AspNetCore.Components.Typography.Body" Style="color: var(--neutral-foreground-hint);">No items found.</FluentLabel>
                }
                else
                {
                    @RenderTreeItems(_treeSearchItems, TreeRootNamespace, 0, false)
                }
            }
            else if (TreeRootIsLoading)
            {
                @if (BoundShowLoadingIndicator)
                {
                    @RenderTreeLoading()
                }
            }
            else if (TreeRootIsEmpty)
            {
                @if (BoundShowEmptyMessage)
                {
                    @if (ShowCreateButton)
                    {
                        <div class="mesh-search-empty-create" @onclick="HandleCreateClick">
                            <div class="mesh-search-empty-title">Nothing here yet</div>
                            <div class="mesh-search-empty-hint">Click to create your first item</div>
                        </div>
                    }
                    else
                    {
                        <FluentLabel Typo="Microsoft.FluentUI.AspNetCore.Components.Typography.Body" Style="color: var(--neutral-foreground-hint);">No items found.</FluentLabel>
                    }
                }
            }
            else
            {
                @RenderTreeLevel(TreeRootNamespace, 0)
            }
        }
        else if (IsGraphNavigatorMode)
        {
            @RenderGraphNavigator()
        }
        else if (_isLoading && !IsPrecomputedMode && BoundShowLoadingIndicator)
        {
            <div class="mesh-search-area-grid">
                @for (var i = 0; i < 3; i++)
                {
                    <FluentCard Class="mesh-search-card">
                        <div class="mesh-search-card-content">
                            <div class="mesh-search-skeleton-avatar"></div>
                            <div class="mesh-search-card-text">
                                <div class="mesh-search-skeleton-line" style="width: 60%;"></div>
                                <div class="mesh-search-skeleton-line" style="width: 40%;"></div>
                            </div>
                        </div>
                    </FluentCard>
                }
            </div>
        }
        else if (!HasResults() && BoundShowEmptyMessage)
        {
            @if (ShowCreateButton)
            {
                <div class="mesh-search-empty-create" @onclick="HandleCreateClick">
                    <div class="mesh-search-empty-icon">
                        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="8" y="12" width="48" height="40" rx="6" stroke="currentColor" stroke-width="2" stroke-dasharray="4 3" opacity="0.4"/>
                            <circle cx="32" cy="32" r="14" fill="var(--accent-fill-rest)" opacity="0.12"/>
                            <line x1="32" y1="24" x2="32" y2="40" stroke="var(--accent-fill-rest)" stroke-width="2.5" stroke-linecap="round"/>
                            <line x1="24" y1="32" x2="40" y2="32" stroke="var(--accent-fill-rest)" stroke-width="2.5" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <div class="mesh-search-empty-title">Nothing here yet</div>
                    <div class="mesh-search-empty-hint">Click to create your first item</div>
                </div>
            }
            else
            {
                <FluentLabel Typo="Microsoft.FluentUI.AspNetCore.Components.Typography.Body" Style="color: var(--neutral-foreground-hint);">No items found.</FluentLabel>
            }
        }
        else
        {
            var groups = GetGroups();
            var skipHeaders = groups.Count == 1;

            @foreach (var group in groups)
            {
                var isCollapsed = _collapsedGroups.Contains(group.GroupKey);
                var showCollapsible = (BoundSections?.Collapsible ?? true) && !skipHeaders;
                var showCounts = BoundSections?.ShowCounts ?? true;
                var headerLabel = showCounts ? $"{group.Label} ({group.TotalCount})" : group.Label;
                var groupKey = group.GroupKey;

                <div class="mesh-search-section">
                    @if (!skipHeaders)
                    {
                        @if (showCollapsible)
                        {
                            <div class="mesh-search-section-header" @onclick="() => ToggleGroup(groupKey)">
                                <span class="@(isCollapsed ? "mesh-search-collapse-icon" : "mesh-search-collapse-icon expanded")">&#x25b6;</span>
                                <span class="mesh-search-section-label">@headerLabel</span>
                            </div>
                        }
                        else
                        {
                            <h3 class="mesh-search-section-title">@headerLabel</h3>
                        }
                    }

                    @if (!isCollapsed)
                    {
                        var maxVisible = GetMaxVisibleItems(groupKey);
                        var visibleItems = maxVisible.HasValue
                            ? group.Items.Take(maxVisible.Value).ToList()
                            : group.Items;
                        var hiddenCount = group.Items.Count - visibleItems.Count;

                        <div class="mesh-search-grid-wrapper">
                            <div class="mesh-search-area-grid" style="@CardGridStyle">
                                @foreach (var item in visibleItems)
                                {
                                    if (item is MeshNode node)
                                    {
                                        @RenderCard(node)
                                    }
                                }
                            </div>
                        </div>

                        @if (hiddenCount > 0)
                        {
                            <div class="mesh-search-show-more">
                                <button type="button" class="mesh-search-toggle-rows" @onclick="() => ToggleGroupExpanded(groupKey)">
                                    Show all @group.Items.Count
                                </button>
                            </div>
                        }
                        else if (maxVisible.HasValue && _expandedRowGroups.Contains(groupKey) && group.Items.Count > (BoundMaxRows!.Value * (BoundMaxColumns ?? 3)))
                        {
                            <div class="mesh-search-show-more">
                                <button type="button" class="mesh-search-toggle-rows" @onclick="() => ToggleGroupExpanded(groupKey)">
                                    Show less
                                </button>
                            </div>
                        }
                        else if (group.Items.Count < group.TotalCount)
                        {
                            <div class="mesh-search-show-more">
                                <span style="color: var(--neutral-foreground-hint);">Showing @group.Items.Count of @group.TotalCount</span>
                                @if (!string.IsNullOrEmpty(BoundShowAllHref))
                                {
                                    <a href="@BoundShowAllHref" style="color: var(--accent-foreground-rest); text-decoration: none; font-size: 0.85rem; font-weight: 500;">Show all &rarr;</a>
                                }
                            </div>
                        }
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    private RenderFragment RenderCard(MeshNode node) => __builder =>
    {
        var cardControl = GetCardControl(node);
        var clickAddress = ViewModel?.ClickMessageAddress?.ToString();
        var drillArea = BoundDrillDownArea;
        // Drill-down is only meaningful for browser navigation — when the card
        // selects (picker) or posts a click message, skip the secondary anchor.
        var showDrill = !string.IsNullOrEmpty(drillArea)
            && !OnNodeSelected.HasDelegate
            && string.IsNullOrEmpty(clickAddress);

        if (OnNodeSelected.HasDelegate)
        {
            <div style="cursor: pointer;" @onclick="() => OnNodeSelected.InvokeAsync(node)">
                <MeshNodeCardView ViewModel="@cardControl" Stream="@Stream" Area="@($"search-{node.Path}")" />
            </div>
        }
        else if (!string.IsNullOrEmpty(clickAddress))
        {
            <div style="cursor: pointer;" @onclick="() => PostClickMessage(node, clickAddress)">
                <MeshNodeCardView ViewModel="@cardControl" Stream="@Stream" Area="@($"search-{node.Path}")" />
            </div>
        }
        else if (showDrill)
        {
            <div class="mesh-search-card-wrap">
                <MeshNodeCardView ViewModel="@cardControl" Stream="@Stream" Area="@($"search-{node.Path}")" />
                <a class="mesh-search-drilldown" href="/@node.Path/@drillArea"
                   title="Drill down" @onclick:stopPropagation="true">
                    @DrillDownIcon
                </a>
            </div>
        }
        else
        {
            <MeshNodeCardView ViewModel="@cardControl" Stream="@Stream" Area="@($"search-{node.Path}")" />
        }
    };

    /// <summary>Small folder-tree / drill-down glyph (~14px) for the secondary "Drill down" affordance.</summary>
    private static readonly MarkupString DrillDownIcon = (MarkupString)(
        "<svg width=\"14\" height=\"14\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">" +
        "<path d=\"M1.5 3.5a1 1 0 0 1 1-1h3l1.2 1.4H13a1 1 0 0 1 1 1V12a1 1 0 0 1-1 1H2.5a1 1 0 0 1-1-1V3.5Z\" " +
        "stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linejoin=\"round\"/>" +
        "<path d=\"M5.5 8.25h5M8 6.5l2 1.75-2 1.75\" stroke=\"currentColor\" stroke-width=\"1.2\" " +
        "stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>");

    private void PostClickMessage(MeshNode node, string targetAddress)
    {
        Hub.Post(new NavigationRequest($"/{node.Path}") { Target = "SidePanel" },
            o => o.WithTarget(new MeshWeaver.Messaging.Address(targetAddress)));
    }

    // ----- Namespace tree rendering (MeshSearchRenderMode.NamespaceTree) -----

    private RenderFragment RenderTreeLoading() => __builder =>
    {
        <div class="mesh-search-tree-loading">
            <div class="mesh-search-skeleton-line" style="width: 40%;"></div>
            <div class="mesh-search-skeleton-line" style="width: 60%;"></div>
        </div>
    };

    /// <summary>Renders one lazily-loaded namespace level (queried on expand).</summary>
    private RenderFragment RenderTreeLevel(string ns, int depth) => __builder =>
    {
        if (!_treeLevels.TryGetValue(ns, out var level) || level.IsLoading)
        {
            @RenderTreeLoading()
            return;
        }

        if (level.Items.Count == 0)
        {
            <div class="mesh-search-tree-empty">Empty</div>
            return;
        }

        @RenderTreeItems(level.Items, ns, depth, true)
    };

    /// <summary>
    /// Renders folders as collapsible sections (same look as the grouped sections)
    /// and leaves as the usual thumbnail-card grid. <paramref name="lazy"/>: folder
    /// content comes from the per-level cache (browse mode) vs. inline children
    /// (search mode, fully expanded by default).
    /// </summary>
    private RenderFragment RenderTreeItems(IReadOnlyList<NamespaceTreeItem> items, string levelKey, int depth, bool lazy) => __builder =>
    {
        var folders = items.OfType<NamespaceTreeFolder>().ToList();
        var leaves = items.OfType<NamespaceTreeLeaf>().ToList();
        var showCounts = BoundSections?.ShowCounts ?? true;

        @if (lazy)
        {
            @* Browse mode: folders are modern tiles that NAVIGATE into the namespace
               (default page /{folderPath}); drilling deeper expands the URL. *@
            @if (folders.Count > 0)
            {
                <div class="mesh-search-grid-wrapper">
                    <div class="mesh-search-area-grid" style="@CardGridStyle">
                        @foreach (var folder in folders)
                        {
                            @RenderFolderTile(folder, FormatTreeCount(folder.Count), showCounts)
                        }
                    </div>
                </div>
            }
        }
        else
        {
            @* Search mode: folders group flat result nodes — keep the collapsible
               in-page sections so matches stay visible in their namespace context. *@
            @foreach (var folder in folders)
            {
                var isExpanded = IsSearchTreeFolderExpanded(folder.Path);
                var countLabel = folder.Count.ToString();
                var folderPath = folder.Path;

                <div class="mesh-search-section mesh-search-tree-section">
                    <div class="mesh-search-section-header"
                         @onclick="() => OnTreeFolderHeaderClick(folderPath, false)">
                        <span class="@(isExpanded ? "mesh-search-collapse-icon expanded" : "mesh-search-collapse-icon")">&#x25b6;</span>
                        <span class="mesh-search-tree-folder-glyph">
                            <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Folder())" />
                        </span>
                        <span class="mesh-search-section-label">@folder.Name</span>
                        @if (showCounts)
                        {
                            <span class="mesh-search-tree-count">@countLabel</span>
                        }
                        <a class="mesh-search-tree-open" href="/@folder.Path" title="Open @folder.Name"
                           @onclick:stopPropagation="true">&#x2197;</a>
                    </div>
                    @if (isExpanded)
                    {
                        <div class="mesh-search-tree-children">
                            @RenderTreeItems(folder.Children, folder.Path, depth + 1, false)
                        </div>
                    }
                </div>
            }
        }

        @if (leaves.Count > 0)
        {
            var groupKey = $"tree:{levelKey}";
            var maxVisible = GetMaxVisibleItems(groupKey);
            var visibleLeaves = maxVisible.HasValue ? leaves.Take(maxVisible.Value).ToList() : leaves;
            var hiddenCount = leaves.Count - visibleLeaves.Count;

            <div class="mesh-search-grid-wrapper">
                <div class="mesh-search-area-grid" style="@CardGridStyle">
                    @foreach (var leaf in visibleLeaves)
                    {
                        @RenderCard(leaf.Node)
                    }
                </div>
            </div>

            @if (hiddenCount > 0)
            {
                <div class="mesh-search-show-more">
                    <button type="button" class="mesh-search-toggle-rows" @onclick="() => ToggleGroupExpanded(groupKey)">
                        Show all @leaves.Count
                    </button>
                </div>
            }
            else if (_expandedRowGroups.Contains(groupKey)
                     && BoundMaxRows.HasValue
                     && leaves.Count > BoundMaxRows.Value * (BoundMaxColumns ?? 3))
            {
                <div class="mesh-search-show-more">
                    <button type="button" class="mesh-search-toggle-rows" @onclick="() => ToggleGroupExpanded(groupKey)">
                        Show less
                    </button>
                </div>
            }
        }
    };

    /// <summary>
    /// Renders a sub-namespace as a modern folder tile. The PRIMARY click navigates
    /// to the folder's default page <c>/{folderPath}</c> (empty area) so drilling
    /// expands the URL; when a drill-down area is set, a secondary "Drill down" anchor
    /// re-roots the Search/catalog area at <c>/{folderPath}/{BoundDrillDownArea}</c>.
    /// </summary>
    private RenderFragment RenderFolderTile(NamespaceTreeFolder folder, string countLabel, bool showCounts) => __builder =>
    {
        var folderPath = folder.Path;
        var drillArea = BoundDrillDownArea;

        // Avoid nested anchors: the tile body is a full-cover primary anchor; the
        // secondary "Drill down" anchor is a SIBLING positioned over the top-right.
        <div class="mesh-search-folder-tile">
            <a class="mesh-search-folder-tile-link" href="/@folderPath" title="Open @folder.Name">
                <span class="mesh-search-folder-tile-icon">
                    <svg width="22" height="22" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M2 5a1.5 1.5 0 0 1 1.5-1.5h3.2l1.5 1.7H16.5A1.5 1.5 0 0 1 18 6.7V15a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 2 15V5Z"
                              fill="currentColor" fill-opacity="0.14" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span class="mesh-search-folder-tile-text">
                    <span class="mesh-search-folder-tile-name">@folder.Name</span>
                    @if (showCounts)
                    {
                        <span class="mesh-search-folder-tile-count">@countLabel</span>
                    }
                </span>
            </a>
            @if (!string.IsNullOrEmpty(drillArea))
            {
                <a class="mesh-search-drilldown mesh-search-folder-drilldown"
                   href="/@folderPath/@drillArea" title="Drill down"
                   @onclick:stopPropagation="true">
                    @DrillDownIcon
                </a>
            }
        </div>
    };

    // ----- Graph navigator rendering (MeshSearchRenderMode.GraphNavigator) -----

    /// <summary>Small "open ↗" glyph for the secondary "open the node's page" affordance.</summary>
    private static readonly MarkupString OpenIcon = (MarkupString)(
        "<svg width=\"14\" height=\"14\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">" +
        "<path d=\"M6 3.5h6.5V10M12.5 3.5 4 12\" stroke=\"currentColor\" stroke-width=\"1.3\" " +
        "stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>");

    /// <summary>Folder glyph for a sub-namespace drill link.</summary>
    private static readonly MarkupString FolderIcon = (MarkupString)(
        "<svg width=\"16\" height=\"16\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">" +
        "<path d=\"M2 5a1.5 1.5 0 0 1 1.5-1.5h3.2l1.5 1.7H16.5A1.5 1.5 0 0 1 18 6.7V15a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 2 15V5Z\" " +
        "fill=\"currentColor\" fill-opacity=\"0.14\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linejoin=\"round\"/></svg>");

    /// <summary>
    /// Renders the navigator for the Search layout area on a mesh node: the ancestor breadcrumb rail
    /// ABOVE, an "include documents" toggle, the mesh NODES at this level as cards (TOP — a node that
    /// also contains content gets a "drill in" symbol), and the sub-NAMESPACES (no node of their own)
    /// as drill-down links (BOTTOM — visually distinct from node cards). Clicking a namespace, an
    /// ancestor, or a node's drill symbol re-roots the navigator at that path and recomputes.
    /// </summary>
    private RenderFragment RenderGraphNavigator() => __builder =>
    {
        if (_navLoading && _navModel is null)
        {
            @RenderTreeLoading()
            return;
        }

        var model = _navModel;
        var navArea = NavArea;
        var nodes = NavNodes;
        var namespaces = NavNamespaces;

        <div class="mesh-nav">
            <nav class="mesh-nav-rail" aria-label="Ancestors">
                @if (model is not null)
                {
                    @foreach (var ancestor in model.Ancestors)
                    {
                        <a class="mesh-nav-crumb" href="/@ancestor.Path/@navArea"
                           title="@(ancestor.Name ?? ancestor.Id)">@(ancestor.Name ?? ancestor.Id)</a>
                        <span class="mesh-nav-sep" aria-hidden="true">/</span>
                    }
                }
                <span class="mesh-nav-crumb mesh-nav-crumb-current">@NavCurrentName</span>
                @if (!string.IsNullOrEmpty(NavRootPath))
                {
                    <a class="mesh-nav-open" href="/@NavRootPath" title="Open @NavCurrentName">@OpenIcon</a>
                }
            </nav>

            <label class="mesh-nav-doctoggle" title="Show indexed content (Document nodes) in this view">
                <input type="checkbox" checked="@_includeDocuments" @onchange="ToggleIncludeDocuments" />
                <span>Include documents</span>
            </label>

            @* TOP: the mesh nodes at this level. *@
            @if (nodes.Count > 0)
            {
                <div class="mesh-nav-section">
                    <div class="mesh-nav-section-label">Nodes</div>
                    <div class="mesh-search-area-grid" style="@CardGridStyle">
                        @foreach (var item in nodes)
                        {
                            @RenderNavNode(item)
                        }
                    </div>
                </div>
            }

            @* BOTTOM: sub-namespaces to drill into — distinct link styling, not node cards. *@
            @if (namespaces.Count > 0)
            {
                <div class="mesh-nav-section">
                    <div class="mesh-nav-section-label">Namespaces</div>
                    <div class="mesh-nav-namespaces">
                        @foreach (var ns in namespaces)
                        {
                            <a class="mesh-nav-namespace" href="/@ns.Path/@navArea" title="Drill into @ns.Name">
                                <span class="mesh-nav-namespace-icon">@FolderIcon</span>
                                <span class="mesh-nav-namespace-name">@ns.Name</span>
                                <span class="mesh-nav-namespace-count">@ns.Count</span>
                                <span class="mesh-nav-namespace-chevron" aria-hidden="true">&#8250;</span>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (nodes.Count == 0 && namespaces.Count == 0 && BoundShowEmptyMessage)
            {
                <div class="mesh-nav-empty">
                    <FluentLabel Typo="Microsoft.FluentUI.AspNetCore.Components.Typography.Body"
                                 Style="color: var(--neutral-foreground-hint);">
                        Nothing below this node.
                    </FluentLabel>
                </div>
            }
        </div>
    };

    /// <summary>
    /// One node at the current level (TOP). The card opens the node; when the node ALSO has content
    /// inside its namespace (<see cref="GraphNavNode.HasChildren"/>) a "drill in" symbol re-roots the
    /// navigator at that node. <c>DisableNavigation</c> stops the inner card from emitting its own
    /// anchor (no nesting).
    /// </summary>
    private RenderFragment RenderNavNode(GraphNavNode item) => __builder =>
    {
        var node = item.Node;
        var navArea = NavArea;
        var cardControl = MeshNodeCardControl.FromNode(node, node.Path, BoundItemArea, true);
        <div class="mesh-nav-card-wrap">
            <a class="mesh-nav-card-link" href="/@node.Path" title="Open @(node.Name ?? node.Id)">
                <MeshNodeCardView ViewModel="@cardControl" Stream="@Stream" Area="@($"nav-{node.Path}")" />
            </a>
            @if (item.HasChildren)
            {
                <a class="mesh-search-drilldown mesh-nav-card-drill" href="/@node.Path/@navArea"
                   title="Drill into @(node.Name ?? node.Id) (@item.ChildCount)" @onclick:stopPropagation="true">
                    @DrillDownIcon
                </a>
            }
        </div>
    };
}
