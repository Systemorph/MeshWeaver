@using MeshWeaver.Blazor
@using MeshWeaver.Blazor.Components.Monaco
@using MeshWeaver.Layout
@using MeshWeaver.Layout.Catalog
@using MeshWeaver.Layout.Client
@using MeshWeaver.Data
@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Services
@using System.Text.Json
@using System.Reactive.Linq
@using Microsoft.FluentUI.AspNetCore.Components
@implements IDisposable
@inject NavigationManager NavigationManager
@inject IMeshQuery MeshQuery

<div class="mesh-search-container" style="width: 100%;">
    @if (BoundShowSearchBox)
    {
        <div class="mesh-search-box" style="margin-bottom: 16px; width: 100%;">
            <div style="display: flex; gap: 8px; align-items: center; width: 100%;">
                <div style="flex: 1;">
                    <MonacoEditorView @ref="monacoEditor"
                                      Value="@_currentValue"
                                      ValueChanged="@OnValueChanged"
                                      OnSubmit="HandleSearch"
                                      Placeholder="@BoundPlaceholder"
                                      Height="38px"
                                      MaxHeight="38px"
                                      ShowBorder="true"
                                      CodeEditMode="false"
                                      AsyncCompletionCallback="@GetCompletionsAsync" />
                </div>
                <button type="button" @onclick="HandleSearch"
                    style="padding: 8px 16px; background: var(--accent-fill-rest, #0078d4); color: var(--foreground-on-accent-rest, white); border: none; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 500; height: 38px;">
                    Search
                </button>
            </div>
        </div>
    }

    <div class="mesh-search-results" style="width: 100%;">
        @if (_isLoading)
        {
            <FluentProgressRing />
        }
        else if (!HasResults())
        {
            <FluentLabel Typo="Microsoft.FluentUI.AspNetCore.Components.Typography.Body" Style="color: var(--neutral-foreground-hint);">No items found.</FluentLabel>
        }
        else
        {
            @RenderGroupedResults()
        }
    </div>
</div>

@code {
    private MonacoEditorView? monacoEditor;
    private string _currentValue = "";
    private bool _initialized;
    private bool _isLoading = true;
    private List<MeshNode> _nodes = new();
    private GroupedSearchResult? _computedGroups;
    private IDisposable? _reactiveSubscription;
    private HashSet<string> _collapsedGroups = new();

    [Parameter]
    public MeshSearchControl? ViewModel { get; set; }

    [Parameter]
    public ISynchronizationStream<JsonElement>? Stream { get; set; }

    [Parameter]
    public string? Area { get; set; }

    // Basic properties
    private string BoundHiddenQuery => ViewModel?.HiddenQuery?.ToString() ?? "";
    private string BoundVisibleQuery => ViewModel?.VisibleQuery?.ToString() ?? "";
    private string BoundPlaceholder => ViewModel?.Placeholder?.ToString() ?? "Search...";
    private string BoundNamespace => ViewModel?.Namespace?.ToString() ?? "";
    private int BoundMaxColumns => ViewModel?.MaxColumns is int cols ? cols : 3;
    private bool BoundShowSearchBox => ViewModel?.ShowSearchBox is bool show ? show : true;
    private bool BoundExcludeBasePath => ViewModel?.ExcludeBasePath is bool exclude ? exclude : true;
    private bool BoundLiveSearch => ViewModel?.LiveSearch is bool live ? live : true;
    private bool BoundReactiveMode => ViewModel?.ReactiveMode is bool reactive && reactive;
    private MeshSearchRenderMode BoundRenderMode => ViewModel?.RenderMode is MeshSearchRenderMode mode ? mode : MeshSearchRenderMode.Grouped;

    // Config objects
    private SectionConfig? BoundSections => ViewModel?.Sections;
    private GridConfig BoundGrid => ViewModel?.Grid ?? new GridConfig();

    // Pre-computed groups (from ViewModel or computed locally)
    private GroupedSearchResult? BoundPrecomputedGroups => ViewModel?.PrecomputedGroups;

    private bool HasResults()
    {
        if (BoundPrecomputedGroups != null)
            return BoundPrecomputedGroups.TotalItems > 0;
        return _nodes.Count > 0;
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        if (!_initialized && !string.IsNullOrEmpty(BoundVisibleQuery))
        {
            _currentValue = BoundVisibleQuery;
        }

        // Initialize collapsed state from pre-computed groups
        if (BoundPrecomputedGroups != null && !_initialized)
        {
            foreach (var group in BoundPrecomputedGroups.Groups.Where(g => !g.IsExpanded))
            {
                _collapsedGroups.Add(group.GroupKey);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _initialized = true;
            if (monacoEditor != null && !string.IsNullOrEmpty(BoundVisibleQuery))
            {
                await monacoEditor.SetValueAsync(BoundVisibleQuery);
            }

            // If we have pre-computed groups, no need to fetch
            if (BoundPrecomputedGroups != null)
            {
                _isLoading = false;
                StateHasChanged();
                return;
            }

            if (BoundReactiveMode)
            {
                SetupReactiveSubscription();
            }
            else
            {
                await LoadResultsAsync();
            }
            StateHasChanged();
        }
    }

    private void SetupReactiveSubscription()
    {
        _reactiveSubscription?.Dispose();
        var query = BuildFullQuery();

        _reactiveSubscription = MeshQuery.ObserveQuery<MeshNode>(MeshQueryRequest.FromQuery(query))
            .Subscribe(change =>
            {
                _nodes = ApplyChangesToList(_nodes, change);

                // Apply exclusion filter
                if (BoundExcludeBasePath && !string.IsNullOrEmpty(BoundNamespace))
                {
                    var basePath = BoundNamespace.Trim('/');
                    _nodes = _nodes.Where(n => n.Path != basePath).ToList();
                }

                // Compute groups using extension method
                if (ViewModel != null)
                {
                    _computedGroups = ViewModel.ProcessResults(_nodes);
                    InitializeCollapsedState(_computedGroups);
                }

                _isLoading = false;
                InvokeAsync(StateHasChanged);
            });
    }

    private List<MeshNode> ApplyChangesToList(List<MeshNode> current, QueryResultChange<MeshNode> change)
    {
        if (change.ChangeType == QueryChangeType.Initial || change.ChangeType == QueryChangeType.Reset)
        {
            return change.Items.ToList();
        }

        var result = new List<MeshNode>(current);
        foreach (var item in change.Items)
        {
            if (change.ChangeType == QueryChangeType.Removed)
            {
                result.RemoveAll(n => n.Path == item.Path);
            }
            else
            {
                var existingIndex = result.FindIndex(n => n.Path == item.Path);
                if (existingIndex >= 0)
                    result[existingIndex] = item;
                else
                    result.Add(item);
            }
        }
        return result;
    }

    private Task OnValueChanged(string value)
    {
        _currentValue = value;
        if (BoundLiveSearch)
        {
            if (BoundReactiveMode)
            {
                SetupReactiveSubscription();
            }
            else
            {
                _ = LoadResultsAsync();
            }
        }
        return Task.CompletedTask;
    }

    private async Task HandleSearch()
    {
        if (monacoEditor != null)
        {
            _currentValue = await monacoEditor.GetValueAsync();
        }

        if (BoundReactiveMode)
        {
            SetupReactiveSubscription();
        }
        else
        {
            await LoadResultsAsync();
        }
    }

    private async Task LoadResultsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var query = BuildFullQuery();
            _nodes = await MeshQuery.QueryAsync<MeshNode>(query).ToListAsync();

            // Exclude base path node if configured
            if (BoundExcludeBasePath && !string.IsNullOrEmpty(BoundNamespace))
            {
                var basePath = BoundNamespace.Trim('/');
                _nodes = _nodes.Where(n => n.Path != basePath).ToList();
            }

            // Compute groups using extension method
            if (ViewModel != null)
            {
                _computedGroups = ViewModel.ProcessResults(_nodes);
                InitializeCollapsedState(_computedGroups);
            }
        }
        catch
        {
            _nodes = new List<MeshNode>();
            _computedGroups = null;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void InitializeCollapsedState(GroupedSearchResult? groups)
    {
        if (groups == null || _initialized) return;

        foreach (var group in groups.Groups.Where(g => !g.IsExpanded))
        {
            _collapsedGroups.Add(group.GroupKey);
        }
    }

    private string BuildFullQuery()
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(BoundHiddenQuery))
            parts.Add(BoundHiddenQuery);

        if (!string.IsNullOrWhiteSpace(_currentValue))
            parts.Add(_currentValue.Trim());

        return string.Join(" ", parts);
    }

    private async Task<CompletionItem[]> GetCompletionsAsync(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
            return [];

        try
        {
            var searchQuery = string.IsNullOrEmpty(BoundNamespace)
                ? $"*{query}* scope:descendants"
                : $"namespace:{BoundNamespace} *{query}* scope:descendants";

            var request = new MeshQueryRequest { Query = searchQuery, Limit = 10 };
            var results = await MeshQuery.QueryAsync<MeshNode>(request).ToArrayAsync();

            return results.Select(node => new CompletionItem
            {
                Label = node.Name ?? node.Id,
                InsertText = node.Name ?? node.Id,
                Description = node.Description ?? "",
                Path = node.Path,
                Category = node.Category ?? ""
            }).ToArray();
        }
        catch
        {
            return [];
        }
    }

    /// <summary>
    /// Gets the groups to render, preferring pre-computed over locally computed.
    /// </summary>
    private IReadOnlyList<SearchResultGroup> GetGroups()
    {
        // Prefer pre-computed groups from ViewModel
        if (BoundPrecomputedGroups != null)
            return BoundPrecomputedGroups.Groups;

        // Fall back to locally computed groups
        return _computedGroups?.Groups ?? [];
    }

    /// <summary>
    /// Renders grouped results using SearchResultGroup.
    /// </summary>
    private RenderFragment RenderGroupedResults() => builder =>
    {
        var groups = GetGroups();
        var seq = 0;

        // Skip headers entirely if there's only one group (cleaner single-category display)
        var skipHeaders = groups.Count == 1;

        foreach (var group in groups)
        {
            var isCollapsed = _collapsedGroups.Contains(group.GroupKey);
            var showCollapsible = (BoundSections?.Collapsible ?? true) && !skipHeaders;
            var showCounts = BoundSections?.ShowCounts ?? true;

            // Section header - use TotalCount for accurate count display
            var headerLabel = showCounts ? $"{group.Label} ({group.TotalCount})" : group.Label;

            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "style", "margin-bottom: 24px;");

            // Header with collapse toggle - skip if only one group
            if (!skipHeaders)
            {
                if (showCollapsible)
                {
                    builder.OpenElement(seq++, "div");
                    builder.AddAttribute(seq++, "style", "display: flex; align-items: center; gap: 8px; cursor: pointer; padding: 10px 14px; background: var(--neutral-layer-2); border-radius: 6px; margin-bottom: 8px;");
                    var groupKey = group.GroupKey;
                    builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => ToggleGroup(groupKey)));

                    // Collapse icon
                    builder.OpenElement(seq++, "span");
                    builder.AddAttribute(seq++, "style", $"transition: transform 0.2s; transform: rotate({(isCollapsed ? "0" : "90")}deg);");
                    builder.AddContent(seq++, "▶");
                    builder.CloseElement();

                    // Label
                    builder.OpenElement(seq++, "span");
                    builder.AddAttribute(seq++, "style", "font-weight: 600; font-size: 1.1rem;");
                    builder.AddContent(seq++, headerLabel);
                    builder.CloseElement();

                    builder.CloseElement(); // header div
                }
                else
                {
                    builder.OpenElement(seq++, "h3");
                    builder.AddAttribute(seq++, "style", "margin: 24px 0 12px 0;");
                    builder.AddContent(seq++, headerLabel);
                    builder.CloseElement();
                }
            }

            // Content (items grid)
            if (!isCollapsed)
            {
                // Items are already limited in SearchResultGroup
                builder.OpenComponent<FluentGrid>(seq++);
                builder.AddAttribute(seq++, "Spacing", BoundGrid.Spacing);
                builder.AddAttribute(seq++, "Justify", Microsoft.FluentUI.AspNetCore.Components.JustifyContent.FlexStart);
                builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(gridBuilder =>
                {
                    var gridSeq = 0;

                    foreach (var item in group.Items)
                    {
                        if (item is not MeshNode node) continue;

                        gridBuilder.OpenComponent<FluentGridItem>(gridSeq++);
                        // Use same breakpoints as original MeshNodeView.Children: xs=12, sm=6, md=4, lg=4
                        gridBuilder.AddAttribute(gridSeq++, "xs", BoundGrid.Xs);
                        gridBuilder.AddAttribute(gridSeq++, "sm", BoundGrid.Sm);
                        gridBuilder.AddAttribute(gridSeq++, "md", BoundGrid.Md);
                        gridBuilder.AddAttribute(gridSeq++, "lg", BoundGrid.Lg);
                        gridBuilder.AddAttribute(gridSeq++, "ChildContent", (RenderFragment)(itemBuilder =>
                        {
                            RenderNodeCard(itemBuilder, node);
                        }));
                        gridBuilder.CloseComponent();
                    }
                }));
                builder.CloseComponent();

                // Show more button if items were limited
                if (group.Items.Count < group.TotalCount)
                {
                    var showMoreHref = ViewModel?.GetShowMoreHref(group.GroupKey);
                    if (!string.IsNullOrEmpty(showMoreHref))
                    {
                        builder.OpenElement(seq++, "div");
                        builder.AddAttribute(seq++, "style", "margin-top: 8px;");
                        builder.OpenElement(seq++, "a");
                        builder.AddAttribute(seq++, "href", showMoreHref);
                        builder.AddAttribute(seq++, "style", "color: var(--accent-fill-rest); text-decoration: none; font-weight: 500;");
                        builder.AddContent(seq++, $"Show all {group.TotalCount} →");
                        builder.CloseElement();
                        builder.CloseElement();
                    }
                }
            } // end if (!isCollapsed)

            builder.CloseElement(); // section div
        }
    };

    private void ToggleGroup(string groupKey)
    {
        if (_collapsedGroups.Contains(groupKey))
            _collapsedGroups.Remove(groupKey);
        else
            _collapsedGroups.Add(groupKey);
        StateHasChanged();
    }

    private void RenderNodeCard(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder, MeshNode node)
    {
        var seq = 0;

        if (BoundRenderMode == MeshSearchRenderMode.Hierarchical)
        {
            RenderNodeTree(builder, node, 0, ref seq);
        }
        else
        {
            RenderThumbnailCard(builder, node, ref seq);
        }
    }

    private void RenderNodeTree(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder, MeshNode node, int indentLevel, ref int seq)
    {
        var marginLeft = indentLevel * 20;

        // Container for this node and its children
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "style", $"margin-left: {marginLeft}px; width: 100%;");

        // Render the thumbnail for this node
        RenderThumbnailCard(builder, node, ref seq);

        // Render children recursively
        var children = FindDirectChildren(node);
        foreach (var child in children)
        {
            RenderNodeTree(builder, child, indentLevel + 1, ref seq);
        }

        builder.CloseElement();
    }

    private void RenderThumbnailCard(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder, MeshNode node, ref int seq)
    {
        var imageUrl = GetImageUrl(node);
        var title = node.Name ?? node.Id;
        var description = node.Description ?? "";
        var initial = !string.IsNullOrEmpty(title) ? title[0].ToString().ToUpper() : "?";

        // Match the min-width from MeshNodeThumbnailView.razor (320px)
        var cardStyle = "min-width: 320px; cursor: pointer; margin: 8px;";

        builder.OpenComponent<FluentCard>(seq++);
        builder.AddAttribute(seq++, "Class", "mesh-search-card");
        builder.AddAttribute(seq++, "Style", cardStyle);
        builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => NavigateTo(node.Path)));
        builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(cardBuilder =>
        {
            var cardSeq = 0;
            cardBuilder.OpenElement(cardSeq++, "div");
            cardBuilder.AddAttribute(cardSeq++, "style", "display: flex; align-items: center; gap: 12px; padding: 8px;");

            // Image or initial
            if (!string.IsNullOrEmpty(imageUrl))
            {
                cardBuilder.OpenElement(cardSeq++, "img");
                cardBuilder.AddAttribute(cardSeq++, "src", imageUrl);
                cardBuilder.AddAttribute(cardSeq++, "alt", title);
                cardBuilder.AddAttribute(cardSeq++, "style", "width: 40px; height: 40px; border-radius: 6px; object-fit: cover; flex-shrink: 0;");
                cardBuilder.CloseElement();
            }
            else
            {
                cardBuilder.OpenElement(cardSeq++, "div");
                cardBuilder.AddAttribute(cardSeq++, "style", "width: 40px; height: 40px; border-radius: 6px; background: var(--accent-fill-rest, #0078d4); color: var(--foreground-on-accent-rest, white); display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 16px; flex-shrink: 0;");
                cardBuilder.AddContent(cardSeq++, initial);
                cardBuilder.CloseElement();
            }

            // Text content
            cardBuilder.OpenElement(cardSeq++, "div");
            cardBuilder.AddAttribute(cardSeq++, "style", "flex: 1; min-width: 0;");

            cardBuilder.OpenElement(cardSeq++, "div");
            cardBuilder.AddAttribute(cardSeq++, "style", "font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;");
            cardBuilder.AddContent(cardSeq++, title);
            cardBuilder.CloseElement();

            if (!string.IsNullOrEmpty(description))
            {
                cardBuilder.OpenElement(cardSeq++, "div");
                cardBuilder.AddAttribute(cardSeq++, "style", "font-size: 12px; color: var(--neutral-foreground-hint, #666); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;");
                cardBuilder.AddContent(cardSeq++, Truncate(description, 50));
                cardBuilder.CloseElement();
            }

            cardBuilder.CloseElement();
            cardBuilder.CloseElement();
        }));
        builder.CloseComponent();
    }

    private void NavigateTo(string path)
    {
        NavigationManager.NavigateTo($"/{path}");
    }

    private bool HasParentInSet(string path, HashSet<string> allPaths)
    {
        var pathNormalized = path.Trim('/');
        var lastSlash = pathNormalized.LastIndexOf('/');
        while (lastSlash > 0)
        {
            var parentPath = pathNormalized.Substring(0, lastSlash);
            if (allPaths.Contains(parentPath))
                return true;
            lastSlash = parentPath.LastIndexOf('/');
        }
        return false;
    }

    private List<MeshNode> FindDirectChildren(MeshNode parent)
    {
        var parentPath = parent.Path + "/";
        var allPaths = _nodes.Select(n => n.Path).ToHashSet();

        return _nodes
            .Where(n => n.Path.StartsWith(parentPath) && !HasIntermediateParent(n.Path, parent.Path, allPaths))
            .ToList();
    }

    private bool HasIntermediateParent(string childPath, string parentPath, HashSet<string> allPaths)
    {
        var childNormalized = childPath.Trim('/');
        var parentNormalized = parentPath.Trim('/');

        var lastSlash = childNormalized.LastIndexOf('/');
        while (lastSlash > parentNormalized.Length)
        {
            var intermediatePath = childNormalized.Substring(0, lastSlash);
            if (allPaths.Contains(intermediatePath))
                return true;
            lastSlash = intermediatePath.LastIndexOf('/');
        }
        return false;
    }

    private string? GetImageUrl(MeshNode node)
    {
        if (node.Content is System.Text.Json.JsonElement json)
        {
            if (json.TryGetProperty("avatar", out var avatar) && avatar.ValueKind == System.Text.Json.JsonValueKind.String)
                return avatar.GetString();
            if (json.TryGetProperty("Avatar", out var Avatar) && Avatar.ValueKind == System.Text.Json.JsonValueKind.String)
                return Avatar.GetString();
            if (json.TryGetProperty("logo", out var logo) && logo.ValueKind == System.Text.Json.JsonValueKind.String)
                return logo.GetString();
            if (json.TryGetProperty("Logo", out var Logo) && Logo.ValueKind == System.Text.Json.JsonValueKind.String)
                return Logo.GetString();
        }
        return node.Icon;
    }

    private string Truncate(string text, int maxLength)
    {
        return text.Length > maxLength ? text.Substring(0, maxLength - 3) + "..." : text;
    }

    public void Dispose()
    {
        _reactiveSubscription?.Dispose();
    }
}
