@using MeshWeaver.Blazor.Components.Monaco
@using MeshWeaver.Graph
@using MeshWeaver.Layout
@using MeshWeaver.Mesh
@using Microsoft.FluentUI.AspNetCore.Components

<div class="mesh-search-container">
    @if (BoundShowSearchBox)
    {
        <div class="mesh-search-box">
            <div class="mesh-search-box-inner">
                <div class="mesh-search-box-input">
                    <MonacoEditorView @ref="monacoEditor"
                                      Value="@_currentValue"
                                      ValueChanged="@OnValueChanged"
                                      OnSubmit="HandleSearch"
                                      Placeholder="@BoundPlaceholder"
                                      Height="38px"
                                      MaxHeight="38px"
                                      ShowBorder="true"
                                      CodeEditMode="false"
                                      AsyncCompletionCallback="@GetCompletionsAsync" />
                </div>
                <button type="button" class="mesh-search-button" @onclick="HandleSearch">
                    Search
                </button>
                @if (ShowCreateButton)
                {
                    <button type="button" class="mesh-search-create-button" @onclick="HandleCreateClick"
                            title="Create new">
                        +
                    </button>
                }
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(BoundCreateNodeType))
    {
        <div class="mesh-search-box">
            <div class="mesh-search-box-inner" style="justify-content: flex-end;">
                <button type="button" class="mesh-search-create-button" @onclick="HandleCreateClick"
                        title="Create new">
                    +
                </button>
            </div>
        </div>
    }

    <div class="mesh-search-results">
        @if (_isLoading && !IsPrecomputedMode && BoundShowLoadingIndicator)
        {
            <div class="mesh-search-area-grid">
                @for (var i = 0; i < 3; i++)
                {
                    <FluentCard Class="mesh-search-card">
                        <div class="mesh-search-card-content">
                            <div class="mesh-search-skeleton-avatar"></div>
                            <div class="mesh-search-card-text">
                                <div class="mesh-search-skeleton-line" style="width: 60%;"></div>
                                <div class="mesh-search-skeleton-line" style="width: 40%;"></div>
                            </div>
                        </div>
                    </FluentCard>
                }
            </div>
        }
        else if (!HasResults() && BoundShowEmptyMessage)
        {
            <FluentLabel Typo="Microsoft.FluentUI.AspNetCore.Components.Typography.Body" Style="color: var(--neutral-foreground-hint);">No items found.</FluentLabel>
        }
        else
        {
            var groups = GetGroups();
            var skipHeaders = groups.Count == 1;

            @foreach (var group in groups)
            {
                var isCollapsed = _collapsedGroups.Contains(group.GroupKey);
                var showCollapsible = (BoundSections?.Collapsible ?? true) && !skipHeaders;
                var showCounts = BoundSections?.ShowCounts ?? true;
                var headerLabel = showCounts ? $"{group.Label} ({group.TotalCount})" : group.Label;
                var groupKey = group.GroupKey;

                <div class="mesh-search-section">
                    @if (!skipHeaders)
                    {
                        @if (showCollapsible)
                        {
                            <div class="mesh-search-section-header" @onclick="() => ToggleGroup(groupKey)">
                                <span class="@(isCollapsed ? "mesh-search-collapse-icon" : "mesh-search-collapse-icon expanded")">&#x25b6;</span>
                                <span class="mesh-search-section-label">@headerLabel</span>
                            </div>
                        }
                        else
                        {
                            <h3 class="mesh-search-section-title">@headerLabel</h3>
                        }
                    }

                    @if (!isCollapsed)
                    {
                        <div class="mesh-search-grid-wrapper">
                            @if (!string.IsNullOrEmpty(BoundItemArea))
                            {
                                <div class="mesh-search-area-grid" style="@AreaGridStyle">
                                    @foreach (var item in group.Items)
                                    {
                                        if (item is MeshNode node)
                                        {
                                            @RenderCard(node)
                                        }
                                    }
                                </div>
                            }
                            else
                            {
                                <FluentGrid Spacing="@BoundGrid.Spacing" Justify="Microsoft.FluentUI.AspNetCore.Components.JustifyContent.FlexStart" Style="width: 100%;">
                                    @foreach (var item in group.Items)
                                    {
                                        if (item is MeshNode node)
                                        {
                                            <FluentGridItem xs="@BoundGrid.Xs" sm="@BoundGrid.Sm" md="@BoundGrid.Md" lg="@BoundGrid.Lg" Style="width: 100%;">
                                                @RenderCard(node)
                                            </FluentGridItem>
                                        }
                                    }
                                </FluentGrid>
                            }
                        </div>

                        @if (group.Items.Count < group.TotalCount)
                        {
                            <div class="mesh-search-show-more">
                                <span style="color: var(--neutral-foreground-hint);">Showing @group.Items.Count of @group.TotalCount</span>
                            </div>
                        }
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    private RenderFragment RenderCard(MeshNode node) => __builder =>
    {
        var cardControl = GetCardControl(node);

        if (OnNodeSelected.HasDelegate)
        {
            <div style="cursor: pointer;" @onclick="() => OnNodeSelected.InvokeAsync(node)">
                <MeshNodeCardView ViewModel="@cardControl" Stream="@Stream" Area="@($"search-{node.Path}")" />
            </div>
        }
        else
        {
            <MeshNodeCardView ViewModel="@cardControl" Stream="@Stream" Area="@($"search-{node.Path}")" />
        }
    };
}
