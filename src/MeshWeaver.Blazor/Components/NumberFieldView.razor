@inherits FormComponentBase<NumberFieldControl, NumberFieldView<TValue>, TValue>

@using Microsoft.AspNetCore.Components.Forms
@typeparam TValue

@* Single wrapping container so Label + input share the same width/height.
   Width/Height come from data binding (ViewModel.Width / ViewModel.Height). *@
<div style="display: inline-flex; flex-direction: column; @ComputedStyle">

@if (!string.IsNullOrEmpty(Label))
{
    <label style="
        display: block;
        font-size: var(--type-ramp-minus-1-font-size);
        line-height: var(--type-ramp-minus-1-line-height);
        margin-bottom: 4px;
        color: var(--neutral-foreground-rest);
        cursor: pointer;
    ">@Label</label>
}

<div class="root" part="root" style="
    display: flex;
    align-items: center;
    position: relative;
    width: 100%;
    background: var(--neutral-fill-input-rest);
    border: calc(var(--stroke-width) * 1px) solid var(--neutral-stroke-rest);
    border-radius: calc(var(--control-corner-radius) * 1px);
    height: calc((var(--base-height-multiplier) + var(--density)) * var(--design-unit) * 1px);
">
    <span part="start">
        <slot name="start">
            @if (IconStart is not null)
            {
                <FluentIcon Value="@IconStart.ToFluentIcon()" class="icon-start" />
            }
        </slot>
    </span>

    @{
        var appearanceClass = $"control {Appearance.ToString().ToLower()}-appearance";

        // Match the FluentUI design system's ComboBox styling.
        // Width/min-width are NOT hard-coded — size is controlled by the consumer
        // via Style on the NumberFieldControl (or by the parent container).
        var inputStyle = @"
        background: transparent;
        border: none;
        box-shadow: none;
        outline: none;
        width: 100%;
        padding: 0 calc((10 + (var(--design-unit) * 2 * var(--density))) * 1px);
        height: calc((var(--base-height-multiplier) + var(--density)) * var(--design-unit) * 1px);
        ";
    }

    <InputNumber @bind-Value="Value"
                 id="control"
                 class="@appearanceClass"
                 part="control"
                 readonly="@Readonly"
                 disabled="@Disabled"
                 placeholder="@Placeholder"
                 step="@Step"
                 min="@Min"
                 max="@Max"
                 size="@Size"
                 style="@inputStyle"
                 aria-label="@(string.IsNullOrEmpty(Label) ? "Numeric input" : null)"
                 @onfocusout="OnBlur" />

    <span part="end">
        <slot name="end">
            @if (IconEnd is not null)
            {
                <FluentIcon Value="@IconEnd.ToFluentIcon()" class="icon-end" />
            }
        </slot>
    </span>
</div>

</div>