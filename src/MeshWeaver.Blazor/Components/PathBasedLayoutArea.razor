@using MeshWeaver.Layout
@using MeshWeaver.Mesh.Services
@inject IMeshCatalog MeshCatalog

@if (IsLoading)
{
    <div class="layout-area-loading" style="padding: 8px; color: #666;">Loading @Path...</div>
}
else if (ErrorMessage != null)
{
    <div class="layout-area-error" style="padding: 8px; color: #c00;">@ErrorMessage</div>
}
else if (ResolvedViewModel != null)
{
    <LayoutAreaView ViewModel="@ResolvedViewModel" />
}
else
{
    <div class="layout-area-error" style="padding: 8px; color: #c00;">Could not resolve path: @Path</div>
}

@code {
    [Parameter]
    public string? Path { get; set; }

    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private LayoutAreaControl? ResolvedViewModel { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Path))
        {
            IsLoading = false;
            ErrorMessage = "No path specified";
            return;
        }

        IsLoading = true;
        ErrorMessage = null;
        ResolvedViewModel = null;

        try
        {
            if (MeshCatalog == null)
            {
                ErrorMessage = "MeshCatalog service not available";
                return;
            }

            var resolution = await MeshCatalog.ResolvePathAsync(Path);
            if (resolution != null)
            {
                var (area, id) = ParseRemainder(resolution.Remainder);
                ResolvedViewModel = new LayoutAreaControl(
                    (Messaging.Address)resolution.Prefix,
                    new Data.LayoutAreaReference(area) { Id = id }
                )
                {
                    ShowProgress = true,
                    ProgressMessage = $"Loading {Path}..."
                };
            }
            else
            {
                ErrorMessage = $"Path not found: {Path}";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error resolving path: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static (string? Area, string? Id) ParseRemainder(string? remainder)
    {
        if (string.IsNullOrEmpty(remainder))
            return (null, null);

        var slashIndex = remainder.IndexOf('/');
        if (slashIndex >= 0)
            return (remainder.Substring(0, slashIndex), remainder.Substring(slashIndex + 1));

        return (remainder, null);
    }
}
