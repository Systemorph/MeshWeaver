@using SelectPosition = Microsoft.FluentUI.AspNetCore.Components.SelectPosition
@using MeshWeaver.Application.Styles
@using Icon = MeshWeaver.Domain.Icon
@inherits ListBase<SelectControl, SelectView>

@if (_hasIcons)
{
    <FluentSelect
        Label="@Label"
        Items="@Options"
        TOption="Option"
        OptionText="@(x => x.Text)"
        OptionValue="@(x => x.ItemString)"
        Position="@Position"
        Class="@Class"
        Style="@Style"
        @bind-SelectedOption="Value"
        @onfocusout="OnBlur">
        <OptionTemplate>
            <div style="display: flex; align-items: center; gap: 8px;">
                @if (!string.IsNullOrEmpty(context.Icon))
                {
                    @RenderIcon(context.Icon)
                }
                <span>@context.Text</span>
            </div>
        </OptionTemplate>
    </FluentSelect>
}
else
{
    <FluentSelect
        Label="@Label"
        Items="@Options"
        TOption="Option"
        OptionText="@(x => x.Text)"
        OptionValue="@(x => x.ItemString)"
        Position="@Position"
        Class="@Class"
        Style="@Style"
        @bind-SelectedOption="Value"
        @onfocusout="OnBlur"
    />
}

@code
{
    private SelectPosition? Position { get; set; }
    private bool _hasIcons;

    protected override void BindData()
    {
        base.BindData();
        DataBind(ViewModel.Position, x => x.Position);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        _hasIcons = Options?.Any(o => !string.IsNullOrEmpty(o.Icon)) ?? false;
    }

    private RenderFragment RenderIcon(string icon)
    {
        // Image URL or data URI
        if (icon.Contains('/') || icon.StartsWith("data:"))
            return @<img src="@icon" alt="" style="width: 20px; height: 20px;" />;

        // Try Fluent icon by name
        var fluentIcon = new Icon(FluentIcons.Provider, icon).ToFluentIcon();
        if (fluentIcon != null)
            return @<FluentIcon Value="@fluentIcon" Width="20px" />;

        // Fallback: render as text (emoji or other)
        return @<span style="font-size: 1.2em; line-height: 1;">@icon</span>;
    }
}
