@inherits InputBase<TextFieldControl,TextFieldView, string>

<FluentTextField
    @bind-Value="Value"
    TextFieldType="@(ViewModel.Password ? Microsoft.FluentUI.AspNetCore.Components.TextFieldType.Password : Microsoft.FluentUI.AspNetCore.Components.TextFieldType.Text)"
    Placeholder="@Placeholder"
    Label="@Label"
    Autofocus="@AutoFocus"
    Disabled="@Disabled"
    AutoComplete="@Autocomplete"
    Immediate="@Immediate"
    ImmediateDelay="@ImmediateDelay"
    Style="@ComputedStyle"
    Class="@Class"
    Readonly="@Readonly"
    Required="@Required"
    Size="@Size"
    MinLength="@MinLength"
    MaxLength="@MaxLength"
    @onfocusout="OnBlur">
    @if (IconStart is not null)
    {
        <FluentIcon Value="@IconStart.ToFluentIcon()" Slot="start" />
    }
    @if (IconEnd is not null)
    {
        <FluentIcon Value="@IconEnd.ToFluentIcon()" Slot="end" />
    }
</FluentTextField>

@code
{
    private string? Autocomplete { get; set; }

    protected override void BindData()
    {
        base.BindData();

        // Lowercase "off" — the HTML autocomplete keyword browsers honour (capital "Off" is ignored by
        // some, re-enabling autofill/suggestion popups over the field).
        DataBind(ViewModel.Autocomplete, x => x.Autocomplete, defaultValue:"off");
    }
}