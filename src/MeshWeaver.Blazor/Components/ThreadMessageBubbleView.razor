@inherits BlazorView<ThreadMessageBubbleControl, ThreadMessageBubbleView>
@using MeshWeaver.Layout

<div class="thread-msg-bubble @(IsUser ? "thread-msg-user" : "thread-msg-assistant") @(isExecuting ? "thread-msg-is-executing" : "")" style="@Style">
    <div class="thread-msg-author @(IsUser ? "thread-msg-author-user" : "")">@ViewModel.AuthorName</div>
    @if (!IsUser && (!string.IsNullOrEmpty(ViewModel.ModelName) || ViewModel.Timestamp.HasValue))
    {
        <div class="thread-msg-meta">
            @if (!string.IsNullOrEmpty(ViewModel.ModelName))
            {
                <span>@ViewModel.ModelName</span>
            }
            @if (ViewModel.Timestamp.HasValue)
            {
                <span>@ViewModel.Timestamp.Value.ToString("HH:mm:ss")</span>
            }
        </div>
    }

    @if (ShowSpinner)
    {
        <div class="thread-msg-spinner">
            <span class="thread-msg-dots">
                <span class="thread-msg-dot" style="animation-delay: 0s;"></span>
                <span class="thread-msg-dot" style="animation-delay: 0.2s;"></span>
                <span class="thread-msg-dot" style="animation-delay: 0.4s;"></span>
            </span>
            <span class="thread-msg-status">@StatusTitle</span>
        </div>
        @if (StatusDetail != null)
        {
            <pre class="thread-msg-status-detail">@StatusDetail</pre>
        }
        <div class="thread-msg-cancel-row">
            <button class="thread-msg-cancel-btn" @onclick="OnCancelClick">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854z"/></svg>
                Cancel
            </button>
        </div>
    }
    else
    {
        <MarkdownView ViewModel="@MarkdownVm" Stream="@Stream" Area="@($"{Area}/text")" />
    }

    @if (ShowExecutingIndicator)
    {
        <div class="thread-msg-executing-indicator">
            <span class="thread-msg-dots thread-msg-dots-small">
                <span class="thread-msg-dot-small"></span>
                <span class="thread-msg-dot-small" style="animation-delay: 0.2s;"></span>
                <span class="thread-msg-dot-small" style="animation-delay: 0.4s;"></span>
            </span>
            <span class="thread-msg-exec-status">@StatusTitle</span>
            <button class="thread-msg-cancel-btn-small" @onclick="OnCancelClick">Cancel</button>
        </div>
        @if (StatusDetail != null)
        {
            <pre class="thread-msg-status-detail thread-msg-status-detail-small">@StatusDetail</pre>
        }
    }

    @* Collapsible tool calls — shown during execution (open) and after (collapsed) *@
    @if (HasToolCalls)
    {
        <details class="thread-msg-tool-calls" open="@isExecuting">
            <summary class="thread-msg-tool-summary">
                <svg class="thread-msg-tool-icon" width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M5.5 0a.5.5 0 0 1 .5.5V2h4V.5a.5.5 0 0 1 1 0V2h1a2 2 0 0 1 2 2v1H2V4a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M2 7v7a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V7z"/></svg>
                @toolCalls!.Count tool call(s)
            </summary>
            <div class="thread-msg-tool-list">
                @foreach (var call in toolCalls!)
                {
                    <details class="thread-msg-tool-entry">
                        <summary class="thread-msg-tool-entry-name">
                            <span class="@(call.IsSuccess ? "" : "thread-msg-tool-error")">@(call.DisplayName ?? call.Name)</span>
                            @if (!string.IsNullOrEmpty(call.DelegationPath))
                            {
                                <a href="/@call.DelegationPath/Thread" class="thread-msg-delegation-link">View sub-thread</a>
                            }
                        </summary>
                        @if (!string.IsNullOrEmpty(call.Arguments))
                        {
                            <pre class="thread-msg-tool-args">@call.Arguments</pre>
                        }
                        @if (!string.IsNullOrEmpty(call.Result))
                        {
                            <pre class="thread-msg-tool-result">@call.Result</pre>
                        }
                    </details>
                }
            </div>
        </details>
    }
</div>

<style>
    .thread-msg-bubble {
        max-width: 100%;
        padding: 12px 16px;
        border-radius: 12px;
        color: var(--neutral-foreground-rest);
        margin-bottom: 12px;
        min-width: 0;
        overflow: hidden;
        overflow-wrap: break-word;
        word-break: break-word;
    }
    .thread-msg-user {
        background: var(--neutral-layer-4);
        border-inline-end: 3px solid var(--accent-fill-rest);
        border-bottom-right-radius: 4px;
    }
    .thread-msg-assistant {
        background: var(--neutral-layer-2);
        border-bottom-left-radius: 4px;
    }
    .thread-msg-author {
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 4px;
    }
    .thread-msg-author-user {
        color: var(--accent-fill-rest);
    }
    .thread-msg-meta {
        display: flex;
        gap: 8px;
        font-size: 0.72rem;
        color: var(--neutral-foreground-hint);
        margin-bottom: 4px;
    }

    .thread-msg-spinner {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 0;
    }
    .thread-msg-dots {
        display: inline-flex;
        gap: 4px;
    }
    .thread-msg-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--neutral-foreground-hint);
        animation: thread-dots-blink 1.4s infinite both;
    }
    .thread-msg-status {
        font-size: 0.85rem;
        color: var(--neutral-foreground-hint);
    }
    .thread-msg-cancel-row {
        display: flex;
        justify-content: flex-start;
        margin-top: 4px;
    }
    .thread-msg-cancel-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 12px;
        border: 1px solid var(--neutral-stroke-rest);
        border-radius: 6px;
        background: transparent;
        color: var(--neutral-foreground-rest);
        font-size: 0.8rem;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
    }
    .thread-msg-cancel-btn:hover {
        background: var(--neutral-layer-3);
        border-color: var(--neutral-foreground-hint);
    }

    .thread-msg-executing-indicator {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 4px;
        padding-top: 4px;
        border-top: 1px solid var(--neutral-stroke-rest);
    }
    .thread-msg-dots-small {
        display: inline-flex;
        gap: 3px;
    }
    .thread-msg-dot-small {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: var(--neutral-foreground-hint);
        animation: thread-dots-blink 1.4s infinite both;
    }
    .thread-msg-exec-status {
        font-size: 0.75rem;
        color: var(--neutral-foreground-hint);
        flex: 1;
    }
    .thread-msg-cancel-btn-small {
        padding: 2px 8px;
        border: 1px solid var(--neutral-stroke-rest);
        border-radius: 4px;
        background: transparent;
        color: var(--neutral-foreground-hint);
        font-size: 0.75rem;
        cursor: pointer;
        transition: background 0.15s;
    }
    .thread-msg-cancel-btn-small:hover {
        background: var(--neutral-layer-3);
    }

    /* Hide action row (edit/delete/resubmit) when bubble is executing */
    fluent-stack-item:has(.thread-msg-is-executing) ~ fluent-stack-item .thread-msg-actions {
        display: none;
    }

    /* Collapsible tool calls */
    .thread-msg-tool-calls {
        margin-top: 8px;
        padding-top: 8px;
        border-top: 1px solid var(--neutral-stroke-rest);
    }
    .thread-msg-tool-summary {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        color: var(--neutral-foreground-hint);
        cursor: pointer;
        user-select: none;
    }
    .thread-msg-tool-summary:hover {
        color: var(--neutral-foreground-rest);
    }
    .thread-msg-tool-icon {
        opacity: 0.6;
    }
    .thread-msg-tool-list {
        margin-top: 4px;
        padding-left: 4px;
    }
    .thread-msg-tool-entry {
        margin-bottom: 2px;
    }
    .thread-msg-tool-entry-name {
        font-size: 0.78rem;
        color: var(--neutral-foreground-hint);
        cursor: pointer;
        padding: 2px 0;
    }
    .thread-msg-tool-entry-name:hover {
        color: var(--neutral-foreground-rest);
    }
    .thread-msg-tool-error {
        color: var(--error);
    }
    .thread-msg-delegation-link {
        margin-left: 8px;
        font-size: 0.75rem;
        color: var(--accent-fill-rest);
        text-decoration: none;
    }
    .thread-msg-delegation-link:hover {
        text-decoration: underline;
    }
    .thread-msg-tool-args,
    .thread-msg-tool-result {
        font-size: 0.72rem;
        color: var(--neutral-foreground-hint);
        background: var(--neutral-layer-3);
        border-radius: 4px;
        padding: 6px 8px;
        margin: 2px 0;
        max-height: 120px;
        overflow: auto;
        white-space: pre-wrap;
        word-break: break-all;
    }

    .thread-msg-status-detail {
        font-size: 0.72rem;
        color: var(--neutral-foreground-hint);
        background: var(--neutral-layer-3);
        border-radius: 4px;
        padding: 6px 8px;
        margin: 4px 0;
        max-height: 150px;
        overflow: auto;
        white-space: pre-wrap;
        word-break: break-all;
        font-family: monospace;
    }
    .thread-msg-status-detail-small {
        font-size: 0.68rem;
        max-height: 80px;
        margin-top: 4px;
    }

    @@keyframes thread-dots-blink {
        0%, 80%, 100% { opacity: 0.3; }
        40% { opacity: 1; }
    }
</style>
