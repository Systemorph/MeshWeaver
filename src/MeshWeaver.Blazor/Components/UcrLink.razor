@using System.Reactive.Linq
@using MeshWeaver.Data
@using MeshWeaver.Graph
@using MeshWeaver.Mesh
@using MeshWeaver.Mesh.Services
@using MeshWeaver.Messaging
@inject IPathResolver PathResolver
@inject IMessageHub Hub

<a href="@Href" class="ucr-link" title="@Tooltip" data-raw-path="@Path">@DisplayText</a>

@code {
    [Parameter]
    public string? Path { get; set; }

    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string? DisplayText { get; set; }

    private string? Name { get; set; }

    private string Tooltip => !string.IsNullOrEmpty(Name)
        ? Name
        : Path ?? "";

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(Path)) return;

        // PathResolver is local — Observable.FromAsync is acceptable to bridge it
        // (no hub round-trip). Hub.GetMeshNode is composed via .SelectMany — never
        // awaited (100% deadlock; see Doc/Architecture/AsynchronousCalls.md).
        PathResolver.ResolvePath(Path)
            .Where(resolution => resolution != null)
            .SelectMany(resolution => Hub.GetMeshNode(resolution!.Prefix, TimeSpan.FromSeconds(5)))
            .Catch<MeshNode?, Exception>(_ => Observable.Return<MeshNode?>(null))
            .Subscribe(node =>
            {
                if (node != null)
                {
                    Name = node.Name;
                    InvokeAsync(StateHasChanged);
                }
            });
    }
}
