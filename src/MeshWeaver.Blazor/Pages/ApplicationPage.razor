@* Routes for application pages - entire path is matched against registered namespace patterns *@
@* The :nonfile constraint prevents matching static file paths like _content, _framework, etc. *@
@page "/{*Path:nonfile}"
@using MeshWeaver.Messaging

<FluentDesignTheme @bind-Mode="@Mode" StorageName="theme" />

<PageTitle>@PageTitle</PageTitle>
<CascadingValue Value="@Mode" Name="ThemeMode">
    @if (NavigationService.Context is null && (!IsInteractive || IsLoading))
    {
        @* Show spinner until interactive rendering is established and loading completes *@
        <div class="resolving-container">
            <div class="spinner"></div>
            <p>Looking up <strong>@Path</strong>...</p>
        </div>
    }
    else if (NavigationService.Context is null)
    {
        @* Only shown after OnAfterRender has fired and all resolution retries exhausted *@
        <div class="error-container">
            <h2>Page Not Found</h2>
            <p>The path '<strong>@Path</strong>' does not match any registered address pattern.</p>
            <p>Please double-check the url you have entered.</p>
        </div>
    }
    else if (!IsInteractive && PreRenderedHtml is not null)
    {
        @* Phase 1: Prerender with cached markdown HTML *@
        <article class="markdown-body" style="background-color: var(--neutral-layer-1)">
            @((MarkupString)PreRenderedHtml)
        </article>
    }
    else if (!IsInteractive)
    {
        @* Phase 1: No cached HTML - dots spinner with message *@
        <div class="resolving-container">
            <h3>Resolving @Path...</h3>
            <div class="dots-spinner">
                <span class="dot"></span><span class="dot"></span><span class="dot"></span>
            </div>
        </div>
    }
    else
    {
        @* Phase 2: Interactive - LayoutAreaView with stream subscription *@
        <LayoutAreaView ViewModel="@ViewModel" Top="true" />
    }
</CascadingValue>
