@* Content page routes:
   - /content/{**path} - handles both global and address-scoped content
   Uses IMeshCatalog.ResolvePathAsync to dynamically resolve address from path
*@
@page "/content/{**FullPath}"
@inject NavigationManager NavigationManager

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="error-container">
        <div style="padding: 1rem; background-color: #fef2f2; border: 1px solid #fecaca; border-radius: 0.375rem; margin-bottom: 1rem;">
            <div style="color: #991b1b; font-weight: 600;">Error</div>
            <div style="color: #dc2626;">@ErrorMessage</div>
        </div>
        <div class="error-content">
            <h1>Collection Not Found</h1>
            <p>The collection <strong>@ResolvedCollection</strong> does not exist.</p>
            <p>Please check the URL or contact an administrator.</p>
        </div>
    </div>
}
else if(ContentType == "text/markdown")
{
    <LayoutArea Address="@TargetAddress" Area="@ContentCollectionsExtensions.ContentAreaName" Id="@(ResolvedCollection + '/' + ResolvedPath)"/>
}
else if (Content != null)
{
    if (ContentType?.StartsWith("image/") == true)
    {
        <img src="data:@ContentType;base64,@Convert.ToBase64String(ReadStream(Content))" />
    }
    else if (ContentType == "text/plain")
    {
        <pre>@ReadStreamAsString(Content)</pre>
    }
    else if (ContentType == "application/pdf")
    {
        <iframe src="data:application/pdf;base64,@Convert.ToBase64String(ReadStream(Content))" width="100%" height="600px"></iframe>
    }
    else if (ContentType == "application/json")
    {
        <pre>@ReadStreamAsString(Content)</pre>
    }
    else if (ContentType == "text/csv")
    {
        @if (CsvHeaders != null && CsvRows != null)
        {
            <div style="overflow-x: auto; padding: 1rem;">
                <table style="border-collapse: collapse; width: 100%; font-size: 0.875rem;">
                    <thead>
                        <tr>
                            @foreach (var header in CsvHeaders)
                            {
                                <th style="border: 1px solid var(--neutral-stroke-rest, #ccc); padding: 6px 10px; background: var(--neutral-layer-card-container, #f5f5f5); text-align: left; white-space: nowrap;">@header</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in CsvRows.Take(CsvVisibleRows))
                        {
                            <tr>
                                @foreach (var cell in row)
                                {
                                    <td style="border: 1px solid var(--neutral-stroke-rest, #ccc); padding: 4px 10px; white-space: nowrap;">@cell</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
                <div style="padding: 8px 0; font-size: 0.85rem; color: var(--neutral-foreground-hint, #666);">
                    Showing @Math.Min(CsvVisibleRows, CsvRows.Count) of @CsvRows.Count rows
                    @if (CsvVisibleRows < CsvRows.Count)
                    {
                        <button style="margin-left: 12px; cursor: pointer; background: var(--accent-fill-rest, #0078d4); color: white; border: none; padding: 4px 12px; border-radius: 4px;"
                                @onclick="LoadMoreCsvRows">Load more</button>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p>Unsupported content type: @ContentType</p>
    }
}

