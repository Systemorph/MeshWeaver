<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ProjectGuid>{1f725ab9-e815-4601-ac4f-d3a7e4734e57}</ProjectGuid>
      <PackageId>MeshWeaver.BusinessRules.Generator</PackageId>
      <TargetFramework>netstandard2.0</TargetFramework>
      <PackageDescription>Code generation library for MeshWeaver.BusinessRules</PackageDescription>
      <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
      <NoPackageAnalysis>true</NoPackageAnalysis>
      <IncludeBuildOutput>false</IncludeBuildOutput>
      <DevelopmentDependency>true</DevelopmentDependency>
      <IsOrleansFrameworkPart>false</IsOrleansFrameworkPart>
      <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
      <IsRoslynComponent>true</IsRoslynComponent>
      <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
  </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" Version="5.3.0" />
        <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" Version="5.3.0" />
    </ItemGroup>
    <ItemGroup>
        <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
        <!-- ALSO ship the generator under lib/ so the runtime `#r "nuget:..."` resolver
             (NuGetAssemblyResolver → reader.GetLibItemsAsync, which reads lib/ ONLY) surfaces it
             and SourceGeneratorLoader can load + run it. Node Source pulls the generator via #r
             rather than a framework ProjectReference (which propagated the analyzer + bloated builds).
             Analyzer-style consumers (OutputItemType="Analyzer") keep using analyzers/dotnet/cs above. -->
        <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="lib/netstandard2.0" Visible="false" />
    </ItemGroup>

</Project>
