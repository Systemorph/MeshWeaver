<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ProjectGuid>{1f725ab9-e815-4601-ac4f-d3a7e4734e57}</ProjectGuid>
      <PackageId>MeshWeaver.BusinessRules.Generator</PackageId>
      <TargetFramework>netstandard2.0</TargetFramework>
      <PackageDescription>Code generation library for MeshWeaver.BusinessRules</PackageDescription>
      <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
      <NoPackageAnalysis>true</NoPackageAnalysis>
      <IncludeBuildOutput>false</IncludeBuildOutput>
      <DevelopmentDependency>true</DevelopmentDependency>
      <IsOrleansFrameworkPart>false</IsOrleansFrameworkPart>
      <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
      <IsRoslynComponent>true</IsRoslynComponent>
      <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
  </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" Version="5.3.0" />
        <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" Version="5.3.0" />
    </ItemGroup>
    <ItemGroup>
        <!-- Pack the generator DLL to BOTH analyzers/ (the Roslyn analyzer pipeline, for
             build-time consumers) AND lib/ (so a node's
             `#r "nuget:MeshWeaver.BusinessRules.Generator"` resolves it — INuGetAssemblyResolver
             reads lib/ only — and SourceGeneratorLoader can discover + run ScopeCodeGenerator
             at node-compile time). One <None> with two semicolon-separated PackagePaths: two
             entries with the same Include collapse to one in MSBuild. Microsoft.CodeAnalysis
             stays PrivateAssets=all, so #r consumers get no transitive dependency. -->
        <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true"
              PackagePath="analyzers/dotnet/cs;lib/netstandard2.0" Visible="false" />
    </ItemGroup>

</Project>
