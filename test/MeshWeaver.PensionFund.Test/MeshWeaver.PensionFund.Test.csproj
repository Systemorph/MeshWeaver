<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ProjectGuid>{e8b3f2c1-9d4a-4f6e-a7b8-2c3d4e5f6a1b}</ProjectGuid>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>$(NoWarn);xUnit1051</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Pre-copy samples/Graph for tests -->
    <Content Include="..\..\samples\Graph\**">
      <Link>SamplesGraph\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <!-- Compile-time validation of the mesh node DATA records (dimension + fact types) so a
         malformed sample fails this build, not the portal. BalanceSheetScopes.cs is intentionally
         NOT here: it carries a `#r "nuget:MeshWeaver.BusinessRules.Generator"` directive (the runtime
         compiler strips #r, but a regular `<Compile>` rejects it — CS7011). Its scope codegen is
         covered build-time by FxConversionScopeTest (generator-as-analyzer) and end-to-end by the
         runtime render tests in THIS project; the #r-feed resolution by NuGetAssemblyResolverTest. -->
    <Compile Include="..\..\samples\Graph\Data\PensionFund\Position\Source\Position.cs" Link="MeshNodeSources\Position.cs" />
    <Compile Include="..\..\samples\Graph\Data\PensionFund\Year\Source\Year.cs" Link="MeshNodeSources\Year.cs" />
    <Compile Include="..\..\samples\Graph\Data\PensionFund\Currency\Source\Currency.cs" Link="MeshNodeSources\Currency.cs" />
    <Compile Include="..\..\samples\Graph\Data\PensionFund\BalanceSheetEntry\Source\BalanceSheetEntry.cs" Link="MeshNodeSources\BalanceSheetEntry.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\MeshWeaver.BusinessRules\MeshWeaver.BusinessRules.csproj" />
    <ProjectReference Include="..\..\src\MeshWeaver.BusinessRules.Generator\MeshWeaver.BusinessRules.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\src\MeshWeaver.Fixture\MeshWeaver.Fixture.csproj" />
    <ProjectReference Include="..\..\src\MeshWeaver.Hosting.Monolith\MeshWeaver.Hosting.Monolith.csproj" />
    <ProjectReference Include="..\..\src\MeshWeaver.Hosting\MeshWeaver.Hosting.csproj" />
    <ProjectReference Include="..\..\src\MeshWeaver.Hosting.Monolith.TestBase\MeshWeaver.Hosting.Monolith.TestBase.csproj" />
    <ProjectReference Include="..\..\src\MeshWeaver.Layout\MeshWeaver.Layout.csproj" />
    <ProjectReference Include="..\..\src\MeshWeaver.Graph\MeshWeaver.Graph.csproj" />
    <ProjectReference Include="..\..\src\MeshWeaver.Mesh.Contract\MeshWeaver.Mesh.Contract.csproj" />
    <ProjectReference Include="..\..\src\MeshWeaver.Messaging.Hub\MeshWeaver.Messaging.Hub.csproj" />
  </ItemGroup>
</Project>
